# Vivado temporary files
.Xil/
hs_err_pid*.dmp
hs_err_pid*.log
vivado_pid*.str
vivado*.jou
vivado*.log

# Python cache
__pycache__/
*.pyc

# Project files (kept but user-specific)
projects/*
!projects/.gitkeep

# Screenshots are generated by scripts/capture_screenshot.py and contain
# user-specific window contents (project paths, source filenames, etc.).
# Don't commit them.
screenshots/

# Local configuration
