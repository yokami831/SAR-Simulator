{
  "id": "comment",
  "label": "Comment",
  "category": "Utility",
  "description": "Text note / annotation. Plain text by default; optionally add a colored border and background to act as a labelled frame around other nodes (set border_width > 0). Double-click to edit text (Enter inserts a newline), right-click → Edit Style for fonts/colors/borders.",
  "parameters": [
    {
      "id": "text",
      "label": "Text",
      "dtype": "code",
      "default": ""
    },
    {
      "id": "font_size",
      "label": "Font Size",
      "dtype": "enum",
      "options": ["12", "14", "16", "20", "24", "32", "48"],
      "default": "14"
    },
    {
      "id": "font_weight",
      "label": "Weight",
      "dtype": "enum",
      "options": ["normal", "bold"],
      "default": "normal"
    },
    {
      "id": "text_color",
      "label": "Text Color",
      "dtype": "color",
      "default": "#e0e0e0"
    },
    {
      "id": "bg_color",
      "label": "Background",
      "dtype": "color",
      "default": "transparent"
    },
    {
      "id": "border_color",
      "label": "Border Color",
      "dtype": "color",
      "default": "#5078c8"
    },
    {
      "id": "border_style",
      "label": "Border Style",
      "dtype": "enum",
      "options": ["solid", "dashed", "dotted"],
      "default": "dashed"
    },
    {
      "id": "border_width",
      "label": "Border Width",
      "dtype": "enum",
      "options": ["0", "1", "2", "3", "4"],
      "default": "0"
    }
  ],
  "inputs": [],
  "outputs": [],
  "code_template": ""
}
