      {
        "id": "n31",
        "type": "canvasNode",
        "position": {
          "x": 2.6462366243377744,
          "y": 424.8317982939334
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# === Plot library (workspace-local) ===\n# Display/interpolation helpers for this SAR workspace. Defined here as a\n# visible first node (not hidden in app code) so they are easy to find and\n# edit, and shared with every downstream node via the kernel namespace.\n# See this block's SPEC for what each function does.\n\nimport json as _json\nfrom IPython.display import display as _display, HTML as _HTML\n\n# Display vertex cap used by crop_upsample_factor to bound the upsampled-crop\n# vertex count so a complex-upsampled crop stays under the 4GB-capped renderer\n# heap. (The _gl display path is full resolution / no max-pool.)\nMAX_VERTS = 250000  # ~500x500\n\ndef crop_upsample_factor(n_rows, n_cols, cap=MAX_VERTS, fmax=6, range_only=False):\n    \"\"\"Largest integer upsample factor F in [1..fmax] keeping the upsampled crop\n    under `cap` vertices, so a crop can be x-upsampled WITHOUT being max-pooled\n    afterwards (pooling a deliberate upsample is self-defeating).\n      2D  (upsample_complex, both axes): verts ~= ((R-1)*F+1)*((C-1)*F+1)\n          -> F ~= floor(sqrt(cap/(R*C)))\n      range-only (upsample_complex_range, only last axis; rows stay full):\n          verts ~= R*((C-1)*F+1) -> F ~= floor((cap/R - 1)/(C-1))\n          (If R alone already nears cap, F clamps to 1 and the caller should pool\n           the ROW axis only via pool='rows' to fit — that keeps range detail.)\n    n_rows/n_cols are the crop's sample counts BEFORE upsampling.\"\"\"\n    import math as _math\n    R = max(1, int(n_rows)); C = max(1, int(n_cols))\n    if range_only:\n        if C <= 1:\n            return max(1, min(fmax, int(cap // R)))\n        F = int((cap / R - 1) // (C - 1))\n    else:\n        F = int(_math.floor(_math.sqrt(cap / (R * C))))\n    return max(1, min(fmax, F))\n\n\ndef _catmull(p0,p1,p2,p3,t):\n    t2=t*t; t3=t2*t\n    return 0.5*(2*p1+(-p0+p2)*t+(2*p0-5*p1+4*p2-p3)*t2+(-p0+3*p1-3*p2+p3)*t3)\ndef _interp_axis(a, f):\n    import numpy as _np\n    N=a.shape[-1]; outN=(N-1)*f+1; oc=_np.arange(outN); fc=oc/f\n    c1=_np.minimum(N-2,_np.floor(fc).astype(int)); tc=fc-c1\n    cm1=_np.clip(c1-1,0,N-1); c0=_np.clip(c1,0,N-1); cp1=_np.clip(c1+1,0,N-1); cp2=_np.clip(c1+2,0,N-1)\n    return _catmull(a[...,cm1],a[...,c0],a[...,cp1],a[...,cp2],tc)\ndef upsample_complex(field, factor):\n    import numpy as _np\n    f=int(factor)\n    if f<=1: return _np.abs(field)\n    re=field.real; im=field.imag\n    re=_interp_axis(re,f); im=_interp_axis(im,f)\n    re=_np.moveaxis(_interp_axis(_np.moveaxis(re,0,-1),f),-1,0)\n    im=_np.moveaxis(_interp_axis(_np.moveaxis(im,0,-1),f),-1,0)\n    return _np.hypot(re,im)\ndef upsample_axis(ax, f):\n    import numpy as _np\n    f=int(f); return _np.linspace(float(ax[0]), float(ax[-1]), (len(ax)-1)*f+1) if f>1 else _np.asarray(ax)\n\ndef upsample_complex_range(field, factor):\n    \"\"\"Complex upsample along the LAST axis (range) only — re/im interpolated\n    separately, then magnitude. Use for Range-Doppler/RCMC crops where only the\n    range axis is cropped and the Doppler axis must stay as-is.\"\"\"\n    import numpy as _np\n    f = int(factor)\n    if f <= 1:\n        return _np.abs(field)\n    re = _interp_axis(field.real, f)\n    im = _interp_axis(field.imag, f)\n    return _np.hypot(re, im)\n\ndef _emit_surface_gl(tv, xa, ya, title, xlabel, ylabel, status, db_vmin, db_vmax, H=0.35):\n    \"\"\"Emit the surface as the binary single-renderer mime.\n    tv: float32 0..1 dB-normalised grid (already mapped to [db_vmin, db_vmax]).\n    Vertices go out as base64(Float32Array).\n    db_vmin/db_vmax tell the frontend ColorBar what absolute dBFS range tv=[0,1] maps to.\"\"\"\n    import numpy as _np, base64 as _b64, json as _json2\n    tvf = _np.ascontiguousarray(tv, dtype=_np.float32)\n    nr, nc = tvf.shape\n    meta = {'kind':'single','title':title,'status':status,\n        'nrows':int(nr),'ncols':int(nc),'H':float(H),\n        'xr':[float(_np.min(xa)),float(_np.max(xa))],\n        'yr':[float(_np.min(ya)),float(_np.max(ya))],\n        'xlabel':xlabel,'ylabel':ylabel,'dtype':'float32',\n        'db_vmin':float(db_vmin), 'db_vmax':float(db_vmax),\n        'field_b64':_b64.b64encode(tvf.tobytes()).decode('ascii')}\n    _display({'application/x-hiyocanvas-surface3d': _json2.dumps(meta)}, raw=True)\n    print('surface3d_gl: %d x %d = %d cells, payload %.1f MB (binary path)' %\n          (nr, nc, nr*nc, len(meta['field_b64'])/1e6))\n\nDB_VMIN_DEFAULT = -40.0   # display floor [dBFS]  (40 dB dynamic range, typical SAR)\nDB_VMAX_DEFAULT =   0.0   # display ceiling [dBFS] = ADC/DAC full scale.\nDB_WINDOW       =  40.0   # default dynamic range window [dB] used by peak_relative mode\n\ndef _resolve_db_range(peak_dbfs, peak_relative, db_window, db_vmin, db_vmax):\n    \"\"\"Pick (vmin, vmax) for a panel.\n      peak_relative=False: use (db_vmin or DB_VMIN_DEFAULT, db_vmax or DB_VMAX_DEFAULT)\n                           — absolute dBFS, ADC full-scale = top.\n      peak_relative=True:  slide a `db_window` (default 40 dB) window so the peak\n                           sits at vmax (rounded up to a nice 5 dB step). Lets you\n                           see signals far below ADC FS (pre-compression stages)\n                           without losing 40 dB dynamic range.\n    \"\"\"\n    if peak_relative:\n        import math as _math\n        # Round up to nearest 5 dB so the top tick is a tidy number.\n        vmax = 5.0 * _math.ceil(peak_dbfs / 5.0)\n        vmin = vmax - float(db_window)\n    else:\n        vmax = DB_VMAX_DEFAULT if db_vmax is None else float(db_vmax)\n        vmin = DB_VMIN_DEFAULT if db_vmin is None else float(db_vmin)\n    return vmin, vmax\n\ndef surface3d_gl(field, x_axis, y_axis, title, xlabel='range [m]', ylabel='azimuth [m]',\n                 x_range=None, y_range=None, status=None,\n                 peak_relative=False, db_window=DB_WINDOW, db_vmin=None, db_vmax=None):\n    \"\"\"Binary single-renderer surface plot in dB.\n    Default (peak_relative=False): absolute dBFS display, range [-40, 0] dBFS\n      so signal-level changes (g_lna_db / σ°_max) move colors instead of being\n      hidden by peak normalisation. ADC FS = 0 dBFS = visual saturation marker.\n    peak_relative=True: window slides so peak sits at vmax (rounded to 5 dB),\n      vmin = vmax - db_window. Use for plots where signal sits far below FS\n      (pre-compression stages) so you can still see structure with 40 dB DR.\"\"\"\n    import numpy as _np\n    A = _np.abs(field) if _np.iscomplexobj(field) else _np.asarray(field)\n    xa = _np.asarray(x_axis); ya = _np.asarray(y_axis)\n    if x_range is not None:\n        sel=_np.where((xa>=x_range[0])&(xa<=x_range[1]))[0]; j0,j1=int(sel[0]),int(sel[-1]); A=A[:,j0:j1+1]; xa=xa[j0:j1+1]\n    if y_range is not None:\n        sel=_np.where((ya>=y_range[0])&(ya<=y_range[1]))[0]; i0,i1=int(sel[0]),int(sel[-1]); A=A[i0:i1+1,:]; ya=ya[i0:i1+1]\n    peak_dbfs = float(20*_np.log10(A.max()+1e-12))\n    vmin, vmax = _resolve_db_range(peak_dbfs, peak_relative, db_window, db_vmin, db_vmax)\n    dbv = 20*_np.log10(A + 1e-12); dbv = _np.clip(dbv, vmin, vmax)\n    tv = ((dbv - vmin) / (vmax - vmin)).astype(_np.float32)\n    title = title + ' (peak=%+.1f dBFS)' % peak_dbfs\n    _emit_surface_gl(tv, xa, ya, title, xlabel, ylabel, status, vmin, vmax)\n\n\ndef _surf_gl_sub(field, x_axis, y_axis, title, xlabel, ylabel, status,\n                 peak_relative, db_window, db_vmin, db_vmax, H=0.35):\n    \"\"\"Build one sub-payload dict (a or b) for surface3d_pair_gl.\"\"\"\n    import numpy as _np, base64 as _b64\n    A = _np.abs(field) if _np.iscomplexobj(field) else _np.asarray(field)\n    xa = _np.asarray(x_axis); ya = _np.asarray(y_axis)\n    peak_dbfs = float(20*_np.log10(A.max()+1e-12))\n    vmin, vmax = _resolve_db_range(peak_dbfs, peak_relative, db_window, db_vmin, db_vmax)\n    dbv = 20*_np.log10(A + 1e-12); dbv = _np.clip(dbv, vmin, vmax)\n    tv = ((dbv - vmin) / (vmax - vmin)).astype(_np.float32); tvf=_np.ascontiguousarray(tv,dtype=_np.float32)\n    title = title + ' (peak=%+.1f dBFS)' % peak_dbfs\n    nr,nc = tvf.shape\n    return {'title':title,'status':status,'nrows':int(nr),'ncols':int(nc),'H':float(H),\n        'xr':[float(_np.min(xa)),float(_np.max(xa))],'yr':[float(_np.min(ya)),float(_np.max(ya))],\n        'xlabel':xlabel,'ylabel':ylabel,'dtype':'float32',\n        'db_vmin':float(vmin), 'db_vmax':float(vmax),\n        'field_b64':_b64.b64encode(tvf.tobytes()).decode('ascii')}\n\ndef surface3d_pair_gl(field_a, xa, ya, title_a, field_b, xb, yb, title_b,\n                      xlabel_a='range [m]', ylabel_a='azimuth [m]', xlabel_b=None, ylabel_b=None,\n                      status_a=None, status_b=None,\n                      peak_relative=False, db_window=DB_WINDOW, db_vmin=None, db_vmax=None):\n    \"\"\"Pair (Full=a / Crop=b toggle). dB-norm options same as surface3d_gl.\n    peak_relative is per-panel: each panel's vmax tracks its own peak.\"\"\"\n    import json as _json2\n    if xlabel_b is None: xlabel_b = xlabel_a\n    if ylabel_b is None: ylabel_b = ylabel_a\n    a = _surf_gl_sub(field_a, xa, ya, title_a, xlabel_a, ylabel_a, status_a,\n                     peak_relative, db_window, db_vmin, db_vmax)\n    b = _surf_gl_sub(field_b, xb, yb, title_b, xlabel_b, ylabel_b, status_b,\n                     peak_relative, db_window, db_vmin, db_vmax)\n    meta = {'kind':'pair','a':a,'b':b}\n    _display({'application/x-hiyocanvas-surface3d': _json2.dumps(meta)}, raw=True)\n    print('surface3d_pair_gl: A %dx%d / B %dx%d, payload %.1f MB (binary path)' %\n          (a['nrows'],a['ncols'],b['nrows'],b['ncols'],(len(a['field_b64'])+len(b['field_b64']))/1e6))\n\nprint('plot library ready: crop_upsample_factor, upsample_complex, upsample_complex_range, upsample_axis, surface3d_gl, surface3d_pair_gl  (peak_relative supported)')\n",
            "label": "Plot Library",
            "spec": "Plot library for this SAR workspace (workspace-local, not app code). Defined as an unconnected first node so it runs before everything (input-unconnected nodes execute first) and shares its functions with all downstream nodes via the kernel namespace.\n\nFunctions:\n- surface3d(field, x_axis, y_axis, title, xlabel, ylabel, x_range, y_range, status): interactive Three.js 3D dB surface (inferno, -40..0 dB). x_range/y_range crop range/azimuth. On-demand render; left-drag rotate, right-drag pan, wheel zoom; Expand opens a new window.\n- upsample_complex(field, factor): 2-axis complex Catmull-Rom upsample (re/im then |z|) for smooth sidelobes on cropped views.\n- upsample_complex_range(field, factor): complex upsample along the range axis only (Range-Doppler/RCMC crops; Doppler stays as-is).\n- upsample_axis(ax, factor): matching linear upsample of an axis vector.\n- _catmull/_interp_axis: internal Catmull-Rom helpers."
          },
          "codeCollapsed": true,
          "executionOrder": 7
        },
        "width": 400,
        "style": {}
      },
      {
        "id": "n32",
        "type": "canvasNode",
        "position": {
          "x": 2160.7966858033133,
          "y": 280.8485750918655
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# === Reflection Coefficients (NUFFT) — Common stage for all FPGA routes ===\n# Self-contained NUFFT forward model. Builds frequency-domain reflection\n# coefficients S_all (Na,Nr) complex64 from POINT targets or an IMAGE target\n# (2D reflectivity), using finufft type-1. Uses GPU cufinufft when available\n# (no GPU<->CPU transfer, no CPU spreading); falls back to parallel CPU\n# finufft otherwise.\n#\n# This node STOPS at coefficient generation — it does NOT compute s_raw.\n# The downstream \"FPGA Route X\" nodes (Float / Fixed / FPGA-Save / FPGA-Load)\n# consume S_all + chirp_fft (+ fir_coefficients) and produce s_raw.\n#\n# Variables left in the kernel namespace for the route nodes:\n#   S_all            (Na, Nr) complex64  — frequency-domain reflection coeffs\n#   chirp_fft        (Nr,)    complex64  — fft(ref_chirp), NOT conjugated\n#   fir_coefficients (Na, Nr) complex64  — time-domain FIR taps per pulse\n#                                          = ifftshift(ifft(S_all, axis=1))\n#                                          (same form as the FPGA Notebook)\nimport numpy as np\nimport finufft               # CPU fallback\nimport cupy as cp           # MUST import before cufinufft: cupy registers the\n                            # CUDA runtime DLL directory (os.add_dll_directory),\n                            # without which cufinufft's native lib fails to load\n                            # (\"Could not find cufinufft library in system path\").\ntry:\n    import cufinufft         # GPU NUFFT (type-1). ~194s -> ~70s when present.\n    _HAVE_CUFINUFFT = True\nexcept Exception as _e:\n    _HAVE_CUFINUFFT = False\n    _CUFINUFFT_ERR = repr(_e)\nimport concurrent.futures\nimport time as _time\n\nNUFFT_EPS = 1e-6      # accuracy floor (~120 dB). Lower to 1e-9 for higher.\nN_WORKERS = 8         # outer parallelism; finufft inner nthreads=1\n_t0 = _time.monotonic()\n\n# ---- 0. Self-contained clutter helper (was defined in the removed n7) ----\ndef make_clutter_scatterers(count, rcs_db, half_az_m, half_range_m, seed, R0):\n    rnd = make_rand(seed)\n    sigma = (10.0 ** (rcs_db / 20.0)) / np.sqrt(2.0)\n    out = []\n    for i in range(int(count)):\n        az_m = (rnd() * 2 - 1) * half_az_m\n        sr_m = R0 + (rnd() * 2 - 1) * half_range_m\n        u1 = max(rnd(), 1e-12); u2 = rnd()\n        mag = sigma * np.sqrt(-2.0 * np.log(u1))\n        out.append(('clutter%d' % i, az_m, sr_m, mag * np.cos(2*np.pi*u2), mag * np.sin(2*np.pi*u2)))\n    return out\n\n# ---- 1. Build the source list: point targets, clutter, OR an image ----\n_mode = str(globals().get('target_mode', 'point')).strip().lower()\nTARGET_SEED  = 42\nCLUTTER_SEED = 2\nhalf = float(view_scale)\n\n# Level 2 RF physics: σ°_max sets the *amplitude scale* of the brightest scatterer\n# (in voltage units relative to \"1.0 = reference white pixel / unit point target\").\n# σ° is power (m²/m²) so amplitude scales as 10^(σ°_dB / 20). For image targets,\n# the per-pixel image_amp ∈ [0,1] additionally weights this. For point targets,\n# each point gets the full σ°_max amplitude.\nsigma0_max_db = float(globals().get('sigma0_max_db', 0.0))\nsigma0_amp = 10.0 ** (sigma0_max_db / 20.0)\n\nif _mode == 'image':\n    from PIL import Image\n    _path = str(globals().get('image_path', '')).strip()\n    if not _path:\n        raise ValueError(\"target_mode='image' but image_path is empty — pick a file in the Image File block\")\n    _invert = str(globals().get('invert_image', 'true')).strip().lower() in ('1', 'true', 'on', 'yes')\n    _img = Image.open(_path).convert('L')\n    _gray = np.asarray(_img, dtype=np.float32)\n    if _invert:\n        _gray = 255.0 - _gray\n    _rscale = float(globals().get('range_scale', 1.0))\n    _sp_rg = (c / (2 * B)) * _rscale\n    _sp_az = La / 2.0\n    _H, _W = _gray.shape\n    _cell_rg = c / (2 * Fs)\n    _max_cols = int(np.floor(Nr * _cell_rg / max(_sp_rg, 1e-12)))\n    _az_span = float(az_pos.max() - az_pos.min())\n    _max_rows = int(np.floor(_az_span / _sp_az)) + 1\n    _cropped = False\n    if _W > _max_cols:\n        print('!! IMAGE TOO WIDE (range): %d px * range_scale %.2f > Nr %d. Cropping range to %d px (top-left). Lower range_scale or raise Nr to see it all.' % (_W, _rscale, Nr, _max_cols))\n        _gray = _gray[:, :_max_cols]; _cropped = True\n    if _H > _max_rows:\n        print('!! IMAGE TOO TALL (azimuth): %d px > az grid %d px. Cropping azimuth to %d px (top-left).' % (_H, _max_rows, _max_rows))\n        _gray = _gray[:_max_rows, :]; _cropped = True\n    _H, _W = _gray.shape\n    _rows, _cols = np.where(_gray > 0)\n    if len(_rows) == 0:\n        raise ValueError(\"image has no non-zero pixels after invert=%s / crop\" % _invert)\n    az_arr = (_rows - _H / 2.0) * _sp_az\n    sr_arr = R0 + (_cols - _W / 2.0) * _sp_rg\n    amp_arr = (_gray[_rows, _cols] / 255.0).astype(np.float64)\n    src_az = az_arr.astype(np.float64)\n    src_sr = sr_arr.astype(np.float64)\n    src_re = (amp_arr * sigma0_amp).astype(np.float64)   # image_amp × σ°_max amplitude\n    src_im = np.zeros_like(src_re)\n    NT = len(src_az)\n    print('IMAGE target: %s  %dx%d  %d scatterers (invert=%s)  σ°_max=%+.1f dB  spacing %.2f x %.2f m  window +/-%.0f m'\n          % (_path.split('/')[-1].split('\\\\')[-1], _H, _W, NT, _invert, sigma0_max_db, _sp_rg, _sp_az, half))\nelse:\n    sources = [(n, a, s, sigma0_amp, 0.0) for (n, a, s) in\n               make_point_targets(n_targets, half, half, TARGET_SEED, R0)]\n    n_clutter = int(clutter_n)\n    if n_clutter > 0:\n        sources += make_clutter_scatterers(n_clutter, clutter_rcs_db, half, half, CLUTTER_SEED, R0)\n    src_az = np.array([s[1] for s in sources], dtype=np.float64)\n    src_sr = np.array([s[2] for s in sources], dtype=np.float64)\n    src_re = np.array([s[3] for s in sources], dtype=np.float64)\n    src_im = np.array([s[4] for s in sources], dtype=np.float64)\n    NT = len(sources)\n    print('POINT sources: %d point + %d clutter  σ°_max=%+.1f dB  window=+/-%.0f m' % (n_targets, n_clutter, sigma0_max_db, half))\n\n# ---- 2. Forward chirp spectrum: fft(ref_chirp), NOT conjugated, NO ifftshift ----\nchirp_fft = np.fft.fft(ref_chirp).astype(np.complex64)\n\n# ---- 3. GPU precompute weights + NUFFT coords; CPU parallel finufft ----\naz_t = cp.asarray(src_az, dtype=cp.float64)\nsr_t = cp.asarray(src_sr, dtype=cp.float64)\nrefl = cp.asarray((src_re + 1j * src_im).astype(np.complex64), dtype=cp.complex64)\naz_g = cp.asarray(az_pos, dtype=cp.float64)\nt_r_center = float(2 * R0 / c)\ninv_lam = 1.0 / float(lam)\n\n_xb_chk = -2.0 * np.pi * Fs * (2.0 * src_sr / c - t_r_center) / Nr\n_xb_max = float(np.abs(_xb_chk).max())\nif _xb_max > np.pi:\n    _fold_pct = 100.0 * float((np.abs(_xb_chk) > np.pi).mean())\n    _ext_cells = (src_sr.max() - src_sr.min()) / (c / (2 * Fs))\n    print((\"!! NUFFT FOLD WARNING: x_b reaches %.2f*pi (>1). %.0f%% of scatterers \"\n           \"fold (alias) -> spurious range banding. Image range extent = %.0f cells \"\n           \"but grid Nr = %d. Fix: lower range_scale, use a smaller image, or raise \"\n           \"Nr. Result is NOT physically correct.\") % (_xb_max/np.pi, _fold_pct, _ext_cells, Nr))\n\n\nS_all = np.zeros((Na, Nr), dtype=np.complex64)\n\nif _HAVE_CUFINUFFT:\n    gpu_pb = max(4, min(512, int(2e9 / max(1, NT) / 32)))\n    print('GPU NUFFT (cufinufft): gpu_pb=%d  n_batches=%d  NT=%d' % (gpu_pb, (Na+gpu_pb-1)//gpu_pb, NT))\n    _cuplan = cufinufft.Plan(1, (Nr,), eps=NUFFT_EPS, isign=1, dtype='complex64')\n    S_gpu_acc = cp.empty((Na, Nr), dtype=cp.complex64)\n    for pstart in range(0, Na, gpu_pb):\n        pend = min(pstart + gpu_pb, Na)\n        azb = az_g[pstart:pend]\n        daz = azb[:, None] - az_t[None, :]\n        R_eta = cp.sqrt(sr_t[None, :]**2 + daz**2)\n        squint = cp.arctan2(daz, sr_t[None, :])\n        pat = cp.sinc(squint / theta_az) ** 2\n        tau = 2.0 * R_eta / c\n        x_b = (-2.0 * np.pi * Fs * (tau - t_r_center) / Nr).astype(cp.float32)\n        carrier = cp.exp(-4j * np.pi * R_eta * inv_lam).astype(cp.complex64)\n        # Level 2: 1/R² range-loss amplitude factor per scatterer per pulse.\n        # Normalized by R0 so the magnitude stays ~1 (R_eta ≈ R0 ± 100m for SAR\n        # swaths). Captures the *relative* range loss within a swath; absolute\n        # link-budget scaling is applied later in n25 (signal_peak_dBFS).\n        range_loss = ((R0 / R_eta) ** 2).astype(cp.complex64)\n        w_b = (refl[None, :] * pat.astype(cp.complex64) * carrier * range_loss).astype(cp.complex64)\n        del daz, R_eta, squint, pat, tau, carrier, range_loss\n        for i in range(pend - pstart):\n            _cuplan.setpts(cp.ascontiguousarray(x_b[i]))\n            S_gpu_acc[pstart + i] = cp.fft.ifftshift(_cuplan.execute(cp.ascontiguousarray(w_b[i])))\n        del x_b, w_b\n        cp.get_default_memory_pool().free_all_blocks()\n        print('\\r  pulses %d/%d (%.0f%%)' % (pend, Na, 100*pend/Na), end='')\n    S_all = cp.asnumpy(S_gpu_acc)\n    del S_gpu_acc\n    cp.get_default_memory_pool().free_all_blocks()\nelse:\n    print('GPU cufinufft unavailable (%s) -> CPU finufft fallback' % _CUFINUFFT_ERR)\n    gpu_pb = max(4, min(512, int(2e9 / max(1, NT) / 32)))\n\n    def _nufft_chunk(x_chunk, w_chunk, row_start):\n        plan = finufft.Plan(1, (Nr,), eps=NUFFT_EPS, isign=1,\n                            dtype='complex64', nthreads=1)\n        out = np.empty((len(x_chunk), Nr), dtype=np.complex64)\n        for i in range(len(x_chunk)):\n            plan.setpts(x_chunk[i])\n            out[i] = np.fft.ifftshift(plan.execute(w_chunk[i]))\n        return row_start, out\n\n    for pstart in range(0, Na, gpu_pb):\n        pend = min(pstart + gpu_pb, Na)\n        azb = az_g[pstart:pend]\n        daz = azb[:, None] - az_t[None, :]\n        R_eta = cp.sqrt(sr_t[None, :]**2 + daz**2)\n        squint = cp.arctan2(daz, sr_t[None, :])\n        pat = cp.sinc(squint / theta_az) ** 2\n        tau = 2.0 * R_eta / c\n        x_b = cp.asnumpy((-2.0 * np.pi * Fs * (tau - t_r_center) / Nr).astype(cp.float32))\n        carrier = cp.exp(-4j * np.pi * R_eta * inv_lam).astype(cp.complex64)\n        # Level 2: 1/R² range-loss (same as GPU path above).\n        range_loss = ((R0 / R_eta) ** 2).astype(cp.complex64)\n        w_b = cp.asnumpy((refl[None, :] * pat.astype(cp.complex64) * carrier * range_loss).astype(cp.complex64))\n        del daz, R_eta, squint, pat, tau, carrier, range_loss\n        cp.get_default_memory_pool().free_all_blocks()\n        nb = pend - pstart\n        sub = max(1, nb // N_WORKERS)\n        chunks = [(x_b[i:i+sub], w_b[i:i+sub], i) for i in range(0, nb, sub)]\n        with concurrent.futures.ThreadPoolExecutor(max_workers=N_WORKERS) as ex:\n            for fut in concurrent.futures.as_completed(\n                    [ex.submit(_nufft_chunk, xc, wc, st) for xc, wc, st in chunks]):\n                st, res = fut.result()\n                S_all[pstart + st: pstart + st + len(res)] = res\n        print('\\r  pulses %d/%d (%.0f%%)' % (pend, Na, 100*pend/Na), end='')\n\n# ---- 4. Time-domain FIR taps for FPGA / Route B (fixed-point) ----\n# fir_coefficients[i, :] = ifft(S_all[i, :])  — NO fftshift.\n# Why no shift: Route B simulates FPGA's FFT-multiply-IFFT path, so\n# fft(fir_coefficients) must equal S_all exactly. A fftshift would inject\n# a (-1)^k factor in frequency domain and Route B's s_raw would be circularly\n# shifted by Nr/2 relative to Route A. Route C-out (.mat save) saves this\n# unshifted form; external HDL viewers can fftshift on display if desired.\nfir_coefficients = np.fft.ifft(S_all, axis=1).astype(np.complex64)\n\nprint('\\nNUFFT coeffs ready: mode=%s S_all=%s chirp_fft=%s fir_coeffs=%s NT=%d  (%.2fs)'\n      % (_mode, S_all.shape, chirp_fft.shape, fir_coefficients.shape, NT, _time.monotonic() - _t0))\n",
            "label": "Reflection Coefficients (NUFFT, common)",
            "spec": "【共通ステージ】NUFFTで反射係数を生成するだけのノード。s_raw は計算しない。\n\n出力（kernel namespace 経由で下流の FPGA ルートノードへ）:\n- S_all (Na, Nr) complex64  — 周波数領域反射係数（NUFFT 直出力）\n- chirp_fft (Nr,) complex64 — fft(ref_chirp)、共役なし・ifftshift なし\n- fir_coefficients (Na, Nr) complex64 — 時間領域FIRタップ = ifftshift(ifft(S_all, axis=1))。FPGA Notebook（target_sim_FFT_FPGA_convert2Image2_375M.ipynb）と同じ形式\n\n3つのFPGAルート（Float / Fixed-point / 外部FPGA）はすべてこのノードの出力を共有する。下記ルートノードのいずれかを Enabled にして s_raw を生成する:\n- n32_Float       : Route A — 浮動小数点理想 IFFT（デフォルト Enabled）\n- n32_Fixed       : Route B — fxpmath 固定小数点（3ステージ Q-format）\n- n32_FPGA_Save   : Route C-out — 係数を .mat に書き出し（HDL シミュ用）\n- n32_FPGA_Load   : Route C-in  — FPGA出力の .npy を取り込み s_raw として使用\n\n性能: NUFFT本体（~84s on RTX 5080）は旧 n32 と同じ。末尾の IFFT（~1秒）だけ各ルートノードへ移動した。"
          },
          "codeCollapsed": true,
          "executionOrder": 14
        },
        "width": 503,
        "style": {}
      },
      {
        "id": "n41",
        "type": "canvasNode",
        "position": {
          "x": 2606.207951414265,
          "y": 1990.130104050218
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# Step 6 (2-D): top-down view of the focused image [img] in dB. The 3-D surface\n# (n18) shows valleys between azimuth ridges that, seen at an angle, can read as\n# features the image does not actually contain. This flat 2-D imshow is the\n# faithful top-down picture for judging the real focused image.\n#\n# Emits TWO separate PNGs (Full, then Crop). The frontend shows a Full/Crop\n# toggle + Expand for any node that emits multiple images. Display-only:\n# dB-normalised exactly like the 3-D path (20*log10(|img|/max), clipped -40..0),\n# inferno. Full is max-pooled to a display cap (peak-preserving, display only);\n# Crop is the view window at full resolution. The physical img is never modified.\n# Orientation: origin='upper' + y extent (max..min) so azimuth increases\n# DOWNWARD, matching the 3-D plot (n18) and keeping the image upright.\n# Aspect: aspect='equal' so range and azimuth share the same metric scale\n# (1 km in range = 1 km in azimuth on screen). The figure shape is driven by\n# the data extent, not stretched to fill the axes.\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport io, base64\nfrom IPython.display import display\n\n# Absolute dBFS display (reference = 1.0 = ADC FS). 40 dB standard SAR\n# dynamic range. DB_VMAX = 0 dBFS is the physical cap (anything above = signal\n# exceeds ADC/DAC full scale = visual saturation as a realistic indicator).\nDB_VMIN = -40.0\nDB_VMAX =   0.0\n\ndef _db(a):\n    A = np.abs(a)\n    d = 20.0 * np.log10(A + 1e-12)\n    return np.clip(d, DB_VMIN, DB_VMAX)\n\ndef _pool_to(a, cap=1200):\n    R, C = a.shape\n    fr = max(1, int(np.ceil(R / cap))); fc = max(1, int(np.ceil(C / cap)))\n    if fr == 1 and fc == 1:\n        return a\n    Rt = (R // fr) * fr; Ct = (C // fc) * fc\n    return a[:Rt, :Ct].reshape(Rt // fr, fr, Ct // fc, fc).max(axis=(1, 3))\n\ndef _emit_png(field_db, x0, x1, y0, y1, title, peak_dbfs):\n    # Figure size sized to data extent so aspect='equal' fits without huge margins.\n    dx = abs(x1 - x0); dy = abs(y1 - y0)\n    base_h = 4.5\n    img_w = base_h * (dx / dy) if dy > 0 else base_h\n    img_w = max(3.0, min(12.0, img_w))\n    fig_w = img_w + 1.8\n    fig, ax = plt.subplots(figsize=(fig_w, base_h + 0.6))\n    im = ax.imshow(field_db, origin='upper', cmap='inferno', vmin=DB_VMIN, vmax=DB_VMAX,\n                   aspect='equal', extent=[x0, x1, y0, y1])\n    ax.set_title('%s  (peak=%+.1f dBFS)' % (title, peak_dbfs))\n    ax.set_xlabel('range [m]'); ax.set_ylabel('azimuth [m]')\n    fig.colorbar(im, ax=ax, label='[dBFS]', shrink=0.85)\n    buf = io.BytesIO(); fig.savefig(buf, format='png', dpi=110, bbox_inches='tight')\n    plt.close(fig)\n    display({'image/png': base64.b64encode(buf.getvalue()).decode('ascii')}, raw=True)\n\nrg_axis = (t_r - t_r_center) * c / 2\n_W = float(view_scale)\n_rc = np.where((rg_axis >= -_W) & (rg_axis <= _W))[0]\n_ac = np.where((az_pos >= -_W) & (az_pos <= _W))[0]\n_crop = np.abs(img[_ac[0]:_ac[-1]+1, _rc[0]:_rc[-1]+1])\n_rgx = rg_axis[_rc[0]:_rc[-1]+1]; _azx = az_pos[_ac[0]:_ac[-1]+1]\n\n# 1) FULL (max-pooled for display)\n_full_abs = _pool_to(np.abs(img))\n_full_peak_dbfs = float(20*np.log10(_full_abs.max() + 1e-12))\nfull_db = _db(_full_abs)\n_emit_png(full_db, rg_axis.min(), rg_axis.max(), az_pos.max(), az_pos.min(),\n          'Focused image FULL (2-D)', _full_peak_dbfs)\n# 2) CROP (view window, full resolution — no pool)\n_crop_peak_dbfs = float(20*np.log10(_crop.max() + 1e-12))\ncrop_db = _db(_crop)\n_emit_png(crop_db, _rgx.min(), _rgx.max(), _azx.max(), _azx.min(),\n          'Focused image CROP (+/-%dm)' % int(_W), _crop_peak_dbfs)\nprint('2-D focused: full %s pooled %s peak=%+.1f dBFS | crop %s peak=%+.1f dBFS'\n      % (img.shape, full_db.shape, _full_peak_dbfs, _crop.shape, _crop_peak_dbfs))\n",
            "label": "Plot Focused Image (2-D)"
          },
          "codeCollapsed": true,
          "executionOrder": 32
        },
        "width": 687,
        "style": {}
      },
      {
        "id": "n42",
        "type": "canvasNode",
