          ],
          "defaultParameters": {
            "code": "# === FPGA Route B: Fixed-point (Q-format 3-stage, GPU) ===\n# FPGA で必然となるビット幅制限が SAR 画像品質にどう効くかを Python で評価する\n# ルート。FPGA でよくある FFT × 周波数乗算 × IFFT のパイプラインを cupy GPU で\n# 量子化しながら模擬する。3 ステージ独立 Q-format:\n#   Stage A : 入力時間領域 (FIR taps + chirp)  --> ADC ビット幅 (Q_IN_*)\n#   Stage B : FFT 後の周波数領域 + 乗算後      --> FPGA 内部演算 (Q_FFT_*)\n#   Stage C : IFFT 後の時間領域 (最終 s_raw)   --> DAC ビット幅 (Q_OUT_*)\n# 各ステージで auto-scale (peak->full-scale*0.95) → round-half-to-even +\n# saturate で量子化 → 復元。量子化 SNR を per-stage に GPU 上で計算して表示。\n#\n# 同時 Enable 排他: Route A (n42) / Route C-in (n47) と同時 Enable 不可\n# (s_raw が衝突する)。Route C-out (n44) とは併用可。\nimport numpy as np\nimport cupy as cp\nimport math\nimport time as _time\n_t0 = _time.monotonic()\n\n# --- Q-format parameters (このノード code を編集してチューニング) ----------\n# Stage A: 入力時間領域 = ADC ビット幅。10bit ADC は Q1.9 (1bit符号 + 9bit小数、\n# range ~[-1, 1))。chirp / FIR taps は概ね O(1) なのでこれで足りる\nQ_IN_W,  Q_IN_F  = 8, 7\n# Stage B: FFT 後周波数領域 (FPGA 内部演算)。N=Nr で log2(Nr) のビット成長を\n# 吸収するため広めに取る。Xilinx 7 系 DSP の 18bit に合わせて Q8.10\n# (整数 8bit + 小数 10bit、dynamic range ~256、分解能 ~0.001)\nQ_FFT_W, Q_FFT_F = 14, 4\n# Stage C: IFFT 後時間領域 = DAC ビット幅。10bit DAC は Q1.9\nQ_OUT_W, Q_OUT_F = 8, 7\n# -------------------------------------------------------------------------\n\n# fxpmath の signed Q(n_word-n_frac).n_frac 定義と等価の量子化を cupy で実装。\n# round-half-to-even (cp.rint と等価) + saturate (cp.clip)。numpy 版から1行\n# 単位で対応する形なので、結果はビット同一。\ndef _qaxis(v, n_word, n_frac, scale):\n    step = 2.0 ** (-n_frac)\n    iv_max =  (1 << (n_word - 1)) - 1\n    iv_min = -(1 << (n_word - 1))\n    return cp.clip(cp.round(v * scale / step), iv_min, iv_max) * step / scale\n\ndef qz(x, n_word, n_frac, name='', mode='auto'):\n    \"\"\"Quantize cupy complex array to Q(n_word-n_frac).n_frac signed.\n\n    mode='auto'  : Block Floating Point - auto-scale by peak so |x|_max -> FS*0.95.\n                   Output is rescaled back to original magnitude (peak preserved).\n                   Used for Stage B (FFT internal datapath) and Stage C.\n    mode='fixed' : Fixed Q-format at FS=2^(n_word-1-n_frac). NO auto-scale.\n                   Input must already be in [-FS, +FS] range (clipped if not).\n                   Used for Stage A (ADC quantize): the analog gain decided in\n                   n25 determines where the signal lands relative to FS.\n\n    Reports SNR and (for fixed) clip percentage.\"\"\"\n    import math\n    if x.size == 0:\n        return x.astype(cp.complex64)\n\n    if mode == 'fixed':\n        full_scale = float(2 ** (n_word - 1 - n_frac))\n        step = 2.0 ** (-n_frac)\n        iv_max =  (1 << (n_word - 1)) - 1\n        iv_min = -(1 << (n_word - 1))\n        # Direct fixed quantize: clip first to full-scale, then round.\n        r_q = cp.clip(cp.round(x.real / step), iv_min, iv_max) * step\n        i_q = cp.clip(cp.round(x.imag / step), iv_min, iv_max) * step\n        peak = float(cp.maximum(cp.abs(x.real).max(), cp.abs(x.imag).max()))\n        clip_frac = float(((cp.abs(x.real) >= full_scale) | (cp.abs(x.imag) >= full_scale)).mean())\n        err2 = (x.real - r_q) ** 2 + (x.imag - i_q) ** 2\n        sig2 = (cp.abs(x) ** 2).mean()\n        snr_db = 10.0 * float(cp.log10(sig2 / (err2.mean() + 1e-30)))\n        headroom_db = 20.0 * math.log10(full_scale / peak) if peak > 0 else float('inf')\n        print('  qz[%-9s fixed] Q%d.%d  FS=%.3g  peak=%.3g  headroom=%+5.1f dB  clip=%5.2f%%  SNR=%.1f dB'\n              % (name, n_word - n_frac, n_frac, full_scale, peak, headroom_db, 100*clip_frac, snr_db))\n        return (r_q + 1j * i_q).astype(cp.complex64)\n\n    # mode == 'auto' (BFP)\n    peak = float(cp.maximum(cp.abs(x.real).max(), cp.abs(x.imag).max()))\n    if peak == 0:\n        return x.astype(cp.complex64)\n    full_scale = float(2 ** (n_word - 1 - n_frac))\n    s = 0.95 * full_scale / peak\n    r_q = _qaxis(x.real, n_word, n_frac, s)\n    i_q = _qaxis(x.imag, n_word, n_frac, s)\n    err2 = (x.real - r_q) ** 2 + (x.imag - i_q) ** 2\n    sig2 = (cp.abs(x) ** 2).mean()\n    snr_db = 10.0 * float(cp.log10(sig2 / (err2.mean() + 1e-30)))\n    shift_bits = math.log2(s) if s > 0 else 0.0\n    print('  qz[%-9s auto ] Q%d.%d  peak=%.3g  shift=%+6.2f bits  SNR=%.1f dB'\n          % (name, n_word - n_frac, n_frac, peak, shift_bits, snr_db))\n    return (r_q + 1j * i_q).astype(cp.complex64)\n\nprint('Fixed route start (GPU): Q_IN=Q%d.%d  Q_FFT=Q%d.%d  Q_OUT=Q%d.%d' % (\n    Q_IN_W - Q_IN_F, Q_IN_F,\n    Q_FFT_W - Q_FFT_F, Q_FFT_F,\n    Q_OUT_W - Q_OUT_F, Q_OUT_F))\n\n# --- CPU -> GPU 転送 -----------------------------------------------------\n_t_xfer = _time.monotonic()\nfir_gpu   = cp.asarray(fir_coefficients)\nchirp_gpu = cp.asarray(ref_chirp.astype(np.complex64))\ncp.cuda.Stream.null.synchronize()\nprint('  H2D: fir %s + chirp %s  (%.2fs)' % (\n    fir_gpu.shape, chirp_gpu.shape, _time.monotonic() - _t_xfer))\n\n# --- Stage A: 入力時間領域 (fixed Q-format = ADC ビット幅) ----------------\n# Level 2 model: Stage A is an ADC-like fixed quantizer. The analog gain decided\n# in n25 (signal_peak_dbfs) determines where signals land relative to FS=1.0.\n# Out-of-range samples are clipped (real ADC saturation). The chirp template\n# (ref_chirp peak = 1) lands at signal_peak_dbfs. fir_coefficients is a stored\n# coefficient table — its peak depends on the scene (image vs point); in real\n# FPGA the BRAM scaling factor is computed offline, so we similarly bring fir\n# to FS-comparable range by pre-scaling to its own peak (= per-frame block\n# scaling factor, an \"offline\" decision). Apply the inverse scale after Stage A\n# so downstream code sees natural magnitudes (BFP-style block exponent).\nfir_peak = float(cp.maximum(cp.abs(fir_gpu.real).max(), cp.abs(fir_gpu.imag).max()))\nfir_pre_scale = 0.95 / fir_peak if fir_peak > 0 else 1.0\nprint('  fir_in BRAM pre-scale: 1/%.3g   (block-scale shift = %+.2f bits)' % (\n    1.0 / fir_pre_scale, math.log2(fir_pre_scale)))\nfir_q   = qz(fir_gpu * fir_pre_scale, Q_IN_W, Q_IN_F, 'fir_in',   mode='fixed') / fir_pre_scale\nchirp_q = qz(chirp_gpu,               Q_IN_W, Q_IN_F, 'chirp_in', mode='fixed')\ndel fir_gpu, chirp_gpu\n\n# --- Stage B: FFT 後周波数領域 (乗算ステップ含む) -------------------------\nF    = qz(cp.fft.fft(fir_q, axis=1), Q_FFT_W, Q_FFT_F, 'fir_fft')\nC    = qz(cp.fft.fft(chirp_q),       Q_FFT_W, Q_FFT_F, 'chirp_fft')\nprod = qz(F * C[None, :],            Q_FFT_W, Q_FFT_F, 'prod')\ndel fir_q, chirp_q, F, C\n\n# --- Stage C: IFFT 後時間領域 -------------------------------------------\ns_raw_gpu = qz(cp.fft.ifft(prod, axis=1), Q_OUT_W, Q_OUT_F, 'out')\ndel prod\n\n# --- GPU -> CPU 転送 -----------------------------------------------------\n_t_xfer = _time.monotonic()\ns_raw = cp.asnumpy(s_raw_gpu).astype(np.complex64)\ndel s_raw_gpu\ncp.get_default_memory_pool().free_all_blocks()\nprint('  D2H: s_raw %s  (%.2fs)' % (s_raw.shape, _time.monotonic() - _t_xfer))\n\nprint('Fixed route: s_raw=%s peak|s|=%.3f  (%.2fs total)'\n      % (s_raw.shape, float(np.abs(s_raw).max()), _time.monotonic() - _t0))\n",
            "label": "FPGA Route B: Fixed-point (Q-format 3-stage)",
            "spec": "【Route B: 固定小数点評価ルート (fxpmath)】\n\nFPGA で必然となるビット幅制限が SAR 画像品質にどう効くかを Python 側で評価するルート。FPGA でよくある FFT × 周波数乗算 × IFFT のパイプラインを fxpmath で量子化しながら模擬する。\n\n3ステージ独立 Q-format（ノードコード冒頭の定数を編集してチューニング）:\n\nStage A — 入力時間領域 (= ADC ビット幅):\n  Q_IN_W=10, Q_IN_F=9  (Q1.9, range ~ [-1, 1))\n  10bit ADC を想定。対象: fir_coefficients, ref_chirp\n\nStage B — FFT 後周波数領域 + 乗算後 (FPGA 内部演算):\n  Q_FFT_W=18, Q_FFT_F=10  (整数8bit + 小数10bit、Xilinx 7系 DSP 18bit に整合)\n  FFT 長 Nr で log2(Nr) のビット成長を吸収するため整数部に余裕を持たせる\n  対象: fft(fir_coefficients), fft(chirp), F × C[None,:]\n\nStage C — IFFT 後時間領域 (= DAC ビット幅):\n  Q_OUT_W=10, Q_OUT_F=9  (Q1.9)\n  10bit DAC を想定。対象: 最終 s_raw\n\n各ステージは auto-scale: peak を Q full-scale × 0.95 にマップして 5% のオーバーフローヘッドルームを確保 → fxpmath で量子化 → 復元。量子化 SNR を per-stage で表示。\n\n入力（kernel namespace）:\n  S_all, chirp_fft, fir_coefficients, ref_chirp, Na, Nr  ← n32 が生成\n\n出力（kernel namespace）:\n  s_raw  ← n25 (LNA) が消費\n\n排他関係:\n  Route A (n32_Float) / Route C-in (n32_FPGA_Load) と同時 Enable 不可。\n  Route C-out (n32_FPGA_Save) とは併用可（量子化結果を .mat 保存も可能）。\n\n参考: workspace-SAR-SIM/TargetSim_old/target_sim_FFT_FPGA_convert2Image2_375M.ipynb の BadAccuracy モード（int16 直接キャスト）の柔軟版。"
          },
          "enabled": false
        },
        "width": 400
      },
