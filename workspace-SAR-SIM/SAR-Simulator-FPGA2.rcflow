      {
        "id": "n58",
        "type": "canvasNode",
        "position": {
          "x": -467.1594743922747,
          "y": 1092.8289819718716
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# === Level Diagram (SAR link budget waterfall) ===\n# Absolute power level [dBm] through each RF chain stage from HPA output down\n# to LNA input. Reads everything from the kernel namespace so the plot tracks\n# n25 (LNA), sar_visualizer (geometry), antenna params, σ_max live. Shows the\n# noise floor kTB·F as a horizontal line — direct visual check of per-pulse\n# SNR (without matched-filter processing gain).\n#\n# Stages (per pulse, σ_ref point scatterer at slant range R0):\n#   1) HPA out         P_t                                      [dBm]\n#   2) TX feed out     P_t - L_tx_feed                          [dBm]\n#   3) EIRP            P_t - L_tx_feed + G_t                    [dBm]\n#   4) After uplink    EIRP - 10·log10(4πR0²)                   [dBm/m²]\n#   5) Target reflect  + σ_dBsm                                  [dBm]\n#   6) After downlink  - 10·log10(4πR0²)                        [dBm/m²]\n#   7) After RX ant    + 10·log10(Aeff), Aeff = G_r·λ²/(4π)      [dBm]\n#   8) LNA input       (signal at LNA terminal, before amp)      [dBm]\n#\n# Stops at LNA input. Past LNA, the simulator treats noise as ADC-referred-fixed\n# (so g_lna_db moves signal, not noise — see n25 spec), which is incompatible\n# with a continuing dBm waterfall. The LNA gain knob is annotated separately.\n\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport io, base64\nfrom IPython.display import display\n\n# --- Design constants (kept in sync with n25 LNA hard-coded values) ---\nP_t_dbm      = 63.0       # HPA peak power [dBm] (~2 kW)\nL_tx_feed_db = 3.0        # Tx feedline / waveguide loss [dB]\neta_ant      = 0.6        # Antenna aperture efficiency\nT_K          = 290.0      # Reference noise temperature [K]\n\n# --- Live values from kernel namespace ---\nnf_db_v   = float(globals().get('nf_db',        3.0))\ng_lna_v   = float(globals().get('g_lna_db',   110.0))   # annotation only\nsigma_max_db_v = float(globals().get('sigma0_max_db', 0.0))\nsigma_dbsm = sigma_max_db_v   # display the brightest-scatterer RCS in the chain\n\n# --- Derived (uses the same formulas as n25) ---\nG_ant_dbi   = 10.0 * np.log10(4.0 * np.pi * eta_ant * La * Lr / (lam ** 2))\nAeff_m2     = (10.0 ** (G_ant_dbi / 10.0)) * (lam ** 2) / (4.0 * np.pi)\nAeff_db     = 10.0 * np.log10(Aeff_m2)\nL_oneway_db = 10.0 * np.log10(4.0 * np.pi * R0 ** 2)     # one-leg spreading factor [dB]\nktbf_dbm    = -174.0 + 10.0 * np.log10(B) + nf_db_v      # noise floor [dBm] at LNA input\n\n# --- Build the cumulative-level chain ---\nstages = []\nlvl = P_t_dbm;          stages.append(('HPA out',         lvl))\nlvl -= L_tx_feed_db;    stages.append(('TX feed out',     lvl))\nlvl += G_ant_dbi;       stages.append(('EIRP',            lvl))\nlvl -= L_oneway_db;     stages.append(('After uplink',    lvl))\nlvl += sigma_dbsm;      stages.append(('Target reflect',  lvl))\nlvl -= L_oneway_db;     stages.append(('After downlink',  lvl))\nlvl += Aeff_db;         stages.append(('After RX ant',    lvl))\nstages.append(('LNA input', lvl))\nlabels = [s[0] for s in stages]\nlevels = [s[1] for s in stages]\n\n# --- Plot ---\nfig, ax = plt.subplots(figsize=(11, 5))\nax.plot(range(len(stages)), levels, '-o', color='#5fa8d3', linewidth=2.0, markersize=7, label='Signal level')\nax.axhline(ktbf_dbm, color='#e8696b', linestyle='--', linewidth=1.5,\n           label='Noise floor kTB·F = %+.1f dBm  (B=%.0f MHz, NF=%.1f dB)' % (ktbf_dbm, B/1e6, nf_db_v))\n\n# Inter-stage delta annotations\nfor i in range(1, len(stages)):\n    dl = levels[i] - levels[i-1]\n    if abs(dl) >= 0.05:\n        sign = '+' if dl >= 0 else ''\n        ax.annotate('%s%.1f dB' % (sign, dl),\n                    xy=((i-1+i)/2, (levels[i-1]+levels[i])/2),\n                    xytext=(0, 8 if dl >= 0 else -14), textcoords='offset points',\n                    ha='center', fontsize=8, color='#cdd6f4')\n\nax.set_xticks(range(len(stages))); ax.set_xticklabels(labels, rotation=20, ha='right')\nax.set_ylabel('Level [dBm]')\nax.set_title('SAR Link Budget Waterfall  (σ=%+.0f dBsm  R=%.1f km  λ=%.2f cm  ant %.1fx%.1f m  G_ant=%+.1f dBi)' %\n             (sigma_dbsm, R0/1e3, lam*100, La, Lr, G_ant_dbi))\nax.grid(True, alpha=0.3)\nax.legend(loc='lower left', fontsize=9)\n\n# SNR-at-LNA-input annotation\nsnr_in_db = levels[-1] - ktbf_dbm\nsnr_color = '#a6e3a1' if snr_in_db >= 0 else '#f9e2af' if snr_in_db >= -10 else '#f38ba8'\nax.annotate('SNR @ LNA in: %+.1f dB' % snr_in_db,\n            xy=(len(stages)-1, levels[-1]),\n            xytext=(-8, -34), textcoords='offset points', ha='right', fontsize=10, color=snr_color,\n            arrowprops=dict(arrowstyle='->', color=snr_color, lw=1))\n\n# G_LNA side note (it's applied after this waterfall)\nax.text(0.99, 0.97, 'G_LNA = %+.1f dB  (applied past LNA input — see n25)' % g_lna_v,\n        transform=ax.transAxes, ha='right', va='top', fontsize=8, color='#a6adc8')\n\nfig.tight_layout()\nbuf = io.BytesIO(); fig.savefig(buf, format='png', dpi=110, bbox_inches='tight')\nplt.close(fig)\ndisplay({'image/png': base64.b64encode(buf.getvalue()).decode('ascii')}, raw=True)\n\nprint('Link budget waterfall:')\nfor lab, lvl in stages:\n    print('  %-16s  %+8.1f dBm' % (lab, lvl))\nprint('  %-16s  %+8.1f dBm  (kTB·F)' % ('Noise floor', ktbf_dbm))\nprint('  %-16s  %+8.1f dB'  % ('SNR @ LNA in', snr_in_db))\nprint('  (G_LNA = %+.1f dB applied downstream — see n25)' % g_lna_v)\n",
            "label": "Level Diagram (Link Budget)"
          },
          "executionOrder": 16,
          "codeCollapsed": true
        },
        "width": 400,
        "style": {}
      },
