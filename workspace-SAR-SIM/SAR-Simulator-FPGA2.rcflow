      {
        "id": "n27",
        "type": "canvasNode",
        "position": {
          "x": 122.95939438515097,
          "y": 1086.468504618489
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# Step 2: Raw echo with noise (after LNA) — full view + adaptive-x crop in ONE\n# block, faithful (surface3d_pair_gl, NO max-pool). The crop is complex-upsampled\n# by F; its title/status note the upsample factor. Toggle Full/Crop in the plot.\n# peak_relative=True: raw-echo level is far below ADC FS (no matched-filter gain\n# yet), so the absolute -40..0 dBFS window would show black. Slide the 40 dB\n# window so the panel's peak sits at the top of the colormap; the title still\n# prints the absolute peak in dBFS so you can compare across stages.\nrg_axis = (t_r - t_r_center) * c / 2\n_W = float(view_scale)\n\n_rc = np.where((rg_axis >= -_W) & (rg_axis <= _W))[0]\n_ac = np.where((az_pos  >= -_W) & (az_pos  <= _W))[0]\n_sub = s_raw[_ac[0]:_ac[-1]+1, _rc[0]:_rc[-1]+1]\n_rgx = rg_axis[_rc[0]:_rc[-1]+1]; _azx = az_pos[_ac[0]:_ac[-1]+1]\nF = crop_upsample_factor(len(_azx), len(_rgx))\n_mag = upsample_complex(_sub, F)\n_rgu = upsample_axis(_rgx, F); _azu = upsample_axis(_azx, F)\n\nsurface3d_pair_gl(\n    s_raw, rg_axis, az_pos, 'Step 2: Raw echo with noise (full view)',\n    _mag, _rgu, _azu, 'Step 2: Raw echo with noise (x%d crop)' % F,\n    status_b='upsample x%d' % F,\n    peak_relative=True)\n",
            "label": "Plot Raw Echo with noise",
            "spec": "Display-only: show |s_raw| (raw echo amplitude) over (range, azimuth). Does not modify any physical array."
          },
          "codeCollapsed": true,
          "executionOrder": 18
        },
        "width": 400,
