          ],
          "defaultParameters": {
            "code": "# matplotlib with max-pooling downscale (preserves point targets)\ndef image_plot_dB_maxpool(data):\n    plot_size_az = 20000\n    plot_size_rg = 20000\n    if len(data) > plot_size_az:\n        az_l = len(data) // 2 - plot_size_az // 2\n        az_u = len(data) // 2 + plot_size_az // 2\n    else:\n        az_l = 0\n        az_u = len(data)\n    if len(data[0]) > plot_size_rg:\n        rg_l = len(data[0]) // 2 - plot_size_rg // 2\n        rg_u = len(data[0]) // 2 + plot_size_rg // 2\n    else:\n        rg_l = 0\n        rg_u = len(data[0])\n    plot_data = np.abs(data[az_l:az_u, rg_l:rg_u])\n    norm_factor = np.max(plot_data)\n    plot_data = plot_data / norm_factor\n    threshould_dB = 60\n    plot_data = np.ceil(plot_data * 10 ** (threshould_dB / 20)) / 10 ** (\n        threshould_dB / 20\n    )\n    db_data = 20 * np.log10(plot_data)\n\n    # Max-pooling to reduce size for display (target ~800x600)\n    target_h, target_w = 600, 800\n    h, w = db_data.shape\n    if h > target_h or w > target_w:\n        bh = max(1, h // target_h)\n        bw = max(1, w // target_w)\n        # Trim to multiple of block size\n        th = (h // bh) * bh\n        tw = (w // bw) * bw\n        trimmed = db_data[:th, :tw]\n        # Reshape and take max per block (preserves bright targets)\n        db_data = trimmed.reshape(th // bh, bh, tw // bw, bw).max(axis=(1, 3))\n\n    plt.imshow(db_data, cmap=\"gray\",\n               extent=[rg_l, rg_u, az_u, az_l])\n    plt.colorbar()\n    plt.show()\n    return\n\nt0 = time.monotonic()\nimage_plot_dB_maxpool(test_data)\nprint(f'MaxPool: {time.monotonic()-t0:.2f}s')",
            "label": "MaxPool Plot"
          },
          "enabled": false
        }
      },
      {
        "id": "n7",
        "type": "canvasNode",
        "position": {
          "x": 50,
          "y": 75.5
        },
        "width": 400,
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "import numpy as np\nfrom scipy import interpolate\nfrom scipy.ndimage import map_coordinates\nimport time\n\n# Simulate data matching TargetSim dimensions\ndata_len = 5400\nnsamples = 10966\n\n# Fake parameters (matching TargetSim)\nc = 299792456\nfs = 100e6\nprf = 4000\nwl = c / 9.65e9\nveff = 7410\nr_sc = 690e3\ndoppler_centroid = 0.0\nd_rg = c / 2 / fs\n\n# Create test RD domain data\niq_data_rd = (np.random.randn(data_len, nsamples) + 1j * np.random.randn(data_len, nsamples)).astype(np.complex64) * 0.01\niq_data_rd[2700, 5483] = 1.0 + 0j\n\n# Pre-compute freq and R (shared by both methods)\nsample_points = np.arange(-(data_len) // 2, data_len // 2)\nfreq = sample_points * (prf / data_len) + doppler_centroid\nfreq = np.roll(freq, np.round(doppler_centroid / (prf / data_len)).astype(int))\nR = r_sc + np.arange(0, nsamples) * d_rg\n\nprint(f'Setup done: iq_data_rd={iq_data_rd.shape}')",
            "label": "RCMC Setup"
          },
          "enabled": false
        }
      },
      {
        "id": "n8",
        "type": "canvasNode",
        "position": {
          "x": 510,
          "y": 506
        },
        "width": 400,
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# Original RCMC\nt0 = time.monotonic()\n\nrcm = np.zeros(iq_data_rd.shape, np.float64)\nfor i in range(iq_data_rd.shape[1]):\n    rcm[:, i] = (1 / np.sqrt(1 - (wl * freq / (2 * veff)) ** 2) - 1) * (r_sc + d_rg * i)\n\nR_new = np.tile(R, (rcm.shape[0], 1)) + rcm\n\niq_data_rcmc_orig = np.zeros_like(iq_data_rd)\nfor i in range(iq_data_rd.shape[0]):\n    f = interpolate.interp1d(R, iq_data_rd[i], kind=\"cubic\", fill_value=\"extrapolate\")\n    iq_data_rcmc_orig[i] = f(R_new[i])\n\nprint(f'Original RCMC: {time.monotonic()-t0:.2f}s')",
            "label": "RCMC Original"
          },
          "enabled": false
        }
      },
      {
        "id": "n9",
        "type": "canvasNode",
        "position": {
          "x": 970,
          "y": 370.5
        },
        "width": 400,
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# GPU RCMC - same cubic interpolation on GPU\nimport cupy as cp\nfrom cupyx.scipy.ndimage import map_coordinates as gpu_map_coordinates\n\nt0 = time.monotonic()\n\n# Vectorized rcm (CPU)\nmigration_factor = 1 / np.sqrt(1 - (wl * freq / (2 * veff)) ** 2) - 1\nrange_offsets = r_sc + d_rg * np.arange(iq_data_rd.shape[1])\nrcm_opt = migration_factor[:, np.newaxis] * range_offsets[np.newaxis, :]\nR_new_opt = np.tile(R, (iq_data_rd.shape[0], 1)) + rcm_opt\n\n# Fractional pixel indices\ncol_coords = (R_new_opt - R[0]) / d_rg\nrow_coords = np.broadcast_to(np.arange(iq_data_rd.shape[0])[:, np.newaxis], col_coords.shape).copy().astype(np.float64)\n\n# Stack into (2, H, W) coordinates array\ncoords = np.stack([row_coords, col_coords], axis=0)\n\n# Transfer to GPU\ncoords_gpu = cp.asarray(coords)\niq_real_gpu = cp.asarray(iq_data_rd.real.astype(np.float64))\niq_imag_gpu = cp.asarray(iq_data_rd.imag.astype(np.float64))\n\n# GPU cubic interpolation\nout_real = gpu_map_coordinates(iq_real_gpu, coords_gpu, order=3, mode='constant', cval=0.0)\nout_imag = gpu_map_coordinates(iq_imag_gpu, coords_gpu, order=3, mode='constant', cval=0.0)\n\n# Transfer back to CPU\niq_data_rcmc_gpu = (cp.asnumpy(out_real) + 1j * cp.asnumpy(out_imag)).astype(np.complex64)\n\ncp.cuda.Stream.null.synchronize()\nprint(f'GPU RCMC (cubic): {time.monotonic()-t0:.2f}s')\n\n# Verify\ndiff = np.max(np.abs(iq_data_rcmc_orig - iq_data_rcmc_gpu))\nrms = np.sqrt(np.mean(np.abs(iq_data_rcmc_orig - iq_data_rcmc_gpu)**2))\nprint(f'Max diff: {diff:.6e}, RMS diff: {rms:.6e}')",
            "label": "RCMC Optimized"
          },
          "enabled": false
        }
      },
      {
        "id": "n10",
        "type": "canvasNode",
        "position": {
          "x": 1663.5,
