          "defaultParameters": {
            "code": "# Pillow-based image_plot_dB with axes, gridlines and colorbar\nfrom PIL import Image, ImageDraw, ImageFont\nfrom IPython.display import display\n\ndef image_plot_dB_pil2(data):\n    plot_size_az = 20000\n    plot_size_rg = 20000\n    if len(data) > plot_size_az:\n        az_l = len(data) // 2 - plot_size_az // 2\n        az_u = len(data) // 2 + plot_size_az // 2\n    else:\n        az_l = 0\n        az_u = len(data)\n    if len(data[0]) > plot_size_rg:\n        rg_l = len(data[0]) // 2 - plot_size_rg // 2\n        rg_u = len(data[0]) // 2 + plot_size_rg // 2\n    else:\n        rg_l = 0\n        rg_u = len(data[0])\n    plot_data = np.abs(data[az_l:az_u, rg_l:rg_u])\n    norm_factor = np.max(plot_data)\n    plot_data = plot_data / norm_factor\n    threshould_dB = 60\n    plot_data = np.ceil(plot_data * 10 ** (threshould_dB / 20)) / 10 ** (\n        threshould_dB / 20\n    )\n    db_data = 20 * np.log10(plot_data)\n    db_min = float(db_data.min())\n    db_max = float(db_data.max())\n\n    # Normalize to 0-255 grayscale\n    if db_max > db_min:\n        img_data = ((db_data - db_min) / (db_max - db_min) * 255).astype(np.uint8)\n    else:\n        img_data = np.zeros_like(db_data, dtype=np.uint8)\n\n    # Resize image for display\n    data_h, data_w = img_data.shape\n    disp_w = 600\n    disp_h = int(data_h / data_w * disp_w)\n    if disp_h < 100:\n        disp_h = 100\n    img = Image.fromarray(img_data, mode='L').resize((disp_w, disp_h), Image.NEAREST)\n\n    # Layout\n    margin_left = 55\n    margin_bottom = 35\n    margin_top = 10\n    margin_right = 70\n    cb_width = 15\n    cb_gap = 8\n\n    canvas_w = margin_left + disp_w + margin_right\n    canvas_h = margin_top + disp_h + margin_bottom\n    canvas = Image.new('RGB', (canvas_w, canvas_h), (255, 255, 255))\n    img_rgb = img.convert('RGB')\n    canvas.paste(img_rgb, (margin_left, margin_top))\n\n    draw = ImageDraw.Draw(canvas)\n\n    # Border\n    draw.rectangle([margin_left, margin_top, margin_left + disp_w, margin_top + disp_h], outline=(0, 0, 0))\n\n    # --- Helper: nice tick values at interval (e.g. 1000) ---\n    def nice_ticks(vmin, vmax, max_ticks=8):\n        span = vmax - vmin\n        if span <= 0:\n            return [vmin]\n        raw_step = span / max_ticks\n        # Round to nice step: 1, 2, 5, 10, 20, 50, 100, 200, 500, 1000, ...\n        mag = 10 ** int(np.floor(np.log10(raw_step)))\n        for s in [1, 2, 5, 10]:\n            if mag * s >= raw_step:\n                step = mag * s\n                break\n        start = int(np.ceil(vmin / step)) * step\n        ticks = []\n        v = start\n        while v <= vmax:\n            ticks.append(int(v))\n            v += step\n        return ticks\n\n    # --- X axis (range pixels) ---\n    x_ticks = nice_ticks(rg_l, rg_u)\n    grid_color = (80, 80, 80)\n    for val in x_ticks:\n        frac = (val - rg_l) / (rg_u - rg_l)\n        x_pos = margin_left + int(frac * disp_w)\n        if 0 <= frac <= 1:\n            # Grid line\n            for y in range(margin_top, margin_top + disp_h):\n                px = canvas.getpixel((x_pos, y))\n                blended = tuple(min(255, c + 40) for c in px)\n                canvas.putpixel((x_pos, y), blended)\n            # Tick\n            draw.line([(x_pos, margin_top + disp_h), (x_pos, margin_top + disp_h + 4)], fill=(0, 0, 0))\n            draw.text((x_pos - 15, margin_top + disp_h + 6), str(val), fill=(0, 0, 0))\n\n    # --- Y axis (azimuth pixels) ---\n    y_ticks = nice_ticks(az_l, az_u)\n    for val in y_ticks:\n        frac = (val - az_l) / (az_u - az_l)\n        y_pos = margin_top + int(frac * disp_h)\n        if 0 <= frac <= 1:\n            # Grid line\n            for x in range(margin_left, margin_left + disp_w):\n                px = canvas.getpixel((x, y_pos))\n                blended = tuple(min(255, c + 40) for c in px)\n                canvas.putpixel((x, y_pos), blended)\n            # Tick\n            draw.line([(margin_left - 4, y_pos), (margin_left, y_pos)], fill=(0, 0, 0))\n            draw.text((2, y_pos - 5), str(val), fill=(0, 0, 0))\n\n    # --- Axis labels ---\n    draw.text((margin_left + disp_w // 2 - 20, margin_top + disp_h + 20), \"Range\", fill=(0, 0, 0))\n    # Y label (simple horizontal text)\n    draw.text((2, margin_top - 2), \"Az\", fill=(0, 0, 0))\n\n    # --- Colorbar ---\n    cb_x = margin_left + disp_w + cb_gap\n    for y in range(disp_h):\n        val = int(255 * (1 - y / disp_h))\n        draw.line([(cb_x, margin_top + y), (cb_x + cb_width, margin_top + y)], fill=(val, val, val))\n    draw.rectangle([cb_x, margin_top, cb_x + cb_width, margin_top + disp_h], outline=(0, 0, 0))\n\n    # Colorbar labels\n    cb_ticks = nice_ticks(db_min, db_max, max_ticks=5)\n    for val in cb_ticks:\n        frac = (db_max - val) / (db_max - db_min) if db_max > db_min else 0\n        y_pos = margin_top + int(frac * disp_h)\n        draw.text((cb_x + cb_width + 3, y_pos - 5), f'{val:.0f}', fill=(0, 0, 0))\n\n    draw.text((cb_x, margin_top - 10), \"dB\", fill=(0, 0, 0))\n\n    display(canvas)\n\nt0 = time.monotonic()\nimage_plot_dB_pil2(test_data)\nprint(f'Pillow v2: {time.monotonic()-t0:.2f}s')",
            "label": "Pillow v2 (axes+cb)"
          },
          "enabled": false
        }
