          "defaultParameters": {
            "code": "# Pillow-based image_plot_dB\nfrom PIL import Image\nfrom IPython.display import display\nimport io, base64\n\ndef image_plot_dB_pil(data):\n    plot_size_az = 20000\n    plot_size_rg = 20000\n    if len(data) > plot_size_az:\n        az_l = len(data) // 2 - plot_size_az // 2\n        az_u = len(data) // 2 + plot_size_az // 2\n    else:\n        az_l = 0\n        az_u = len(data)\n    if len(data[0]) > plot_size_rg:\n        rg_l = len(data[0]) // 2 - plot_size_rg // 2\n        rg_u = len(data[0]) // 2 + plot_size_rg // 2\n    else:\n        rg_l = 0\n        rg_u = len(data[0])\n    plot_data = np.abs(data[az_l:az_u, rg_l:rg_u])\n    norm_factor = np.max(plot_data)\n    plot_data = plot_data / norm_factor\n    threshould_dB = 60\n    plot_data = np.ceil(plot_data * 10 ** (threshould_dB / 20)) / 10 ** (\n        threshould_dB / 20\n    )\n    db_data = 20 * np.log10(plot_data)\n    # Normalize to 0-255 grayscale\n    db_min = db_data.min()\n    db_max = db_data.max()\n    if db_max > db_min:\n        img_data = ((db_data - db_min) / (db_max - db_min) * 255).astype(np.uint8)\n    else:\n        img_data = np.zeros_like(db_data, dtype=np.uint8)\n    img = Image.fromarray(img_data, mode='L')\n    # Resize for display (max 800px wide)\n    max_w = 800\n    if img.width > max_w:\n        ratio = max_w / img.width\n        img = img.resize((max_w, int(img.height * ratio)), Image.NEAREST)\n    display(img)\n\nt0 = time.monotonic()\nimage_plot_dB_pil(test_data)\nprint(f'Pillow: {time.monotonic()-t0:.2f}s')",
            "label": "Pillow Plot"
          },
          "enabled": false
        }
