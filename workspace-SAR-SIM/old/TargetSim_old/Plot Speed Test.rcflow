            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "import numpy as np\nfrom scipy import interpolate\n\nc = 299792456\nchirp_bw = 75e6; fc = 9.6e9; wl = c/fc; fs = 3000e6/16\nprf = 4000; pri = 1/prf; duty = 0.25; chirp_len = pri*duty\nchirp_rate = chirp_bw/chirp_len; chirp_mode = \"down\"\nl_a = 4.9; w_a = 0.7; r_sc = 690e3; veff = 7410\nsquint = 0.0/180*np.pi; doppler_centroid = 2*veff*np.sin(squint)/wl\ntheta_l_a = 0.886*wl/l_a; theta_w_a = 0.886*wl/w_a\n\ntd = chirp_len*fs\nt = np.arange(-td/2, td/2, 1)/fs\nchirp_replica_u = np.exp(1j*np.pi*chirp_rate*t**2)\nchirp_replica_d = np.exp(-1j*np.pi*chirp_rate*t**2)\n\nrange_swath = 10e3; azimuth_swath = 10e3\ntd2 = (range_swath**2+azimuth_swath**2)**0.5/c\nnsamples = np.ceil(td2*fs).astype(int) + len(chirp_replica_u)\nfast_time = np.arange(0, nsamples, 1)/fs + 2*r_sc/c\ntd3 = azimuth_swath/veff\nnpulses = np.ceil(td3*prf).astype(int)\nslow_time = np.arange(-npulses//2, npulses//2, 1)/prf\naz_array = veff*slow_time + r_sc*np.tan(squint)\n\npoints = [(r_sc+range_swath/2, 0)]\nprint(f'Setup done: ({npulses}, {nsamples}), target at {points[0][0]:.0f}m')",
            "label": "Debug Setup"
          }
        }
      },
      {
        "id": "n11",
        "type": "canvasNode",
        "position": {
          "x": 2109.7272943109037,
          "y": 722.9562973669103
        },
        "width": 579,
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# Image target timing - differential phase method (best approach)\nfrom PIL import Image\nimport cupy as cp\nimport time as _time\n\nimg_full = Image.open('D:/yoshitaka/TargetSimulator2/ImageTest/ya.png').convert('L')\ngray_full = np.array(img_full, dtype=np.float32)\n\ntest_cases = [\n    (\"26x26 diff\", np.array(img_full.resize((26, 26)), dtype=np.float32)),\n]\n\nnfast = len(fast_time)\nnpulses = len(slow_time)\nfreqs_gpu = cp.asarray(np.fft.fftfreq(nfast, 1/fs), dtype=cp.float32)\nchirp_padded = np.zeros(nfast, dtype=np.complex64)\nchirp_padded[:len(chirp_replica_d)] = chirp_replica_d\nchirp_fft_gpu = cp.asarray(np.fft.fft(chirp_padded), dtype=cp.complex64)\naz_array_gpu = cp.asarray(az_array, dtype=cp.float32)\nft0 = np.float32(fast_time[0])\nd_rg_val = c / 2 / fs\nd_az_val = veff / prf\nwl_f32 = np.float32(wl)\nsquint_f32 = np.float32(squint)\ntheta_l_a_f32 = np.float32(theta_l_a)\nc_f32 = np.float32(c)\npi_f32 = np.float32(np.pi)\nphase_r_coeff = np.float32(-4 * np.pi / wl)\n\ndef process_image(gray, label):\n    rows, cols = np.where(gray > 0)\n    nt = len(rows)\n    if nt == 0:\n        return 0, 0\n\n    tr_gpu = cp.asarray((r_sc + cols * d_rg_val).astype(np.float32))\n    ta_gpu = cp.asarray(((rows - gray.shape[0]/2) * d_az_val).astype(np.float32))\n    tamp_gpu = cp.asarray((gray[rows, cols] / 255.0).astype(np.float32))\n\n    t0 = _time.monotonic()\n    echo_fft_all = cp.zeros((npulses, nfast), dtype=cp.complex64)\n\n    tb = min(80, nt)\n    reset_interval = 100\n\n    print(f'{label}: {nt} tgts, tb={tb}, reset={reset_interval}')\n\n    for tstart in range(0, nt, tb):\n        tend = min(tstart + tb, nt)\n        nb_t = tend - tstart\n        tr_b = tr_gpu[tstart:tend]\n        ta_b = ta_gpu[tstart:tend]\n        tamp_b = tamp_gpu[tstart:tend]\n\n        prev_delay_phase = None\n        prev_delay = None\n\n        for p in range(npulses):\n            az = az_array_gpu[p]\n\n            r_vec = cp.sqrt(tr_b**2 + (ta_b - az)**2)\n            angle = cp.arctan((az - ta_b) / tr_b)\n            s_az = cp.sinc((angle - squint_f32) / theta_l_a_f32)**2\n            delay = 2 * r_vec / c_f32 - ft0\n            phase_r = cp.exp(1j * phase_r_coeff * r_vec).astype(cp.complex64)\n            weights = (tamp_b * s_az * phase_r).astype(cp.complex64)\n\n            if prev_delay_phase is None or p % reset_interval == 0:\n                cur_delay_phase = cp.exp(-2j * pi_f32 * delay[:, None] * freqs_gpu[None, :]).astype(cp.complex64)\n            else:\n                d_delay = delay - prev_delay\n                delta_phase = cp.exp(-2j * pi_f32 * d_delay[:, None] * freqs_gpu[None, :]).astype(cp.complex64)\n                cur_delay_phase = prev_delay_phase * delta_phase\n\n            prev_delay_phase = cur_delay_phase\n            prev_delay = delay\n\n            contrib = cp.sum(weights[:, None] * cur_delay_phase, axis=0)\n            echo_fft_all[p, :] += chirp_fft_gpu * contrib\n\n        del prev_delay_phase, prev_delay\n        cp.get_default_memory_pool().free_all_blocks()\n\n        elapsed = _time.monotonic() - t0\n        progress = tend / nt\n        remaining = elapsed / progress - elapsed if progress > 0 else 0\n        print(f'{label}: {tend}/{nt} ({progress*100:.0f}%) {elapsed:.1f}s ~{remaining:.0f}s left')\n\n    iq_result = cp.asnumpy(cp.fft.ifft(echo_fft_all, axis=1)).astype(np.complex64)\n    cp.cuda.Stream.null.synchronize()\n    tt = _time.monotonic() - t0\n    del echo_fft_all\n    cp.get_default_memory_pool().free_all_blocks()\n    return nt, tt\n\nprint(f'{\"Size\":<20} {\"Tgts\":>6} {\"Time\":>7} {\"/tgt\":>7} {\"Est ya\":>10}')\nprint('-' * 55)\n\nn_full = np.count_nonzero(gray_full)\nfor name, gray in test_cases:\n    nt, t = process_image(gray, name)\n    if nt > 0:\n        est = t / nt * n_full\n        print(f'{name:<20} {nt:>6} {t:>6.1f}s {t/nt:>6.3f}s {est:>7.0f}s ({est/60:.0f}m)')\n\nprint(f'\\nFull ya.png: {n_full} non-zero pixels')",
            "label": "Image Target Timing"
          }
        }
      }
    ],
