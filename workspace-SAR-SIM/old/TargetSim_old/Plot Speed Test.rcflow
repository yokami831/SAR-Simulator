          "defaultParameters": {
            "code": "import numpy as np\nimport matplotlib.pyplot as plt\nimport time\n\n# Create test data with visible SAR-like features\nrows, cols = 5400, 10966\ntest_data = np.random.randn(rows, cols).astype(np.complex64) * 0.01\n\n# Add point targets with gaussian-like PSF spread\ntargets = [\n    (2700, 5483, 1.0),\n    (1350, 2741, 0.8),\n    (4050, 8224, 0.6),\n    (2700, 3000, 0.7),\n    (2700, 8000, 0.9),\n]\nfor r, c, amp in targets:\n    for dr in range(-20, 21):\n        for dc in range(-20, 21):\n            dist = (dr**2 + dc**2)**0.5\n            val = amp * np.exp(-dist**2 / 50)\n            if r+dr >= 0 and r+dr < rows and c+dc >= 0 and c+dc < cols:\n                test_data[r+dr, c+dc] += val\n\nprint(f'Test data: {test_data.shape}, targets: {len(targets)}')",
            "label": "Test Data"
          },
          "enabled": false
        }
      },
      {
