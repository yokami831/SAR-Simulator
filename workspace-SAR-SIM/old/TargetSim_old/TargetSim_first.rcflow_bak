              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# point target\npoints = [(r_sc+range_swath/2,0)]\nprint(f'targets: {points}')",
            "label": "Point Target"
          }
