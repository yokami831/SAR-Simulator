            }
          ],
          "defaultParameters": {
            "code": "# azimuth profile\nplot_len = 100\nplt.plot(np.abs(slc[peak_idx[0][0]-plot_len//2:peak_idx[0][0]+plot_len//2,peak_idx[0][1]]))\nplt.title('Azimuth Profile')\nplt.show()",
