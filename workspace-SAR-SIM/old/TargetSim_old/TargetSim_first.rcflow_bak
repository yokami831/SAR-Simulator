          "defaultParameters": {
            "code": "# platform parameters\nl_a = 4.9\nw_a = 0.7\ntheta_l = 30 * np.pi/180\nheight = 550e3\nr_sc = 690e3\nveff = 7410\nsquint = 0.0/180*np.pi\ndoppler_centroid = 2*veff*np.sin(squint)/wl\nprint(f'r_sc={r_sc:.0f}, veff={veff}, doppler_centroid={doppler_centroid:.2f}')\n\n# antenna pattern\ntheta_l_a = 0.886*wl/l_a\ntheta_w_a = 0.886*wl/w_a\nprint(f'theta_l_a={theta_l_a:.6f}, theta_w_a={theta_w_a:.6f}')\n",
            "label": "Platform Params"
          }
