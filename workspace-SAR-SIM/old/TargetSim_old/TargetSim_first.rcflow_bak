          "defaultParameters": {
            "code": "# constants\nc = 299792456\nprint(f'c = {c}')\n\n# radar parameters\nchirp_bw = 75e6\nfc = 9.65e9\nwl = c/fc\nfs = 100e6\nprf = 4000\npri = 1/prf\nduty = 0.25\nchirp_len = pri*duty\nchirp_rate = chirp_bw/chirp_len\n\nchirp_mode = \"down\" # up, down, ud\nprint(f'wl={wl:.4f}, fs={fs:.0f}, prf={prf}, chirp_rate={chirp_rate:.2e}')",
            "label": "Radar Params"
          }
        },
        "width": 400
      },
      {
        "id": "n4",
        "type": "canvasNode",
