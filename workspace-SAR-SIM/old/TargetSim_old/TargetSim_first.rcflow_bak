      },
      {
        "id": "n25",
        "type": "canvasNode",
        "position": {
          "x": 6517,
          "y": 325
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "from scipy.signal import peak_widths\n\ndef resolution_estimation(data, interp_ratio=10):\n    data = np.abs(data)\n    idx = np.argmax(data)\n\n    range_cut = data[idx // data.shape[1]]\n    azimuth_cut = data[:, idx % data.shape[1]]\n\n    range_cut = np.abs(fft_interp(range_cut, interp_ratio)) ** 2\n    peak_idx_rg = [np.argmax(range_cut)]\n    width_rg = peak_widths(range_cut, peak_idx_rg, rel_height=0.5)\n\n    azimuth_cut = np.abs(fft_interp(azimuth_cut, interp_ratio)) ** 2\n    peak_idx_az = [np.argmax(azimuth_cut)]\n    width_az = peak_widths(azimuth_cut, peak_idx_az, rel_height=0.5)\n\n    return width_rg[0] / interp_ratio, width_az[0] / interp_ratio\n\n# fft interpolator\ndef fft_interp(sig, interp_ratio):\n    sig_f = np.fft.fftshift(np.fft.fft(sig))\n    tmp = np.zeros(len(sig) * interp_ratio, dtype=np.complex64)\n    tmp[0 : len(sig_f)] = sig_f\n    tmp = np.roll(tmp, len(tmp) // 2 - len(sig_f) // 2)\n    return np.fft.ifft(np.fft.fftshift(tmp)).astype(np.complex64)\n\nprint('Resolution functions defined')",
            "label": "Resolution Est Funcs"
          }
        },
        "width": 400
      },
      {
        "id": "n26",
        "type": "canvasNode",
        "position": {
          "x": 6977,
          "y": 509
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "d_rg = c/2/fs\nd_az = veff/prf\nres_rg, res_az = resolution_estimation(slc)\nprint(f'range resolution: {res_rg*d_rg}')\nprint(f'azimuth resolution: {res_az*d_az}')",
            "label": "Resolution Calc"
          }
        },
        "width": 400
      }
