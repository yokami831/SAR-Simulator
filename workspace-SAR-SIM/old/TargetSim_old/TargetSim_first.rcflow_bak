        "width": 400
      },
      {
        "id": "n9",
        "type": "canvasNode",
        "position": {
          "x": 2837,
          "y": 42.5
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# response from point target\nimport time as _time\n_t0 = _time.monotonic()\niq_data = np.zeros((len(slow_time),len(fast_time)),dtype=np.complex64)\nt_chirp = np.zeros(len(fast_time),dtype=np.complex64)\nchirp_l = len(chirp_replica_u)\nt_chirp[:len(chirp_replica_u)] = chirp_replica_u\nt_chirp_f = np.fft.fft(t_chirp)\n\nphi_offset = np.pi*0\nsample_delay = 0\n\nrg_freq = np.arange(-0.5,0.5,1/len(fast_time))*fs\nrg_freq -=rg_freq[len(rg_freq)//2]\nif chirp_mode == \"up\" or chirp_mode == \"ud\":\n    ss = 1\nelse:\n    ss = -1\n\nfor i in range(len(slow_time)):\n    if chirp_mode == \"ud\":\n        ss *= -1\n\n    for j in range(len(points)):\n        az = az_array[i]\n        r = (points[j][0]**2+(points[j][1]-az)**2)**0.5\n        angle_to_target = np.arctan((az-points[j][1])/points[j][0])\n        s_az = np.sinc((angle_to_target-squint)/theta_l_a)**2\n\n        rect = np.zeros(len(fast_time))\n        rect[int(2*(r-r_sc)/c*fs):int(2*(r-r_sc)/c*fs+chirp_l)] = 1\n\n        iq_data[i,:] += rect*np.exp(ss*1j*np.pi*chirp_rate*(fast_time-2*(r)/c-chirp_len/2)**2)*np.exp(-4j*np.pi*r/wl)*s_az+1e-10\n\nprint(f'IQ data generated: {iq_data.shape}, elapsed: {_time.monotonic()-_t0:.1f}s')",
            "label": "IQ Data Generation"
          }
        },
        "width": 400
      },
