          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# Step 6: Focused image — full view + adaptive-x crop in ONE block (single iframe).\n#   A (Full) = whole focused scene; max-pooled to the vertex cap (pool_a=True).\n#   B (Crop) = 0-centred +/-W window (W = PEAK_HALF * view_scale), complex-\n#              upsampled to reveal IRF sidelobes. F is chosen so the upsampled\n#              crop stays under the vertex cap WITHOUT max-pooling (pool_b=False)\n#              — pooling a deliberate upsample would throw the detail away.\n# surface3d_pair shares one WebGLRenderer; toggle Full/Crop in the plot.\nrg_axis = (t_r - t_r_center) * c / 2\n\nW = PEAK_HALF * view_scale\n_rc = np.where((rg_axis >= -W) & (rg_axis <= W))[0]\n_ac = np.where((az_pos  >= -W) & (az_pos  <= W))[0]\n_sub = img[_ac[0]:_ac[-1]+1, _rc[0]:_rc[-1]+1]\n_rgx = rg_axis[_rc[0]:_rc[-1]+1]; _azx = az_pos[_ac[0]:_ac[-1]+1]\nF = crop_upsample_factor(len(_azx), len(_rgx))\n_mag = upsample_complex(_sub, F)\n_rgu = upsample_axis(_rgx, F); _azu = upsample_axis(_azx, F)\n\nsurface3d_pair(\n    img, rg_axis, az_pos, 'Step 6: Focused image (full view)',\n    _mag, _rgu, _azu, 'Step 6: Focused image (x%d, 0-centred +/-%dm)' % (F, int(W)),\n    status_b='upsample x%d' % F, pool_b=False)\n",
            "label": "Plot Focused Image",
            "spec": "Display-only: 3-D surface of the focused image |img| in dB (the final RDA output). Each point target should appear as a sharp peak (its impulse response / IRF). Interactive; Expand opens a large copy. Does not modify any physical array."
          },
          "codeCollapsed": true
        }
      },
