      {
        "id": "n14",
        "type": "canvasNode",
        "position": {
          "x": 673.9962912517171,
          "y": 2602.6531130425055
        },
        "width": 400,
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
