          ],
          "defaultParameters": {
            "code": "# === Plot library (workspace-local) ===\n# Display/interpolation helpers for this SAR workspace. Defined here as a\n# visible first node (not hidden in app code) so they are easy to find and\n# edit, and shared with every downstream node via the kernel namespace.\n# See this block's SPEC for what each function does.\n\nimport json as _json\nfrom IPython.display import display as _display, HTML as _HTML\n\n# Display vertex cap. surface3d/surface3d_pair emit one vertex per grid cell, so\n# a large image (e.g. 2460x1048 ~ 2.58M) bloats the 4GB-capped renderer heap.\n# Max-pool (peak-preserving, like TargetSim's image_plot_dB) the *display* copy\n# down to <= MAX_VERTS so bright point-target peaks and thin lines survive.\nMAX_VERTS = 250000  # ~500x500\ndef _maxpool_to_cap(tv, cap=MAX_VERTS):\n    \"\"\"Peak-preserving max-pool of a 2D dB-normalised array down to <= cap\n    vertices. Returns (pooled_tv, fr, fc, r0, c0). Pool factors are integers,\n    aspect-preserving; non-divisible sizes trim the remainder rows/cols. No-op\n    (factors 1x1) when already under the cap. Display-only — never touches the\n    physical source array.\"\"\"\n    import numpy as _np\n    r0, c0 = tv.shape\n    if r0 * c0 <= cap:\n        return tv, 1, 1, r0, c0\n    import math as _math\n    # target_r*target_c ~= cap keeping aspect (target_r/target_c == r0/c0)\n    aspect = r0 / c0\n    target_c = _math.sqrt(cap / aspect)\n    target_r = aspect * target_c\n    fr = max(1, _math.ceil(r0 / max(1.0, target_r)))\n    fc = max(1, _math.ceil(c0 / max(1.0, target_c)))\n    nr = (r0 // fr) * fr\n    nc = (c0 // fc) * fc\n    t = tv[:nr, :nc].reshape(nr // fr, fr, nc // fc, fc)\n    pooled = t.max(axis=(1, 3)).astype(_np.float32)\n    return pooled, fr, fc, r0, c0\n\n\ndef _maxpool_rows_to_cap(tv, cap=MAX_VERTS):\n    \"\"\"Max-pool ONLY axis 0 (rows) down so rows*cols <= cap, leaving axis 1\n    (columns) untouched. Used for range-only crops: the range axis (columns) is\n    the deliberately-upsampled detail and must NOT be coarsened, but the Doppler\n    /azimuth rows are full-res pass-through (no upsample detail) so pooling them\n    is safe. Returns (pooled_tv, fr, 1, r0, c0). Display-only.\"\"\"\n    import numpy as _np, math as _math\n    r0, c0 = tv.shape\n    if r0 * c0 <= cap:\n        return tv, 1, 1, r0, c0\n    target_r = max(1, cap // c0)\n    fr = max(1, _math.ceil(r0 / target_r))\n    nr = (r0 // fr) * fr\n    pooled = tv[:nr, :].reshape(nr // fr, fr, c0).max(axis=1).astype(_np.float32)\n    return pooled, fr, 1, r0, c0\n\ndef crop_upsample_factor(n_rows, n_cols, cap=MAX_VERTS, fmax=6, range_only=False):\n    \"\"\"Largest integer upsample factor F in [1..fmax] keeping the upsampled crop\n    under `cap` vertices, so a crop can be x-upsampled WITHOUT being max-pooled\n    afterwards (pooling a deliberate upsample is self-defeating).\n      2D  (upsample_complex, both axes): verts ~= ((R-1)*F+1)*((C-1)*F+1)\n          -> F ~= floor(sqrt(cap/(R*C)))\n      range-only (upsample_complex_range, only last axis; rows stay full):\n          verts ~= R*((C-1)*F+1) -> F ~= floor((cap/R - 1)/(C-1))\n          (If R alone already nears cap, F clamps to 1 and the caller should pool\n           the ROW axis only via pool='rows' to fit — that keeps range detail.)\n    n_rows/n_cols are the crop's sample counts BEFORE upsampling.\"\"\"\n    import math as _math\n    R = max(1, int(n_rows)); C = max(1, int(n_cols))\n    if range_only:\n        if C <= 1:\n            return max(1, min(fmax, int(cap // R)))\n        F = int((cap / R - 1) // (C - 1))\n    else:\n        F = int(_math.floor(_math.sqrt(cap / (R * C))))\n    return max(1, min(fmax, F))\n\n\n_SURF_TEMPLATE = '\\n<div id=\"wrap\" style=\"position:relative;width:100%;height:__HEIGHT__;background:#08090c\">\\n<canvas id=\"sc\" style=\"width:100%;height:100%;display:block\"></canvas>\\n<div id=\"cbar\" style=\"position:absolute;top:12px;right:12px;background:rgba(14,20,34,0.85);border:1px solid #2a3142;border-radius:6px;padding:5px 7px;color:#cfd6e6;font:10px/1.2 system-ui,sans-serif;user-select:none\">\\n  <div style=\"margin-bottom:3px;color:#9aa4ba\">[dB]</div>\\n  <svg id=\"cbsvg\" width=\"40\" height=\"136\" style=\"display:block\"></svg>\\n</div>\\n<div id=\"ustat\" style=\"position:absolute;bottom:8px;right:10px;background:rgba(14,20,34,0.8);border:1px solid #2a3142;border-radius:4px;padding:2px 8px;font:11px sans-serif;color:#9aa6bd;display:none\"></div>\\n<div style=\"position:absolute;top:8px;left:10px;color:#cbd3e4;font:13px sans-serif\" id=\"ttl\"></div>\\n<button id=\"expandbtn\" title=\"Open in a new window\" style=\"position:absolute;top:8px;right:64px;background:rgba(14,20,34,0.85);border:1px solid #2a3142;border-radius:4px;color:#cfd6e6;font:11px sans-serif;padding:3px 8px;cursor:pointer\">? Expand</button>\\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\"></script>\\n<script>\\nconst D = (window.__POPOUT_D !== undefined) ? window.__POPOUT_D : __PAYLOAD__;\\ndocument.getElementById(\"ttl\").textContent = D.title;\\nif(D.status){const u=document.getElementById(\"ustat\");u.textContent=D.status;u.style.display=\"block\";}\\nconst cv=document.getElementById(\"sc\");\\nconst _wrapEl=document.getElementById(\"wrap\");\\nfunction _W(){return _wrapEl.clientWidth||cv.clientWidth||300;}\\nfunction _H(){return _wrapEl.clientHeight||cv.clientHeight||300;}\\nconst rn=new THREE.WebGLRenderer({canvas:cv,antialias:true});\\nrn.setSize(_W(), _H()); rn.setClearColor(0x08090c);\\nconst sc=new THREE.Scene();\\nconst cam=new THREE.PerspectiveCamera(50, _W()/_H(), 0.01, 100);\\nconst LUT=[[0,0.0015,0.0005,0.0139],[0.13,0.087,0.045,0.255],[0.25,0.231,0.059,0.437],[0.38,0.392,0.111,0.451],[0.5,0.550,0.161,0.405],[0.63,0.716,0.215,0.330],[0.75,0.868,0.288,0.217],[0.88,0.967,0.470,0.106],[1,0.988,0.998,0.645]];\\nfunction inferno(v){let i=0;while(i<LUT.length-1&&v>LUT[i+1][0])i++;const a=LUT[i],b=LUT[Math.min(i+1,LUT.length-1)];const f=(v-a[0])/((b[0]-a[0])||1);return [a[1]+(b[1]-a[1])*f,a[2]+(b[2]-a[2])*f,a[3]+(b[3]-a[3])*f];}\\n(function(){const FLOOR=-40,barH=120,barW=12,padTop=6;const NS=\"http://www.w3.org/2000/svg\";\\n const svg=document.getElementById(\"cbsvg\");const defs=document.createElementNS(NS,\"defs\");\\n const lg=document.createElementNS(NS,\"linearGradient\");lg.setAttribute(\"id\",\"inf-bar\");lg.setAttribute(\"x1\",\"0\");lg.setAttribute(\"y1\",\"0\");lg.setAttribute(\"x2\",\"0\");lg.setAttribute(\"y2\",\"1\");\\n const GS=24;for(let i=0;i<=GS;i++){const frac=i/GS;const tt=1-frac;const r=inferno(tt);const st=document.createElementNS(NS,\"stop\");st.setAttribute(\"offset\",(frac*100)+\"%\");st.setAttribute(\"stop-color\",\"rgb(\"+(r[0]*255|0)+\",\"+(r[1]*255|0)+\",\"+(r[2]*255|0)+\")\");lg.appendChild(st);}\\n defs.appendChild(lg);svg.appendChild(defs);const rect=document.createElementNS(NS,\"rect\");rect.setAttribute(\"x\",0);rect.setAttribute(\"y\",padTop);rect.setAttribute(\"width\",barW);rect.setAttribute(\"height\",barH);rect.setAttribute(\"fill\",\"url(#inf-bar)\");rect.setAttribute(\"stroke\",\"#2a3142\");rect.setAttribute(\"stroke-width\",1);svg.appendChild(rect);\\n for(let db=0;db>=FLOOR;db-=10){const frac=db/FLOOR;const y=padTop+frac*barH;const ln=document.createElementNS(NS,\"line\");ln.setAttribute(\"x1\",barW);ln.setAttribute(\"y1\",y);ln.setAttribute(\"x2\",barW+3);ln.setAttribute(\"y2\",y);ln.setAttribute(\"stroke\",\"#6c7894\");ln.setAttribute(\"stroke-width\",1);svg.appendChild(ln);const tx=document.createElementNS(NS,\"text\");tx.setAttribute(\"x\",barW+6);tx.setAttribute(\"y\",y+3);tx.setAttribute(\"fill\",\"#cfd6e6\");tx.setAttribute(\"font-size\",9);tx.textContent=db;svg.appendChild(tx);}\\n})();\\nconst R=D.nrows,C=D.ncols;\\nconst pos=new Float32Array(R*C*3), col=new Float32Array(R*C*3);\\nfor(let r=0;r<R;r++)for(let cc=0;cc<C;cc++){const k=r*C+cc;const tv=D.t[k];pos[k*3]=(cc/(C-1))*2-1;pos[k*3+1]=tv*D.H;pos[k*3+2]=(r/(R-1))*2-1;const rgb=inferno(tv);col[k*3]=rgb[0];col[k*3+1]=rgb[1];col[k*3+2]=rgb[2];}\\nconst idx=[];for(let r=0;r<R-1;r++)for(let cc=0;cc<C-1;cc++){const a=r*C+cc,b=r*C+cc+1,d=(r+1)*C+cc,e=(r+1)*C+cc+1;idx.push(a,d,b,b,d,e);}\\nconst g=new THREE.BufferGeometry();g.setAttribute(\"position\",new THREE.BufferAttribute(pos,3));g.setAttribute(\"color\",new THREE.BufferAttribute(col,3));g.setIndex(idx);\\nconst mat=new THREE.ShaderMaterial({vertexColors:true,side:THREE.DoubleSide,vertexShader:\"varying vec3 vC; void main(){vC=color; gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0);}\",fragmentShader:\"varying vec3 vC; void main(){float l=max(vC.r,max(vC.g,vC.b)); if(l<0.06) discard; gl_FragColor=vec4(vC,1.0);}\"});\\nsc.add(new THREE.Mesh(g,mat));\\nconst grid=new THREE.GridHelper(2,16,0x1c2230,0x12161f); grid.position.y=-0.001; sc.add(grid);\\nfunction label(text,color){const cn=document.createElement(\"canvas\");cn.width=128;cn.height=32;const x=cn.getContext(\"2d\");x.font=\"20px sans-serif\";x.fillStyle=color;x.textAlign=\"center\";x.textBaseline=\"middle\";x.fillText(text,64,16);const tx=new THREE.CanvasTexture(cn);const sp=new THREE.Sprite(new THREE.SpriteMaterial({map:tx,depthTest:false}));sp.scale.set(0.5,0.125,1);return sp;}\\nfunction addTick(text,x,y,z,color){const s=label(text,color||\"#9aa6bd\");s.position.set(x,y,z);sc.add(s);}\\nconst NT=5;for(let i=0;i<NT;i++){const f=i/(NT-1);const xv=D.xr[0]+(D.xr[1]-D.xr[0])*f; addTick(xv.toFixed(0), f*2-1, -0.06, 1.12, \"#9aa6bd\");const yv=D.yr[0]+(D.yr[1]-D.yr[0])*f; addTick(yv.toFixed(0), -1.12, -0.06, f*2-1, \"#9aa6bd\");}\\naddTick(D.xlabel, 0, -0.18, 1.30, \"#cbd3e4\");\\naddTick(D.ylabel, -1.34, -0.18, 0, \"#cbd3e4\");\\nconst tgt=new THREE.Vector3(0,D.H*0.3,0);\\nlet sph={r:3.4,theta:Math.PI*0.25,phi:Math.PI*0.34};\\nfunction upd(){cam.position.set(tgt.x+sph.r*Math.sin(sph.phi)*Math.cos(sph.theta), tgt.y+sph.r*Math.cos(sph.phi), tgt.z+sph.r*Math.sin(sph.phi)*Math.sin(sph.theta));cam.lookAt(tgt);if(typeof draw===\"function\")draw();}\\nupd();\\nlet mode=0; let pv={x:0,y:0};\\ncv.addEventListener(\"contextmenu\",e=>e.preventDefault());\\ncv.addEventListener(\"pointerdown\",e=>{mode=(e.button===2||e.button===1)?2:1;pv={x:e.clientX,y:e.clientY};cv.setPointerCapture(e.pointerId);});\\ncv.addEventListener(\"pointerup\",e=>{mode=0;});\\ncv.addEventListener(\"pointermove\",e=>{\\n  if(!mode)return; const dx=e.clientX-pv.x, dy=e.clientY-pv.y; pv={x:e.clientX,y:e.clientY};\\n  if(mode===1){ sph.theta+=dx*0.01; sph.phi=Math.max(0.05,Math.min(Math.PI/2-0.02,sph.phi-dy*0.01)); }\\n  else { const right=new THREE.Vector3(), up=new THREE.Vector3();\\n    right.setFromMatrixColumn(cam.matrixWorld,0); up.setFromMatrixColumn(cam.matrixWorld,1);\\n    const k=sph.r*0.0016; tgt.addScaledVector(right,-dx*k); tgt.addScaledVector(up, dy*k); }\\n  upd();\\n});\\ncv.addEventListener(\"wheel\",e=>{e.preventDefault();sph.r*=e.deltaY>0?1.1:0.9;sph.r=Math.max(0.2,Math.min(20,sph.r));upd();},{passive:false});\\nfunction draw(){rn.render(sc,cam);}\\nfunction _fit(){rn.setSize(_W(),_H());cam.aspect=_W()/_H();cam.updateProjectionMatrix();draw();}\\ndraw();new ResizeObserver(()=>{_fit();if(window.__POPOUT_D===undefined){window.parent.postMessage({type:\"iframe-resize\",height:500},\"*\");}}).observe(document.body);\\nif(window.__POPOUT_D!==undefined){requestAnimationFrame(_fit);setTimeout(_fit,80);setTimeout(_fit,300);window.addEventListener(\"resize\",_fit);}\\nconst _eb=document.getElementById(\"expandbtn\");\\nif(window.__POPOUT_D!==undefined){ _eb.style.display=\"none\"; }\\nelse { _eb.addEventListener(\"click\",function(){\\n  var w=window.open(\"\",\"_blank\"); if(!w){alert(\"Popup blocked\");return;}\\n  var html=decodeURIComponent(escape(atob(\"__POPB64__\")));\\n  w.document.open(); w.document.write(html); w.document.close();\\n}); }\\n</script>\\n</div>\\n'\n_SURF_PAIR_TEMPLATE = '\\n<div id=\"wrap\" style=\"position:relative;width:100%;height:__HEIGHT__;background:#08090c\">\\n<canvas id=\"sc\" style=\"width:100%;height:100%;display:block\"></canvas>\\n<div id=\"cbar\" style=\"position:absolute;top:12px;right:12px;background:rgba(14,20,34,0.85);border:1px solid #2a3142;border-radius:6px;padding:5px 7px;color:#cfd6e6;font:10px/1.2 system-ui,sans-serif;user-select:none\">\\n  <div style=\"margin-bottom:3px;color:#9aa4ba\">[dB]</div>\\n  <svg id=\"cbsvg\" width=\"40\" height=\"136\" style=\"display:block\"></svg>\\n</div>\\n<div id=\"ustat\" style=\"position:absolute;bottom:8px;right:10px;background:rgba(14,20,34,0.8);border:1px solid #2a3142;border-radius:4px;padding:2px 8px;font:11px sans-serif;color:#9aa6bd;display:none\"></div>\\n<div style=\"position:absolute;top:8px;left:10px;color:#cbd3e4;font:13px sans-serif\" id=\"ttl\"></div>\\n<div style=\"position:absolute;top:8px;left:10px;margin-top:22px;display:flex;gap:0\">\\n  <button id=\"btnA\" style=\"background:#1b2740;border:1px solid #2a3142;border-right:none;border-radius:4px 0 0 4px;color:#cfd6e6;font:11px sans-serif;padding:3px 10px;cursor:pointer\">Full</button>\\n  <button id=\"btnB\" style=\"background:rgba(14,20,34,0.85);border:1px solid #2a3142;border-radius:0 4px 4px 0;color:#cfd6e6;font:11px sans-serif;padding:3px 10px;cursor:pointer\">Crop</button>\\n</div>\\n<button id=\"expandbtn\" title=\"Open in a new window\" style=\"position:absolute;top:8px;right:64px;background:rgba(14,20,34,0.85);border:1px solid #2a3142;border-radius:4px;color:#cfd6e6;font:11px sans-serif;padding:3px 8px;cursor:pointer\">? Expand</button>\\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\"></script>\\n<script>\\nconst D_A = __PAYLOAD_A__;\\nconst D_B = __PAYLOAD_B__;\\nlet D = D_A;\\nconst cv=document.getElementById(\"sc\");\\nconst _wrapEl=document.getElementById(\"wrap\");\\nfunction _W(){return _wrapEl.clientWidth||cv.clientWidth||300;}\\nfunction _H(){return _wrapEl.clientHeight||cv.clientHeight||300;}\\nconst rn=new THREE.WebGLRenderer({canvas:cv,antialias:true});\\nrn.setSize(_W(), _H()); rn.setClearColor(0x08090c);\\nconst sc=new THREE.Scene();\\nconst cam=new THREE.PerspectiveCamera(50, _W()/_H(), 0.01, 100);\\nconst LUT=[[0,0.0015,0.0005,0.0139],[0.13,0.087,0.045,0.255],[0.25,0.231,0.059,0.437],[0.38,0.392,0.111,0.451],[0.5,0.550,0.161,0.405],[0.63,0.716,0.215,0.330],[0.75,0.868,0.288,0.217],[0.88,0.967,0.470,0.106],[1,0.988,0.998,0.645]];\\nfunction inferno(v){let i=0;while(i<LUT.length-1&&v>LUT[i+1][0])i++;const a=LUT[i],b=LUT[Math.min(i+1,LUT.length-1)];const f=(v-a[0])/((b[0]-a[0])||1);return [a[1]+(b[1]-a[1])*f,a[2]+(b[2]-a[2])*f,a[3]+(b[3]-a[3])*f];}\\n(function(){const FLOOR=-40,barH=120,barW=12,padTop=6;const NS=\"http://www.w3.org/2000/svg\";\\n const svg=document.getElementById(\"cbsvg\");const defs=document.createElementNS(NS,\"defs\");\\n const lg=document.createElementNS(NS,\"linearGradient\");lg.setAttribute(\"id\",\"inf-bar\");lg.setAttribute(\"x1\",\"0\");lg.setAttribute(\"y1\",\"0\");lg.setAttribute(\"x2\",\"0\");lg.setAttribute(\"y2\",\"1\");\\n const GS=24;for(let i=0;i<=GS;i++){const frac=i/GS;const tt=1-frac;const r=inferno(tt);const st=document.createElementNS(NS,\"stop\");st.setAttribute(\"offset\",(frac*100)+\"%\");st.setAttribute(\"stop-color\",\"rgb(\"+(r[0]*255|0)+\",\"+(r[1]*255|0)+\",\"+(r[2]*255|0)+\")\");lg.appendChild(st);}\\n defs.appendChild(lg);svg.appendChild(defs);const rect=document.createElementNS(NS,\"rect\");rect.setAttribute(\"x\",0);rect.setAttribute(\"y\",padTop);rect.setAttribute(\"width\",barW);rect.setAttribute(\"height\",barH);rect.setAttribute(\"fill\",\"url(#inf-bar)\");rect.setAttribute(\"stroke\",\"#2a3142\");rect.setAttribute(\"stroke-width\",1);svg.appendChild(rect);\\n for(let db=0;db>=FLOOR;db-=10){const frac=db/FLOOR;const y=padTop+frac*barH;const ln=document.createElementNS(NS,\"line\");ln.setAttribute(\"x1\",barW);ln.setAttribute(\"y1\",y);ln.setAttribute(\"x2\",barW+3);ln.setAttribute(\"y2\",y);ln.setAttribute(\"stroke\",\"#6c7894\");ln.setAttribute(\"stroke-width\",1);svg.appendChild(ln);const tx=document.createElementNS(NS,\"text\");tx.setAttribute(\"x\",barW+6);tx.setAttribute(\"y\",y+3);tx.setAttribute(\"fill\",\"#cfd6e6\");tx.setAttribute(\"font-size\",9);tx.textContent=db;svg.appendChild(tx);}\\n})();\\nfunction label(text,color){const cn=document.createElement(\"canvas\");cn.width=128;cn.height=32;const x=cn.getContext(\"2d\");x.font=\"20px sans-serif\";x.fillStyle=color;x.textAlign=\"center\";x.textBaseline=\"middle\";x.fillText(text,64,16);const tx=new THREE.CanvasTexture(cn);const sp=new THREE.Sprite(new THREE.SpriteMaterial({map:tx,depthTest:false}));sp.scale.set(0.5,0.125,1);return sp;}\\nconst mat=new THREE.ShaderMaterial({vertexColors:true,side:THREE.DoubleSide,vertexShader:\"varying vec3 vC; void main(){vC=color; gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0);}\",fragmentShader:\"varying vec3 vC; void main(){float l=max(vC.r,max(vC.g,vC.b)); if(l<0.06) discard; gl_FragColor=vec4(vC,1.0);}\"});\\nconst grid=new THREE.GridHelper(2,16,0x1c2230,0x12161f); grid.position.y=-0.001; sc.add(grid);\\n// --- mesh + ticks are rebuilt on toggle; everything else persists ---------\\nlet mesh=null; let ticks=[];\\nfunction _clearTicks(){for(const s of ticks){sc.remove(s);if(s.material&&s.material.map)s.material.map.dispose();if(s.material)s.material.dispose();}ticks=[];}\\nfunction addTick(text,x,y,z,color){const s=label(text,color||\"#9aa6bd\");s.position.set(x,y,z);sc.add(s);ticks.push(s);}\\nfunction buildMesh(d){\\n  // dispose previous geometry/mesh + tick sprites (keep renderer/scene/camera)\\n  if(mesh){sc.remove(mesh);mesh.geometry.dispose();mesh=null;}\\n  _clearTicks();\\n  const R=d.nrows,C=d.ncols;\\n  const pos=new Float32Array(R*C*3), col=new Float32Array(R*C*3);\\n  for(let r=0;r<R;r++)for(let cc=0;cc<C;cc++){const k=r*C+cc;const tv=d.t[k];pos[k*3]=(cc/(C-1))*2-1;pos[k*3+1]=tv*d.H;pos[k*3+2]=(r/(R-1))*2-1;const rgb=inferno(tv);col[k*3]=rgb[0];col[k*3+1]=rgb[1];col[k*3+2]=rgb[2];}\\n  const idx=[];for(let r=0;r<R-1;r++)for(let cc=0;cc<C-1;cc++){const a=r*C+cc,b=r*C+cc+1,dd=(r+1)*C+cc,e=(r+1)*C+cc+1;idx.push(a,dd,b,b,dd,e);}\\n  const g=new THREE.BufferGeometry();g.setAttribute(\"position\",new THREE.BufferAttribute(pos,3));g.setAttribute(\"color\",new THREE.BufferAttribute(col,3));g.setIndex(idx);\\n  mesh=new THREE.Mesh(g,mat);sc.add(mesh);\\n  const NT=5;for(let i=0;i<NT;i++){const f=i/(NT-1);const xv=d.xr[0]+(d.xr[1]-d.xr[0])*f; addTick(xv.toFixed(0), f*2-1, -0.06, 1.12, \"#9aa6bd\");const yv=d.yr[0]+(d.yr[1]-d.yr[0])*f; addTick(yv.toFixed(0), -1.12, -0.06, f*2-1, \"#9aa6bd\");}\\n  addTick(d.xlabel, 0, -0.18, 1.30, \"#cbd3e4\");\\n  addTick(d.ylabel, -1.34, -0.18, 0, \"#cbd3e4\");\\n  document.getElementById(\"ttl\").textContent=d.title;\\n  const u=document.getElementById(\"ustat\");if(d.status){u.textContent=d.status;u.style.display=\"block\";}else{u.style.display=\"none\";}\\n}\\nconst tgt=new THREE.Vector3(0,D.H*0.3,0);\\nlet sph={r:3.4,theta:Math.PI*0.25,phi:Math.PI*0.34};\\nfunction upd(){cam.position.set(tgt.x+sph.r*Math.sin(sph.phi)*Math.cos(sph.theta), tgt.y+sph.r*Math.cos(sph.phi), tgt.z+sph.r*Math.sin(sph.phi)*Math.sin(sph.theta));cam.lookAt(tgt);if(typeof draw===\"function\")draw();}\\nfunction draw(){rn.render(sc,cam);}\\nbuildMesh(D); upd();\\n// --- toggle: swap active payload, rebuild mesh, keep camera ----------------\\nconst _bA=document.getElementById(\"btnA\"),_bB=document.getElementById(\"btnB\");\\nfunction _setActive(which){\\n  D=(which===\"B\")?D_B:D_A;\\n  _bA.style.background=(which===\"B\")?\"rgba(14,20,34,0.85)\":\"#1b2740\";\\n  _bB.style.background=(which===\"B\")?\"#1b2740\":\"rgba(14,20,34,0.85)\";\\n  buildMesh(D); draw();\\n}\\n_bA.addEventListener(\"click\",()=>_setActive(\"A\"));\\n_bB.addEventListener(\"click\",()=>_setActive(\"B\"));\\nlet mode=0; let pv={x:0,y:0};\\ncv.addEventListener(\"contextmenu\",e=>e.preventDefault());\\ncv.addEventListener(\"pointerdown\",e=>{mode=(e.button===2||e.button===1)?2:1;pv={x:e.clientX,y:e.clientY};cv.setPointerCapture(e.pointerId);});\\ncv.addEventListener(\"pointerup\",e=>{mode=0;});\\ncv.addEventListener(\"pointermove\",e=>{\\n  if(!mode)return; const dx=e.clientX-pv.x, dy=e.clientY-pv.y; pv={x:e.clientX,y:e.clientY};\\n  if(mode===1){ sph.theta+=dx*0.01; sph.phi=Math.max(0.05,Math.min(Math.PI/2-0.02,sph.phi-dy*0.01)); }\\n  else { const right=new THREE.Vector3(), up=new THREE.Vector3();\\n    right.setFromMatrixColumn(cam.matrixWorld,0); up.setFromMatrixColumn(cam.matrixWorld,1);\\n    const k=sph.r*0.0016; tgt.addScaledVector(right,-dx*k); tgt.addScaledVector(up, dy*k); }\\n  upd();\\n});\\ncv.addEventListener(\"wheel\",e=>{e.preventDefault();sph.r*=e.deltaY>0?1.1:0.9;sph.r=Math.max(0.2,Math.min(20,sph.r));upd();},{passive:false});\\nfunction _fit(){rn.setSize(_W(),_H());cam.aspect=_W()/_H();cam.updateProjectionMatrix();draw();}\\ndraw();new ResizeObserver(()=>{_fit();if(window.__POPOUT!==true){window.parent.postMessage({type:\"iframe-resize\",height:500},\"*\");}}).observe(document.body);\\nif(window.__POPOUT===true){requestAnimationFrame(_fit);setTimeout(_fit,80);setTimeout(_fit,300);window.addEventListener(\"resize\",_fit);}\\nconst _eb=document.getElementById(\"expandbtn\");\\nif(window.__POPOUT===true){ _eb.style.display=\"none\"; }\\nelse { _eb.addEventListener(\"click\",function(){\\n  var w=window.open(\"\",\"_blank\"); if(!w){alert(\"Popup blocked\");return;}\\n  var html=decodeURIComponent(escape(atob(\"__POPB64__\")));\\n  w.document.open(); w.document.write(html); w.document.close();\\n}); }\\n</script>\\n</div>\\n'\ndef _catmull(p0,p1,p2,p3,t):\n    t2=t*t; t3=t2*t\n    return 0.5*(2*p1+(-p0+p2)*t+(2*p0-5*p1+4*p2-p3)*t2+(-p0+3*p1-3*p2+p3)*t3)\ndef _interp_axis(a, f):\n    import numpy as _np\n    N=a.shape[-1]; outN=(N-1)*f+1; oc=_np.arange(outN); fc=oc/f\n    c1=_np.minimum(N-2,_np.floor(fc).astype(int)); tc=fc-c1\n    cm1=_np.clip(c1-1,0,N-1); c0=_np.clip(c1,0,N-1); cp1=_np.clip(c1+1,0,N-1); cp2=_np.clip(c1+2,0,N-1)\n    return _catmull(a[...,cm1],a[...,c0],a[...,cp1],a[...,cp2],tc)\ndef upsample_complex(field, factor):\n    import numpy as _np\n    f=int(factor)\n    if f<=1: return _np.abs(field)\n    re=field.real; im=field.imag\n    re=_interp_axis(re,f); im=_interp_axis(im,f)\n    re=_np.moveaxis(_interp_axis(_np.moveaxis(re,0,-1),f),-1,0)\n    im=_np.moveaxis(_interp_axis(_np.moveaxis(im,0,-1),f),-1,0)\n    return _np.hypot(re,im)\ndef upsample_axis(ax, f):\n    import numpy as _np\n    f=int(f); return _np.linspace(float(ax[0]), float(ax[-1]), (len(ax)-1)*f+1) if f>1 else _np.asarray(ax)\ndef surface3d(field, x_axis, y_axis, title, xlabel='range [m]', ylabel='azimuth [m]', x_range=None, y_range=None, status=None, pool=True):\n    import numpy as _np, base64 as _b64\n    A = _np.abs(field) if _np.iscomplexobj(field) else _np.asarray(field); xa = x_axis; ya = y_axis\n    if x_range is not None:\n        sel = _np.where((x_axis >= x_range[0]) & (x_axis <= x_range[1]))[0]\n        j0, j1 = int(sel[0]), int(sel[-1]); A = A[:, j0:j1+1]; xa = x_axis[j0:j1+1]\n    if y_range is not None:\n        sel = _np.where((y_axis >= y_range[0]) & (y_axis <= y_range[1]))[0]\n        i0, i1 = int(sel[0]), int(sel[-1]); A = A[i0:i1+1, :]; ya = y_axis[i0:i1+1]\n    dbv = 20*_np.log10(A / A.max() + 1e-12); dbv = _np.clip(dbv, -40, 0)\n    tv = ((dbv + 40) / 40).astype(_np.float32)\n    if pool == 'rows':\n        tv, _fr, _fc, _r0, _c0 = _maxpool_rows_to_cap(tv)\n    elif pool:\n        tv, _fr, _fc, _r0, _c0 = _maxpool_to_cap(tv)\n    else:\n        _fr, _fc, _r0, _c0 = 1, 1, tv.shape[0], tv.shape[1]\n    nr, nc = tv.shape\n    payload = _json.dumps({'t':[round(float(v),3) for v in tv.flatten()],\n        'nrows':nr,'ncols':nc,'xr':[float(xa.min()),float(xa.max())],\n        'yr':[float(ya.min()),float(ya.max())],'H':0.35,\n        'xlabel':xlabel,'ylabel':ylabel,'title':title,'status':status})\n    _pinfo = (' (pooled %dx%d from %dx%d)' % (_fr,_fc,_r0,_c0)) if (_fr>1 or _fc>1) else ''\n    print('three.js surface: %d x %d = %d verts%s, payload %.1f MB' % (nr,nc,nr*nc,_pinfo,len(payload)/1e6))\n    # Popout: same surface body at 100vh, payload via window.__POPOUT_D, button hidden.\n    pop_body = _SURF_TEMPLATE.replace('__HEIGHT__','100vh').replace('__POPB64__','')\n    pop_doc = ('<!doctype html><html><head><meta charset=\"utf-8\"><title>' + title +\n        '</title><style>html,body{margin:0;height:100%;background:#08090c;overflow:hidden}</style>'\n        '<script>window.__POPOUT_D=' + payload + ';</scr'+'ipt></head><body>' + pop_body +\n        '</body></html>')\n    popb64 = _b64.b64encode(pop_doc.encode('utf-8')).decode('ascii')\n    # Inline: 480px, real payload, popout doc embedded as base64 in the Expand handler.\n    inline = _SURF_TEMPLATE.replace('__HEIGHT__','480px').replace('__PAYLOAD__', payload).replace('__POPB64__', popb64)\n    _display(_HTML(inline))\n\ndef upsample_complex_range(field, factor):\n    \"\"\"Complex upsample along the LAST axis (range) only — re/im interpolated\n    separately, then magnitude. Use for Range-Doppler/RCMC crops where only the\n    range axis is cropped and the Doppler axis must stay as-is.\"\"\"\n    import numpy as _np\n    f = int(factor)\n    if f <= 1:\n        return _np.abs(field)\n    re = _interp_axis(field.real, f)\n    im = _interp_axis(field.imag, f)\n    return _np.hypot(re, im)\n\ndef _surf_db_payload(field, x_axis, y_axis, title, xlabel, ylabel, status, pool=True):\n    \"\"\"Shared dB-normalised vertex payload (identical look to surface3d).\"\"\"\n    import numpy as _np\n    A = _np.abs(field) if _np.iscomplexobj(field) else _np.asarray(field)\n    xa = _np.asarray(x_axis); ya = _np.asarray(y_axis)\n    dbv = 20*_np.log10(A / A.max() + 1e-12); dbv = _np.clip(dbv, -40, 0)\n    tv = ((dbv + 40) / 40).astype(_np.float32)\n    if pool == 'rows':\n        tv, _fr, _fc, _r0, _c0 = _maxpool_rows_to_cap(tv)\n    elif pool:\n        tv, _fr, _fc, _r0, _c0 = _maxpool_to_cap(tv)\n    else:\n        _fr, _fc, _r0, _c0 = 1, 1, tv.shape[0], tv.shape[1]\n    nr, nc = tv.shape\n    return {'t':[round(float(v),3) for v in tv.flatten()],\n        'nrows':nr,'ncols':nc,'xr':[float(xa.min()),float(xa.max())],\n        'yr':[float(ya.min()),float(ya.max())],'H':0.35,\n        'xlabel':xlabel,'ylabel':ylabel,'title':title,'status':status,\n        '_pool':(_fr,_fc,_r0,_c0)}\n\ndef surface3d_pair(field_a, xa, ya, title_a, field_b, xb, yb, title_b,\n                   xlabel_a='range [m]', ylabel_a='azimuth [m]',\n                   xlabel_b=None, ylabel_b=None, status_a=None, status_b=None,\n                   pool_a=True, pool_b=False):\n    \"\"\"Two dB surfaces (A=Full, B=Crop) in ONE iframe sharing a single\n    WebGLRenderer. A Full/Crop toggle rebuilds only the mesh geometry + tick\n    sprites — no second WebGL context (halves iframe & context count vs two\n    surface3d calls). Camera/controls/colorbar/Expand popout are preserved.\n    xlabel_b/ylabel_b default to the A labels when None (e.g. Range-Doppler\n    passes ylabel_b='Doppler [Hz]' for both).\"\"\"\n    import base64 as _b64\n    if xlabel_b is None: xlabel_b = xlabel_a\n    if ylabel_b is None: ylabel_b = ylabel_a\n    pa = _surf_db_payload(field_a, xa, ya, title_a, xlabel_a, ylabel_a, status_a, pool=pool_a)\n    pb = _surf_db_payload(field_b, xb, yb, title_b, xlabel_b, ylabel_b, status_b, pool=pool_b)\n    _poa = pa.pop('_pool', (1,1,pa['nrows'],pa['ncols']))\n    _pob = pb.pop('_pool', (1,1,pb['nrows'],pb['ncols']))\n    ja = _json.dumps(pa); jb = _json.dumps(pb)\n    def _pstr(poo, flag):\n        if poo[0] > 1 or poo[1] > 1:\n            tag = 'rows-pooled' if flag == 'rows' else 'pooled'\n            return ' (%s %dx%d from %dx%d)' % (tag, poo[0], poo[1], poo[2], poo[3])\n        return '' if flag and flag != 'rows' else ' (no pool)'\n    _sa = _pstr(_poa, pool_a); _sb = _pstr(_pob, pool_b)\n    print('three.js surface-pair: A %dx%d%s; B %dx%d%s; payload %.1f MB' %\n          (pa['nrows'],pa['ncols'],_sa,pb['nrows'],pb['ncols'],_sb,(len(ja)+len(jb))/1e6))\n    # Popout: full-height pair (both payloads), buttons hidden behind __POPOUT__.\n    pop_body = (_SURF_PAIR_TEMPLATE.replace('__HEIGHT__','100vh')\n        .replace('__PAYLOAD_A__', ja).replace('__PAYLOAD_B__', jb)\n        .replace('__POPB64__',''))\n    pop_doc = ('<!doctype html><html><head><meta charset=\"utf-8\"><title>' + title_a +\n        '</title><style>html,body{margin:0;height:100%;background:#08090c;overflow:hidden}</style>'\n        '<script>window.__POPOUT=true;</scr'+'ipt></head><body>' + pop_body +\n        '</body></html>')\n    popb64 = _b64.b64encode(pop_doc.encode('utf-8')).decode('ascii')\n    inline = (_SURF_PAIR_TEMPLATE.replace('__HEIGHT__','480px')\n        .replace('__PAYLOAD_A__', ja).replace('__PAYLOAD_B__', jb)\n        .replace('__POPB64__', popb64))\n    _display(_HTML(inline))\n\nprint('plot library ready: surface3d, surface3d_pair, crop_upsample_factor, upsample_complex, upsample_complex_range, upsample_axis')",
            "label": "Plot Library",
            "spec": "Plot library for this SAR workspace (workspace-local, not app code). Defined as an unconnected first node so it runs before everything (input-unconnected nodes execute first) and shares its functions with all downstream nodes via the kernel namespace.\n\nFunctions:\n- surface3d(field, x_axis, y_axis, title, xlabel, ylabel, x_range, y_range, status): interactive Three.js 3D dB surface (inferno, -40..0 dB). x_range/y_range crop range/azimuth. On-demand render; left-drag rotate, right-drag pan, wheel zoom; Expand opens a new window.\n- upsample_complex(field, factor): 2-axis complex Catmull-Rom upsample (re/im then |z|) for smooth sidelobes on cropped views.\n- upsample_complex_range(field, factor): complex upsample along the range axis only (Range-Doppler/RCMC crops; Doppler stays as-is).\n- upsample_axis(ax, factor): matching linear upsample of an axis vector.\n- _catmull/_interp_axis: internal Catmull-Rom helpers."
          },
          "codeCollapsed": true
        }
      },
      {
        "id": "n32",
        "type": "canvasNode",
        "position": {
          "x": 2192.9748590288937,
