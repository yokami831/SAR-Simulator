            }
          ],
          "defaultParameters": {
            "code": "# Step 2: Raw echo — full view + x6-upsampled 0-centred crop.\nrg_axis = (t_r - t_r_center) * c / 2\n_W = PEAK_HALF * view_scale\nsurface3d(s_raw, rg_axis, az_pos, 'Step 2: Raw echo (full view)')\n_rc = np.where((rg_axis >= -_W) & (rg_axis <= _W))[0]\n_ac = np.where((az_pos  >= -_W) & (az_pos  <= _W))[0]\n_sub = s_raw[_ac[0]:_ac[-1]+1, _rc[0]:_rc[-1]+1]\n_rgx = rg_axis[_rc[0]:_rc[-1]+1]; _azx = az_pos[_ac[0]:_ac[-1]+1]\nF = 6\n_mag = upsample_complex(_sub, F)\n_rgu = upsample_axis(_rgx, F); _azu = upsample_axis(_azx, F)\nsurface3d(_mag, _rgu, _azu, 'Step 2: Raw echo (x6 crop)', status='upsample x6')\n",
            "label": "Plot Raw Echo",
            "spec": "Display-only: show |s_raw| (raw echo amplitude) over (range, azimuth). Does not modify any physical array."
          },
          "codeCollapsed": true,
          "executionOrder": 15
        },
        "width": 400,
        "style": {}
      },
