          "params": "",
          "defaultParameters": {
            "code": "# === Plot library (workspace-local) ===\n# Display/interpolation helpers for this SAR workspace. Defined here as a\n# visible first node (not hidden in app code) so they are easy to find and\n# edit, and shared with every downstream node via the kernel namespace.\n# See this block's SPEC for what each function does.\n\nimport json as _json\nfrom IPython.display import display as _display, HTML as _HTML\n\n_SURF_TEMPLATE = '\\n<div id=\"wrap\" style=\"position:relative;width:100%;height:__HEIGHT__;background:#08090c\">\\n<canvas id=\"sc\" style=\"width:100%;height:100%;display:block\"></canvas>\\n<div id=\"cbar\" style=\"position:absolute;top:12px;right:12px;background:rgba(14,20,34,0.85);border:1px solid #2a3142;border-radius:6px;padding:5px 7px;color:#cfd6e6;font:10px/1.2 system-ui,sans-serif;user-select:none\">\\n  <div style=\"margin-bottom:3px;color:#9aa4ba\">[dB]</div>\\n  <svg id=\"cbsvg\" width=\"40\" height=\"136\" style=\"display:block\"></svg>\\n</div>\\n<div id=\"ustat\" style=\"position:absolute;bottom:8px;right:10px;background:rgba(14,20,34,0.8);border:1px solid #2a3142;border-radius:4px;padding:2px 8px;font:11px sans-serif;color:#9aa6bd;display:none\"></div>\\n<div style=\"position:absolute;top:8px;left:10px;color:#cbd3e4;font:13px sans-serif\" id=\"ttl\"></div>\\n<button id=\"expandbtn\" title=\"Open in a new window\" style=\"position:absolute;top:8px;right:64px;background:rgba(14,20,34,0.85);border:1px solid #2a3142;border-radius:4px;color:#cfd6e6;font:11px sans-serif;padding:3px 8px;cursor:pointer\">? Expand</button>\\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\"></script>\\n<script>\\nconst D = (window.__POPOUT_D !== undefined) ? window.__POPOUT_D : __PAYLOAD__;\\ndocument.getElementById(\"ttl\").textContent = D.title;\\nif(D.status){const u=document.getElementById(\"ustat\");u.textContent=D.status;u.style.display=\"block\";}\\nconst cv=document.getElementById(\"sc\");\\nconst _wrapEl=document.getElementById(\"wrap\");\\nfunction _W(){return _wrapEl.clientWidth||cv.clientWidth||300;}\\nfunction _H(){return _wrapEl.clientHeight||cv.clientHeight||300;}\\nconst rn=new THREE.WebGLRenderer({canvas:cv,antialias:true});\\nrn.setSize(_W(), _H()); rn.setClearColor(0x08090c);\\nconst sc=new THREE.Scene();\\nconst cam=new THREE.PerspectiveCamera(50, _W()/_H(), 0.01, 100);\\nconst LUT=[[0,0.0015,0.0005,0.0139],[0.13,0.087,0.045,0.255],[0.25,0.231,0.059,0.437],[0.38,0.392,0.111,0.451],[0.5,0.550,0.161,0.405],[0.63,0.716,0.215,0.330],[0.75,0.868,0.288,0.217],[0.88,0.967,0.470,0.106],[1,0.988,0.998,0.645]];\\nfunction inferno(v){let i=0;while(i<LUT.length-1&&v>LUT[i+1][0])i++;const a=LUT[i],b=LUT[Math.min(i+1,LUT.length-1)];const f=(v-a[0])/((b[0]-a[0])||1);return [a[1]+(b[1]-a[1])*f,a[2]+(b[2]-a[2])*f,a[3]+(b[3]-a[3])*f];}\\n(function(){const FLOOR=-40,barH=120,barW=12,padTop=6;const NS=\"http://www.w3.org/2000/svg\";\\n const svg=document.getElementById(\"cbsvg\");const defs=document.createElementNS(NS,\"defs\");\\n const lg=document.createElementNS(NS,\"linearGradient\");lg.setAttribute(\"id\",\"inf-bar\");lg.setAttribute(\"x1\",\"0\");lg.setAttribute(\"y1\",\"0\");lg.setAttribute(\"x2\",\"0\");lg.setAttribute(\"y2\",\"1\");\\n const GS=24;for(let i=0;i<=GS;i++){const frac=i/GS;const tt=1-frac;const r=inferno(tt);const st=document.createElementNS(NS,\"stop\");st.setAttribute(\"offset\",(frac*100)+\"%\");st.setAttribute(\"stop-color\",\"rgb(\"+(r[0]*255|0)+\",\"+(r[1]*255|0)+\",\"+(r[2]*255|0)+\")\");lg.appendChild(st);}\\n defs.appendChild(lg);svg.appendChild(defs);const rect=document.createElementNS(NS,\"rect\");rect.setAttribute(\"x\",0);rect.setAttribute(\"y\",padTop);rect.setAttribute(\"width\",barW);rect.setAttribute(\"height\",barH);rect.setAttribute(\"fill\",\"url(#inf-bar)\");rect.setAttribute(\"stroke\",\"#2a3142\");rect.setAttribute(\"stroke-width\",1);svg.appendChild(rect);\\n for(let db=0;db>=FLOOR;db-=10){const frac=db/FLOOR;const y=padTop+frac*barH;const ln=document.createElementNS(NS,\"line\");ln.setAttribute(\"x1\",barW);ln.setAttribute(\"y1\",y);ln.setAttribute(\"x2\",barW+3);ln.setAttribute(\"y2\",y);ln.setAttribute(\"stroke\",\"#6c7894\");ln.setAttribute(\"stroke-width\",1);svg.appendChild(ln);const tx=document.createElementNS(NS,\"text\");tx.setAttribute(\"x\",barW+6);tx.setAttribute(\"y\",y+3);tx.setAttribute(\"fill\",\"#cfd6e6\");tx.setAttribute(\"font-size\",9);tx.textContent=db;svg.appendChild(tx);}\\n})();\\nconst R=D.nrows,C=D.ncols;\\nconst pos=new Float32Array(R*C*3), col=new Float32Array(R*C*3);\\nfor(let r=0;r<R;r++)for(let cc=0;cc<C;cc++){const k=r*C+cc;const tv=D.t[k];pos[k*3]=(cc/(C-1))*2-1;pos[k*3+1]=tv*D.H;pos[k*3+2]=(r/(R-1))*2-1;const rgb=inferno(tv);col[k*3]=rgb[0];col[k*3+1]=rgb[1];col[k*3+2]=rgb[2];}\\nconst idx=[];for(let r=0;r<R-1;r++)for(let cc=0;cc<C-1;cc++){const a=r*C+cc,b=r*C+cc+1,d=(r+1)*C+cc,e=(r+1)*C+cc+1;idx.push(a,d,b,b,d,e);}\\nconst g=new THREE.BufferGeometry();g.setAttribute(\"position\",new THREE.BufferAttribute(pos,3));g.setAttribute(\"color\",new THREE.BufferAttribute(col,3));g.setIndex(idx);\\nconst mat=new THREE.ShaderMaterial({vertexColors:true,side:THREE.DoubleSide,vertexShader:\"varying vec3 vC; void main(){vC=color; gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0);}\",fragmentShader:\"varying vec3 vC; void main(){float l=max(vC.r,max(vC.g,vC.b)); if(l<0.06) discard; gl_FragColor=vec4(vC,1.0);}\"});\\nsc.add(new THREE.Mesh(g,mat));\\nconst grid=new THREE.GridHelper(2,16,0x1c2230,0x12161f); grid.position.y=-0.001; sc.add(grid);\\nfunction label(text,color){const cn=document.createElement(\"canvas\");cn.width=128;cn.height=32;const x=cn.getContext(\"2d\");x.font=\"20px sans-serif\";x.fillStyle=color;x.textAlign=\"center\";x.textBaseline=\"middle\";x.fillText(text,64,16);const tx=new THREE.CanvasTexture(cn);const sp=new THREE.Sprite(new THREE.SpriteMaterial({map:tx,depthTest:false}));sp.scale.set(0.5,0.125,1);return sp;}\\nfunction addTick(text,x,y,z,color){const s=label(text,color||\"#9aa6bd\");s.position.set(x,y,z);sc.add(s);}\\nconst NT=5;for(let i=0;i<NT;i++){const f=i/(NT-1);const xv=D.xr[0]+(D.xr[1]-D.xr[0])*f; addTick(xv.toFixed(0), f*2-1, -0.06, 1.12, \"#9aa6bd\");const yv=D.yr[0]+(D.yr[1]-D.yr[0])*f; addTick(yv.toFixed(0), -1.12, -0.06, f*2-1, \"#9aa6bd\");}\\naddTick(D.xlabel, 0, -0.18, 1.30, \"#cbd3e4\");\\naddTick(D.ylabel, -1.34, -0.18, 0, \"#cbd3e4\");\\nconst tgt=new THREE.Vector3(0,D.H*0.3,0);\\nlet sph={r:3.4,theta:Math.PI*0.25,phi:Math.PI*0.34};\\nfunction upd(){cam.position.set(tgt.x+sph.r*Math.sin(sph.phi)*Math.cos(sph.theta), tgt.y+sph.r*Math.cos(sph.phi), tgt.z+sph.r*Math.sin(sph.phi)*Math.sin(sph.theta));cam.lookAt(tgt);if(typeof draw===\"function\")draw();}\\nupd();\\nlet mode=0; let pv={x:0,y:0};\\ncv.addEventListener(\"contextmenu\",e=>e.preventDefault());\\ncv.addEventListener(\"pointerdown\",e=>{mode=(e.button===2||e.button===1)?2:1;pv={x:e.clientX,y:e.clientY};cv.setPointerCapture(e.pointerId);});\\ncv.addEventListener(\"pointerup\",e=>{mode=0;});\\ncv.addEventListener(\"pointermove\",e=>{\\n  if(!mode)return; const dx=e.clientX-pv.x, dy=e.clientY-pv.y; pv={x:e.clientX,y:e.clientY};\\n  if(mode===1){ sph.theta+=dx*0.01; sph.phi=Math.max(0.05,Math.min(Math.PI/2-0.02,sph.phi-dy*0.01)); }\\n  else { const right=new THREE.Vector3(), up=new THREE.Vector3();\\n    right.setFromMatrixColumn(cam.matrixWorld,0); up.setFromMatrixColumn(cam.matrixWorld,1);\\n    const k=sph.r*0.0016; tgt.addScaledVector(right,-dx*k); tgt.addScaledVector(up, dy*k); }\\n  upd();\\n});\\ncv.addEventListener(\"wheel\",e=>{e.preventDefault();sph.r*=e.deltaY>0?1.1:0.9;sph.r=Math.max(0.2,Math.min(20,sph.r));upd();},{passive:false});\\nfunction draw(){rn.render(sc,cam);}\\nfunction _fit(){rn.setSize(_W(),_H());cam.aspect=_W()/_H();cam.updateProjectionMatrix();draw();}\\ndraw();new ResizeObserver(()=>{_fit();if(window.__POPOUT_D===undefined){window.parent.postMessage({type:\"iframe-resize\",height:500},\"*\");}}).observe(document.body);\\nif(window.__POPOUT_D!==undefined){requestAnimationFrame(_fit);setTimeout(_fit,80);setTimeout(_fit,300);window.addEventListener(\"resize\",_fit);}\\nconst _eb=document.getElementById(\"expandbtn\");\\nif(window.__POPOUT_D!==undefined){ _eb.style.display=\"none\"; }\\nelse { _eb.addEventListener(\"click\",function(){\\n  var w=window.open(\"\",\"_blank\"); if(!w){alert(\"Popup blocked\");return;}\\n  var html=decodeURIComponent(escape(atob(\"__POPB64__\")));\\n  w.document.open(); w.document.write(html); w.document.close();\\n}); }\\n</script>\\n</div>\\n'\ndef _catmull(p0,p1,p2,p3,t):\n    t2=t*t; t3=t2*t\n    return 0.5*(2*p1+(-p0+p2)*t+(2*p0-5*p1+4*p2-p3)*t2+(-p0+3*p1-3*p2+p3)*t3)\ndef _interp_axis(a, f):\n    import numpy as _np\n    N=a.shape[-1]; outN=(N-1)*f+1; oc=_np.arange(outN); fc=oc/f\n    c1=_np.minimum(N-2,_np.floor(fc).astype(int)); tc=fc-c1\n    cm1=_np.clip(c1-1,0,N-1); c0=_np.clip(c1,0,N-1); cp1=_np.clip(c1+1,0,N-1); cp2=_np.clip(c1+2,0,N-1)\n    return _catmull(a[...,cm1],a[...,c0],a[...,cp1],a[...,cp2],tc)\ndef upsample_complex(field, factor):\n    import numpy as _np\n    f=int(factor)\n    if f<=1: return _np.abs(field)\n    re=field.real; im=field.imag\n    re=_interp_axis(re,f); im=_interp_axis(im,f)\n    re=_np.moveaxis(_interp_axis(_np.moveaxis(re,0,-1),f),-1,0)\n    im=_np.moveaxis(_interp_axis(_np.moveaxis(im,0,-1),f),-1,0)\n    return _np.hypot(re,im)\ndef upsample_axis(ax, f):\n    import numpy as _np\n    f=int(f); return _np.linspace(float(ax[0]), float(ax[-1]), (len(ax)-1)*f+1) if f>1 else _np.asarray(ax)\ndef surface3d(field, x_axis, y_axis, title, xlabel='range [m]', ylabel='azimuth [m]', x_range=None, y_range=None, status=None):\n    import numpy as _np, base64 as _b64\n    A = _np.abs(field) if _np.iscomplexobj(field) else _np.asarray(field); xa = x_axis; ya = y_axis\n    if x_range is not None:\n        sel = _np.where((x_axis >= x_range[0]) & (x_axis <= x_range[1]))[0]\n        j0, j1 = int(sel[0]), int(sel[-1]); A = A[:, j0:j1+1]; xa = x_axis[j0:j1+1]\n    if y_range is not None:\n        sel = _np.where((y_axis >= y_range[0]) & (y_axis <= y_range[1]))[0]\n        i0, i1 = int(sel[0]), int(sel[-1]); A = A[i0:i1+1, :]; ya = y_axis[i0:i1+1]\n    dbv = 20*_np.log10(A / A.max() + 1e-12); dbv = _np.clip(dbv, -40, 0)\n    tv = ((dbv + 40) / 40).astype(_np.float32)\n    nr, nc = tv.shape\n    payload = _json.dumps({'t':[round(float(v),3) for v in tv.flatten()],\n        'nrows':nr,'ncols':nc,'xr':[float(xa.min()),float(xa.max())],\n        'yr':[float(ya.min()),float(ya.max())],'H':0.35,\n        'xlabel':xlabel,'ylabel':ylabel,'title':title,'status':status})\n    print('three.js surface: %d x %d = %.2fM verts, payload %.1f MB' % (nr,nc,nr*nc/1e6,len(payload)/1e6))\n    # Popout: same surface body at 100vh, payload via window.__POPOUT_D, button hidden.\n    pop_body = _SURF_TEMPLATE.replace('__HEIGHT__','100vh').replace('__POPB64__','')\n    pop_doc = ('<!doctype html><html><head><meta charset=\"utf-8\"><title>' + title +\n        '</title><style>html,body{margin:0;height:100%;background:#08090c;overflow:hidden}</style>'\n        '<script>window.__POPOUT_D=' + payload + ';</scr'+'ipt></head><body>' + pop_body +\n        '</body></html>')\n    popb64 = _b64.b64encode(pop_doc.encode('utf-8')).decode('ascii')\n    # Inline: 480px, real payload, popout doc embedded as base64 in the Expand handler.\n    inline = _SURF_TEMPLATE.replace('__HEIGHT__','480px').replace('__PAYLOAD__', payload).replace('__POPB64__', popb64)\n    _display(_HTML(inline))\n\ndef upsample_complex_range(field, factor):\n    \"\"\"Complex upsample along the LAST axis (range) only — re/im interpolated\n    separately, then magnitude. Use for Range-Doppler/RCMC crops where only the\n    range axis is cropped and the Doppler axis must stay as-is.\"\"\"\n    import numpy as _np\n    f = int(factor)\n    if f <= 1:\n        return _np.abs(field)\n    re = _interp_axis(field.real, f)\n    im = _interp_axis(field.imag, f)\n    return _np.hypot(re, im)\n\nprint('plot library ready: surface3d, upsample_complex, upsample_complex_range, upsample_axis')\n",
            "label": "Plot Library",
            "spec": "Plot library for this SAR workspace (workspace-local, not app code). Defined as an unconnected first node so it runs before everything (input-unconnected nodes execute first) and shares its functions with all downstream nodes via the kernel namespace.\n\nFunctions:\n- surface3d(field, x_axis, y_axis, title, xlabel, ylabel, x_range, y_range, status): interactive Three.js 3D dB surface (inferno, -40..0 dB). x_range/y_range crop range/azimuth. On-demand render; left-drag rotate, right-drag pan, wheel zoom; Expand opens a new window.\n- upsample_complex(field, factor): 2-axis complex Catmull-Rom upsample (re/im then |z|) for smooth sidelobes on cropped views.\n- upsample_complex_range(field, factor): complex upsample along the range axis only (Range-Doppler/RCMC crops; Doppler stays as-is).\n- upsample_axis(ax, factor): matching linear upsample of an axis vector.\n- _catmull/_interp_axis: internal Catmull-Rom helpers."
          },
          "executionOrder": 6,
          "codeCollapsed": true
        },
        "style": {
          "width": 400
        }
      }
