      {
        "id": "n41",
        "type": "canvasNode",
        "position": {
          "x": 2606.207951414265,
          "y": 1841.6355275167857
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# Step 6 (2-D): top-down view of the focused image [img] in dB. The 3-D surface\n# (n18) shows valleys between azimuth ridges that, seen at an angle, can read as\n# features the image does not actually contain. This flat 2-D imshow is the\n# faithful top-down picture for judging the real focused image.\n#\n# Emits TWO separate PNGs (Full, then Crop). The frontend shows a Full/Crop\n# toggle + Expand for any node that emits multiple images. Display-only:\n# dB-normalised exactly like the 3-D path (20*log10(|img|/max), clipped -40..0),\n# inferno. Full is max-pooled to a display cap (peak-preserving, display only);\n# Crop is the view window at full resolution. The physical img is never modified.\n# Orientation: origin='upper' + y extent (max..min) so azimuth increases\n# DOWNWARD, matching the 3-D plot (n18) and keeping the image upright.\n# Aspect: aspect='equal' so range and azimuth share the same metric scale\n# (1 km in range = 1 km in azimuth on screen). The figure shape is driven by\n# the data extent, not stretched to fill the axes.\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport io, base64\nfrom IPython.display import display\n\ndef _db(a):\n    A = np.abs(a)\n    d = 20.0 * np.log10(A / (A.max() + 1e-12) + 1e-12)\n    return np.clip(d, -40.0, 0.0)\n\ndef _pool_to(a, cap=1200):\n    R, C = a.shape\n    fr = max(1, int(np.ceil(R / cap))); fc = max(1, int(np.ceil(C / cap)))\n    if fr == 1 and fc == 1:\n        return a\n    Rt = (R // fr) * fr; Ct = (C // fc) * fc\n    return a[:Rt, :Ct].reshape(Rt // fr, fr, Ct // fc, fc).max(axis=(1, 3))\n\ndef _emit_png(field_db, x0, x1, y0, y1, title):\n    # Figure size sized to data extent so aspect='equal' fits without huge margins.\n    dx = abs(x1 - x0); dy = abs(y1 - y0)\n    base_h = 4.5  # inches reserved for image height\n    img_w = base_h * (dx / dy) if dy > 0 else base_h\n    img_w = max(3.0, min(12.0, img_w))  # clamp to a sensible range\n    fig_w = img_w + 1.8  # extra room for colorbar + labels\n    fig, ax = plt.subplots(figsize=(fig_w, base_h + 0.6))\n    im = ax.imshow(field_db, origin='upper', cmap='inferno', vmin=-40, vmax=0,\n                   aspect='equal', extent=[x0, x1, y0, y1])\n    ax.set_title(title); ax.set_xlabel('range [m]'); ax.set_ylabel('azimuth [m]')\n    fig.colorbar(im, ax=ax, label='[dB]', shrink=0.85)\n    buf = io.BytesIO(); fig.savefig(buf, format='png', dpi=110, bbox_inches='tight')\n    plt.close(fig)\n    display({'image/png': base64.b64encode(buf.getvalue()).decode('ascii')}, raw=True)\n\nrg_axis = (t_r - t_r_center) * c / 2\n_W = float(view_scale)\n_rc = np.where((rg_axis >= -_W) & (rg_axis <= _W))[0]\n_ac = np.where((az_pos >= -_W) & (az_pos <= _W))[0]\n_crop = np.abs(img[_ac[0]:_ac[-1]+1, _rc[0]:_rc[-1]+1])\n_rgx = rg_axis[_rc[0]:_rc[-1]+1]; _azx = az_pos[_ac[0]:_ac[-1]+1]\n\n# 1) FULL (max-pooled for display)\nfull_db = _db(_pool_to(np.abs(img)))\n_emit_png(full_db, rg_axis.min(), rg_axis.max(), az_pos.max(), az_pos.min(),\n          'Focused image FULL (2-D, dB)')\n# 2) CROP (view window, full resolution — no pool)\ncrop_db = _db(_crop)\n_emit_png(crop_db, _rgx.min(), _rgx.max(), _azx.max(), _azx.min(),\n          'Focused image CROP (2-D, +/-%dm)' % int(_W))\nprint('2-D focused: full', img.shape, 'pooled', full_db.shape, '| crop', _crop.shape)\n",
            "label": "Plot Focused Image (2-D)"
          },
          "codeCollapsed": true,
          "executionOrder": 31
        },
        "width": 1258,
        "style": {}
      }
    ],
