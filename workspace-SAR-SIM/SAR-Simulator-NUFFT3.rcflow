          "defaultParameters": {
            "code": "# Step 5: After RCMC — full view + range-only adaptive-x crop in ONE block,\n# faithful (surface3d_pair_gl, NO max-pool). Vertical axis is Doppler [Hz]: only\n# the range axis is cropped AND complex-upsampled by F to maximize range detail.\n# The crop title/status note the (range) upsample factor. Toggle Full/Crop.\nrg_axis = (t_r - t_r_center) * c / 2\n_W = float(view_scale)\n\n_rc = np.where((rg_axis >= -_W) & (rg_axis <= _W))[0]\n_sub = S_rd_rcmc[:, _rc[0]:_rc[-1]+1]\n_rgx = rg_axis[_rc[0]:_rc[-1]+1]\nF = crop_upsample_factor(S_rd_rcmc.shape[0], len(_rgx), range_only=True)\n_mag = upsample_complex_range(_sub, F)\n_rgu = upsample_axis(_rgx, F)\n\nsurface3d_pair_gl(\n    S_rd_rcmc, rg_axis, f_eta, 'Step 5: After RCMC (full view)',\n    _mag, _rgu, f_eta, 'Step 5: After RCMC (range x%d crop)' % F,\n    ylabel_a='Doppler [Hz]', ylabel_b='Doppler [Hz]',\n    status_b='upsample x%d (range)' % F)",
            "label": "Plot: RCMC",
