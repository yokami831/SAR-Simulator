            }
          ],
          "defaultParameters": {
            "code": "# === HIL Stub: Save FPGA IQ ===\n# Tab 1 の Route C-in が読む .npy として保存。\nimport numpy as np\nimport os\n\n_path = str(globals().get('hil_output_path', '')).strip()\nif not _path:\n    raise ValueError(\"hil_output_path is empty — set it in the file picker (var_name='hil_output_path')\")\n\n_dir = os.path.dirname(_path)\nif _dir and not os.path.isdir(_dir):\n    os.makedirs(_dir, exist_ok=True)\n\nnp.save(_path, s_raw_fpga.astype(np.complex64))\n\n_size_mb = os.path.getsize(_path) / 1e6\nprint('Saved HIL FPGA IQ to %s  (%.1f MB, shape=%s, peak|s|=%.3f)' % (\n    _path, _size_mb, s_raw_fpga.shape, float(np.abs(s_raw_fpga).max())))\n",
            "label": "Save FPGA IQ"
          }
        }
      },
      {
        "id": "n6",
        "type": "canvasNode",
        "position": {
          "x": 700,
          "y": 771
        },
        "width": 400,
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# === FPGA Compute (Verilator HIL — bit-exact gate-level FFT) ===\n# Full Route B equivalent: Stage A (ADC quantize) -> FFT × multiply × IFFT\n# (each FFT done by the Verilator-compiled Amaranth FFT) -> Stage C (DAC\n# quantize). Bit-exact with what a real FPGA implementing the same Q-format\n# pipeline would produce.\n#\n# Slower than n4 cupy (~18s vs ~0.1s per frame) but gives the gate-accurate\n# reference signal — use to confirm that the cupy result is HW-realizable.\n#\n# Mutually exclusive with n4 (both write s_raw_fpga to the kernel).\nimport numpy as np\nimport sys, os\nimport time as _time\n\n_PROJ = r\"d:\\kamijo\\HiyoCanvas\"\n_SCRIPTS = os.path.join(_PROJ, \"workspace-SAR-SIM\", \"scripts\")\nif _SCRIPTS not in sys.path:\n    sys.path.insert(0, _SCRIPTS)\nfrom verilator_route_b import route_b_pipeline\n\n# Q-format parameters — keep aligned with n43 Route B in the main flow.\n# Defaults match the documented Route B (Q1.9 ADC / Q8.10 FFT internal / Q1.9 DAC).\nQ_IN  = (10, 9)\nQ_FFT = (18, 10)\nQ_OUT = (10, 9)\n\n_t0 = _time.monotonic()\nprint(f\"Verilator HIL Route B start: Q_IN=Q{Q_IN[0]-Q_IN[1]}.{Q_IN[1]}  Q_FFT=Q{Q_FFT[0]-Q_FFT[1]}.{Q_FFT[1]}  Q_OUT=Q{Q_OUT[0]-Q_OUT[1]}.{Q_OUT[1]}\")\n\ns_raw_fpga = route_b_pipeline(\n    fir_coefficients.astype(np.complex64),\n    ref_chirp.astype(np.complex64),\n    Q_IN=Q_IN, Q_FFT=Q_FFT, Q_OUT=Q_OUT,\n    verbose=True,\n)\n\nprint(f\"Verilator HIL Route B done: s_raw_fpga={s_raw_fpga.shape} peak|s|={float(np.abs(s_raw_fpga).max()):.3f}  ({_time.monotonic() - _t0:.2f}s total)\")\n",
            "label": "FPGA Compute (Verilator HIL)"
          },
          "enabled": false,
          "barColor": "#a855f7"
        }
      }
    ],
