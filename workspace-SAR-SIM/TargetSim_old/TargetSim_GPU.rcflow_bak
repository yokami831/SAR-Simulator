          ],
          "defaultParameters": {
            "code": "# RCMC (GPU - staged float32 cubic interpolation)\n# Note: float32 gives ~1.3% range resolution diff vs CPU float64 interp1d.\n#       float64 matches CPU exactly but is ~2x slower due to VRAM limits (8GB).\n#       Peak position is identical in both modes.\nimport cupy as cp\nfrom cupyx.scipy.ndimage import map_coordinates as gpu_map_coordinates\nimport time as _time\n_t0 = _time.monotonic()\n\ndata_len = iq_data_rd.shape[0]\nncols = iq_data_rd.shape[1]\n\nsample_points = np.arange(-(data_len) // 2, data_len // 2)\nfreq = sample_points * (prf / data_len) + doppler_centroid\nfreq = np.roll(freq, np.round(doppler_centroid / (prf / data_len)).astype(int))\nd_rg = c / 2 / fs\n\n# GPU coordinates (float32)\nfreq_gpu = cp.asarray(freq, dtype=cp.float32)\nmf = 1 / cp.sqrt(1 - (wl * freq_gpu / (2 * veff)) ** 2) - 1\ncol_base = cp.arange(ncols, dtype=cp.float32)\nr_sc_px = cp.float32(r_sc / d_rg)\ncol_coords = col_base[cp.newaxis, :] + mf[:, cp.newaxis] * (r_sc_px + col_base[cp.newaxis, :])\nrow_coords = cp.ascontiguousarray(cp.broadcast_to(cp.arange(data_len, dtype=cp.float32)[:, cp.newaxis], (data_len, ncols)))\ncoords_gpu = cp.stack([row_coords, col_coords], axis=0)\ndel mf, col_base, row_coords, col_coords, freq_gpu\ncp.get_default_memory_pool().free_all_blocks()\n\n_t1 = _time.monotonic()\n\n# Staged: real part\niq_real_gpu = cp.asarray(iq_data_rd.real, dtype=cp.float32)\nout_real = gpu_map_coordinates(iq_real_gpu, coords_gpu, order=3, mode='nearest')\nout_real_cpu = cp.asnumpy(out_real)\ndel iq_real_gpu, out_real\ncp.get_default_memory_pool().free_all_blocks()\n\n_t2 = _time.monotonic()\n\n# Staged: imag part\niq_imag_gpu = cp.asarray(iq_data_rd.imag, dtype=cp.float32)\nout_imag = gpu_map_coordinates(iq_imag_gpu, coords_gpu, order=3, mode='nearest')\nout_imag_cpu = cp.asnumpy(out_imag)\ndel iq_imag_gpu, coords_gpu, out_imag\ncp.get_default_memory_pool().free_all_blocks()\n\niq_data_rcmc = (out_real_cpu + 1j * out_imag_cpu).astype(np.complex64)\ndel out_real_cpu, out_imag_cpu\n\nprint(f'RCMC (GPU f32): {iq_data_rcmc.shape} (coords:{_t1-_t0:.2f}s, real:{_t2-_t1:.2f}s, imag:{_time.monotonic()-_t2:.2f}s, total:{_time.monotonic()-_t0:.2f}s)')",
            "label": "RCMC"
          }
        },
        "width": 400
      },
