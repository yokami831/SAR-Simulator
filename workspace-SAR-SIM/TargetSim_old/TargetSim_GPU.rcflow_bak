            }
          ],
          "defaultParameters": {
            "code": "# transmitted chirp pulse\ntime_duration = chirp_len*fs\nt = np.arange(-time_duration/2,time_duration/2,1)/fs\nphase = np.pi*chirp_rate*t**2\nchirp_replica_u = np.exp(1j*phase) # up chirp\nchirp_replica_d = np.exp(-1j*phase) # down chirp\nprint(f'chirp samples: {len(chirp_replica_u)}')",
            "label": "Chirp Pulse"
          }
        },
        "width": 400
      },
      {
        "id": "n7",
        "type": "canvasNode",
        "position": {
          "x": 1906.5907229448703,
          "y": 356.5484328820757
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# simulation swath\nrange_swath = 10e3\nazimuth_swath = 10e3\n\n# range time (fast time)\ntime_duration = (range_swath**2+azimuth_swath**2)**0.5/c\nnsamples = np.ceil(time_duration*fs).astype(int) + len(chirp_replica_u)\nfast_time = np.arange(0,nsamples,1)/fs + 2*r_sc/c\nrg_array = c*fast_time+r_sc\n\n# azimuth time\ntime_duration = azimuth_swath/veff\nnpulses = np.ceil(time_duration*prf).astype(int)\nslow_time = np.arange(-npulses//2,npulses//2,1)/prf\naz_array = veff*slow_time+r_sc*np.tan(squint)\nprint(f'nsamples={nsamples}, npulses={npulses}')",
            "label": "Swath & Time Axes"
          }
        },
        "width": 400
      },
      {
        "id": "n8",
        "type": "canvasNode",
        "position": {
          "x": 2377,
          "y": 295.5
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# Target definition - switchable between point target and image target\nfrom PIL import Image\n\n# === MODE SELECT ===\ntarget_mode = \"image\"  # \"point\" or \"image\"\n\nif target_mode == \"point\":\n    # Single point target (original)\n    points = [(r_sc + range_swath/2, 0)]\n    target_ranges = np.array([p[0] for p in points])\n    target_azimuths = np.array([p[1] for p in points])\n    target_amps = np.ones(len(points))\n    print(f'Point target: {len(points)} targets at {points[0][0]:.0f}m')\n\nelif target_mode == \"image\":\n    # Image-based targets\n    img_path = 'D:/Claude/HiyoCanvas/workspace_TargetSim/strix.png'\n    img = Image.open(img_path).convert('L')\n    gray = np.array(img, dtype=np.float32)\n\n    # No inversion: bright pixels = strong reflection\n    # Set gray = 255.0 - gray to invert (e.g. for line drawings like ya.png, strix.png)\n\n    # 1 pixel = 1 SAR sample\n    d_rg = c / 2 / fs\n    d_az = veff / prf\n    pixel_spacing_rg = d_rg  # 0.799 m/pixel\n    pixel_spacing_az = d_az  # 1.853 m/pixel\n\n    rows, cols = np.where(gray > 0)\n\n    # Center image in the middle of the swath\n    rg_center = r_sc + range_swath / 2\n    az_center = 0.0\n\n    target_ranges = rg_center + (cols - gray.shape[1]/2) * pixel_spacing_rg\n    target_azimuths = az_center + (rows - gray.shape[0]/2) * pixel_spacing_az\n    target_amps = gray[rows, cols] / 255.0\n\n    img_span_rg = gray.shape[1] * pixel_spacing_rg\n    img_span_az = gray.shape[0] * pixel_spacing_az\n\n    print(f'Image target: {img_path.split(\"/\")[-1]}')\n    print(f'  Size: {gray.shape}, Non-zero: {len(rows)} ({len(rows)/gray.size*100:.1f}%)')\n    print(f'  Pixel spacing: {pixel_spacing_rg:.2f}m(rg) x {pixel_spacing_az:.2f}m(az)')\n    print(f'  Image span: {img_span_rg:.0f}m(rg) x {img_span_az:.0f}m(az)')\n    print(f'  Swath: {range_swath:.0f}m(rg) x {azimuth_swath:.0f}m(az)')\n    print(f'  Range: {target_ranges.min()/1e3:.3f} - {target_ranges.max()/1e3:.3f} km')\n    print(f'  Azimuth: {target_azimuths.min():.1f} - {target_azimuths.max():.1f} m')",
            "label": "Target Definition"
          }
        },
        "width": 400
      },
      {
        "id": "n9",
        "type": "canvasNode",
        "position": {
          "x": 2835.360984178454,
          "y": 224.39701257893051
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# IQ data generation (NUFFT pipelined: GPU precompute → parallel NUFFT per batch)\nimport finufft\nimport cupy as cp\nimport concurrent.futures\nimport time as _time\n_t0 = _time.monotonic()\n\nnfast = len(fast_time)\nnpulses = len(slow_time)\nnt = len(target_ranges)\nft0 = fast_time[0]\n\n# Chirp spectrum\nchirp_padded = np.zeros(nfast, dtype=np.complex64)\nif chirp_mode == \"down\":\n    chirp_padded[:len(chirp_replica_d)] = chirp_replica_d\nelse:\n    chirp_padded[:len(chirp_replica_u)] = chirp_replica_u\nchirp_fft = np.fft.fft(chirp_padded).astype(np.complex64)\n\n# Target data on GPU\ntr_gpu = cp.asarray(target_ranges, dtype=cp.float64)\nta_gpu = cp.asarray(target_azimuths, dtype=cp.float64)\ntamp_gpu = cp.asarray(target_amps, dtype=cp.float32)\naz_gpu = cp.asarray(az_array, dtype=cp.float64)\n\n# Batch size for GPU precompute (GPU memory limit)\ngpu_pb = max(10, min(500, int(2e9 / (nt * 32))))\n# Thread count for parallel NUFFT\nn_workers = 8\n\nprint(f'Setup: {nt} targets, {npulses} pulses, gpu_batch={gpu_pb}, nufft_threads={n_workers}')\n\n# Parallel NUFFT worker function\ndef nufft_chunk(x_chunk, w_chunk, pulse_start):\n    plan = finufft.Plan(1, (nfast,), eps=1e-6, dtype='complex64', nthreads=1)\n    n = len(x_chunk)\n    results = np.empty((n, nfast), dtype=np.complex64)\n    for i in range(n):\n        plan.setpts(x_chunk[i])\n        results[i] = np.fft.ifftshift(plan.execute(w_chunk[i]))\n    return pulse_start, results\n\n# Output\nS_all = np.zeros((npulses, nfast), dtype=np.complex64)\n\n# Pipeline: GPU precompute batch → parallel NUFFT → next batch\nfor pstart in range(0, npulses, gpu_pb):\n    pend = min(pstart + gpu_pb, npulses)\n    nb_p = pend - pstart\n    az_batch = az_gpu[pstart:pend]\n\n    # GPU precompute for this batch\n    r_all = cp.sqrt(tr_gpu[cp.newaxis, :]**2 + (ta_gpu[cp.newaxis, :] - az_batch[:, cp.newaxis])**2)\n    angle_all = cp.arctan((az_batch[:, cp.newaxis] - ta_gpu[cp.newaxis, :]) / tr_gpu[cp.newaxis, :])\n    s_az_all = cp.sinc((angle_all - squint) / theta_l_a)**2\n    del angle_all\n    tau_all = 2 * r_all / c - ft0\n    x_batch = cp.asnumpy((-2 * np.pi * fs * tau_all / nfast).astype(cp.float32))\n    del tau_all\n    phase_r = cp.exp(-4j * np.pi * r_all / wl).astype(cp.complex64)\n    w_batch = cp.asnumpy((tamp_gpu[cp.newaxis, :] * s_az_all.astype(cp.float32) * phase_r).astype(cp.complex64))\n    del r_all, s_az_all, phase_r\n    cp.get_default_memory_pool().free_all_blocks()\n\n    # Parallel NUFFT for this batch\n    sub_chunk = max(1, nb_p // n_workers)\n    chunks = [(x_batch[i:i+sub_chunk], w_batch[i:i+sub_chunk], i)\n              for i in range(0, nb_p, sub_chunk)]\n\n    with concurrent.futures.ThreadPoolExecutor(max_workers=n_workers) as executor:\n        futures = [executor.submit(nufft_chunk, xc, wc, start) for xc, wc, start in chunks]\n        for f in concurrent.futures.as_completed(futures):\n            start, results = f.result()\n            S_all[pstart + start : pstart + start + len(results)] = results\n\n    elapsed = _time.monotonic() - _t0\n    progress = pend / npulses\n    remaining = elapsed / progress - elapsed if progress > 0 else 0\n    print(f'\\rProgress: {pend}/{npulses} ({progress*100:.0f}%) {elapsed:.1f}s ~{remaining:.0f}s left', end='')\n\n_t2 = _time.monotonic()\n\n# Batch chirp multiply + IFFT on GPU\nS_gpu = cp.asarray(S_all)\nchirp_gpu = cp.asarray(chirp_fft)\niq_data = cp.asnumpy(cp.fft.ifft(S_gpu * chirp_gpu[cp.newaxis, :], axis=1)).astype(np.complex64)\ndel S_gpu, chirp_gpu, S_all\ncp.get_default_memory_pool().free_all_blocks()\n\nprint(f'IQ generated: {iq_data.shape}, {nt} targets, total: {_time.monotonic()-_t0:.1f}s (precomp+nufft: {_t2-_t0:.1f}s)')",
            "label": "IQ Gen (NUFFT parallel)"
          }
        },
        "width": 412,
        "height": 765
      },
      {
