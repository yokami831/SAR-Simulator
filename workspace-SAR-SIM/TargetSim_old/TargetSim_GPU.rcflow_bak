      {
        "id": "n28",
        "type": "canvasNode",
        "position": {
          "x": 868.2631632449409,
          "y": 583.5738640651504
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "params": "",
          "defaultParameters": {
            "code": "def peak_find(input,interval=10,num=3):\n    idx = []\n    data = np.abs(input)\n\n    for i in range(num):\n        idx_i=list(zip(*np.where(data==np.max(data))))\n        idx.append(idx_i[0])\n        data[idx_i[0][0]-interval//2:idx_i[0][0]+interval//2,idx_i[0][1]-interval//2:idx_i[0][1]+interval//2]=0\n\n    return idx\n\n# plot the data in dB scale\ndef image_plot_dB(data, extent=None, xlabel='Range (km)', ylabel='Azimuth (km)',\n                  threshould_dB=20):\n    # mode: \"fast\" = max-pooling (good for point targets), \"quality\" = no pooling (good for images)\n    mode=  \"quality\"\n    plot_size_az = 20000\n    plot_size_rg = 20000\n    if len(data) > plot_size_az:\n        az_l = len(data) // 2 - plot_size_az // 2\n        az_u = len(data) // 2 + plot_size_az // 2\n    else:\n        az_l = 0\n        az_u = len(data)\n    if len(data[0]) > plot_size_rg:\n        rg_l = len(data[0]) // 2 - plot_size_rg // 2\n        rg_u = len(data[0]) // 2 + plot_size_rg // 2\n    else:\n        rg_l = 0\n        rg_u = len(data[0])\n    plot_data = np.abs(data[az_l:az_u, rg_l:rg_u])\n    norm_factor = np.max(plot_data)\n    plot_data = plot_data / norm_factor\n    plot_data = np.ceil(plot_data * 10 ** (threshould_dB / 20)) / 10 ** (\n        threshould_dB / 20\n    )\n    db_data = 20 * np.log10(plot_data)\n\n    if mode == 'fast':\n        # Max-pooling to reduce array size (fast, good for point targets)\n        target_h, target_w = 600, 800\n        h, w = db_data.shape\n        if h > target_h or w > target_w:\n            bh = max(1, h // target_h)\n            bw = max(1, w // target_w)\n            th = (h // bh) * bh\n            tw = (w // bw) * bw\n            db_data = db_data[:th, :tw].reshape(th // bh, bh, tw // bw, bw).max(axis=(1, 3))\n\n    # mode == 'quality': no pooling, matplotlib handles the rendering\n\n    imshow_kwargs = dict(cmap=\"gray\", aspect='auto')\n    if extent is not None:\n        imshow_kwargs['extent'] = extent\n    plt.imshow(db_data, **imshow_kwargs)\n    plt.xlabel(xlabel)\n    plt.ylabel(ylabel)\n    plt.colorbar(label='dB')\n    plt.tight_layout()\n    plt.show()\n\n    return",
            "label": "Image_Plot"
          },
          "codeCollapsed": false
        },
        "style": {
          "width": 400
        }
      }
    ],
