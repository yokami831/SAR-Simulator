            }
          ],
          "defaultParameters": {
            "code": "# preparation of range reference function\nt_chirp_u = np.zeros(len(iq_data[0]),dtype=np.complex64)\nt_chirp_d = np.zeros(len(iq_data[0]),dtype=np.complex64)\nchirp_l = len(chirp_replica_u)\nt_chirp_u[:len(chirp_replica_u)] = chirp_replica_u\nt_chirp_d[:len(chirp_replica_d)] = chirp_replica_d\n\n# convert to frequency domain\nt_chirp_u_f = np.fft.fft(t_chirp_u)\nt_chirp_d_f = np.fft.fft(t_chirp_d)\nprint('Range reference ready')",
            "label": "Range Reference"
          }
        },
        "width": 400
      },
      {
        "id": "n12",
        "type": "canvasNode",
        "position": {
          "x": 3757,
          "y": 243.5
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# range compression (GPU)\nimport cupy as cp\n\niq_data_gpu = cp.asarray(iq_data)\niq_data_f = cp.fft.fft(iq_data_gpu, axis=1)\ndel iq_data_gpu\n\nif chirp_mode == \"down\":\n    ref_f = cp.conj(cp.asarray(t_chirp_d_f))\n    iq_rg_cmp_gpu = cp.fft.ifft(iq_data_f * ref_f[cp.newaxis, :], axis=1)\nelif chirp_mode == \"up\":\n    ref_f = cp.conj(cp.asarray(t_chirp_u_f))\n    iq_rg_cmp_gpu = cp.fft.ifft(iq_data_f * ref_f[cp.newaxis, :], axis=1)\nelse:\n    ref_u_f = cp.conj(cp.asarray(t_chirp_u_f))\n    ref_d_f = cp.conj(cp.asarray(t_chirp_d_f))\n    iq_rg_cmp_gpu = cp.zeros_like(iq_data_f)\n    iq_rg_cmp_gpu[1::2, :] = cp.fft.ifft(iq_data_f[1::2, :] * ref_u_f[cp.newaxis, :], axis=1)\n    iq_rg_cmp_gpu[0::2, :] = cp.fft.ifft(iq_data_f[0::2, :] * ref_d_f[cp.newaxis, :], axis=1)\n\ndel iq_data_f\niq_rg_cmp = cp.asnumpy(iq_rg_cmp_gpu).astype(np.complex64)\ndel iq_rg_cmp_gpu\ncp.get_default_memory_pool().free_all_blocks()\nprint(f'Range compression done (GPU): {iq_rg_cmp.shape}')",
            "label": "Range Compression"
          }
        },
        "width": 400
      },
