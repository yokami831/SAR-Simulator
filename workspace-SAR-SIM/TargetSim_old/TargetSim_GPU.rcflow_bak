            "code": "# Peak & Zoom Plot - switchable between peak zoom and full view\nplot_mode = \"peak\"  # \"peak\" for point target zoom, \"full\" for image target full view\n\nslant_range = c * fast_time / 2\nd_rg = c / 2 / fs\nd_az = veff / prf\n\nif plot_mode == \"peak\":\n    # Point target: zoom around peak\n    peak_idx = peak_find(slc, interval=10, num=1)\n    plot_len = 1000\n    az_center = az_array[peak_idx[0][0]]\n    rg_center = slant_range[peak_idx[0][1]]\n    az_half = plot_len // 2 * d_az\n    rg_half = plot_len // 2 * d_rg\n    extent = [(rg_center - rg_half)/1e3, (rg_center + rg_half)/1e3,\n              (az_center + az_half)/1e3, (az_center - az_half)/1e3]\n    print(f'Peak position: az={peak_idx[0][0]} ({az_center:.1f} m), rg={peak_idx[0][1]} ({rg_center:.1f} m)')\n    image_plot_dB(slc[peak_idx[0][0]-plot_len//2:peak_idx[0][0]+plot_len//2,\n                      peak_idx[0][1]-plot_len//2:peak_idx[0][1]+plot_len//2],\n                  extent=extent, xlabel='Range (km)', ylabel='Azimuth (km)')\n\nelif plot_mode == \"full\":\n    # Image target: full SLC view\n    peak_idx = peak_find(slc, interval=10, num=1)\n    az_center = az_array[peak_idx[0][0]]\n    rg_center = slant_range[peak_idx[0][1]]\n    print(f'Peak position: az={peak_idx[0][0]} ({az_center:.1f} m), rg={peak_idx[0][1]} ({rg_center:.1f} m)')\n    extent = [slant_range[0]/1e3, slant_range[-1]/1e3,\n              az_array[-1]/1e3, az_array[0]/1e3]\n    image_plot_dB(slc, extent=extent, xlabel='Range (km)', ylabel='Azimuth (km)')",
