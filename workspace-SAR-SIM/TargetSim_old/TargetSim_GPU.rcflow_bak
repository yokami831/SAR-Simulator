            }
          ],
          "defaultParameters": {
            "code": "slant_range = c * fast_time / 2 / 1e3  # km\naz_km = az_array / 1e3  # km\nextent = [slant_range[0], slant_range[-1], az_km[-1], az_km[0]]\nimage_plot_dB(iq_data, extent=extent, xlabel='Range (km)', ylabel='Azimuth (km)')",
            "label": "IQ Data Plot"
          },
          "codeCollapsed": true
