          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# azimuth chirp signal generation\ndef azimuth_chirp(doppler_centroid, tau, fm_rate):\n    dt = 1 / prf\n    n_points = np.floor(tau * prf).astype(int)\n    t = np.arange(-n_points // 2, n_points // 2) * dt\n    phase = 2 * np.pi * doppler_centroid * t + np.pi * fm_rate * t**2\n    chirp = np.exp(1j * phase)\n    return chirp\n\n# azimuth reference function generation\ndef azimuth_reference(ri, datalen):\n    ri = ri / np.sqrt(1 - (wl * doppler_centroid) / (2 * veff) ** 2)\n    fm_rate = -(2 * veff**2 / wl) / ri\n    az_beamwidth = ri * (wl / l_a) * 1.2\n    tau_az = az_beamwidth / veff\n\n    az_ref = azimuth_chirp(doppler_centroid, tau_az, fm_rate)\n    az_ref_len = len(az_ref)\n    az_ref_padded = np.zeros(datalen, np.complex64)\n    az_ref_padded[:az_ref_len] = az_ref\n    shift = az_ref_len//2 + int(-(2*(doppler_centroid)/fm_rate)*prf)//2\n    az_ref = np.roll(az_ref_padded, - shift)\n\n    return az_ref\n\n# azimuth compression\ndef azimuth_compression(data):\n    datalen = data.shape[0]\n    for i in range(len(data[0])):\n        ri = r_sc + c / (2 * fs) * i\n        az_ref = azimuth_reference(ri, datalen)\n        az_ref = np.conj(np.fft.fftshift(np.fft.fft(az_ref))).astype(np.complex64)\n        data[:, i] = data[:, i] * az_ref\n    return data\n\nprint('Az functions defined')",
            "label": "Az Chirp & Compress Funcs"
          }
        },
        "width": 400
      },
      {
        "id": "n19",
        "type": "canvasNode",
        "position": {
          "x": 5599.854288773657,
          "y": 228.42421381905814
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# azimuth compression (GPU v5 - batch FFT on GPU)\nimport cupy as cp\nimport time as _time\n_t0 = _time.monotonic()\n\ndatalen = iq_data_rcmc.shape[0]\nncols = iq_data_rcmc.shape[1]\ndt = 1 / prf\n\n# All ri values\nri_all = r_sc + c / (2 * fs) * np.arange(ncols)\nri_corr = ri_all / np.sqrt(1 - (wl * doppler_centroid) / (2 * veff) ** 2)\nfm_rate_all = -(2 * veff**2 / wl) / ri_corr\naz_bw_all = ri_corr * (wl / l_a) * 1.2\ntau_az_all = az_bw_all / veff\nn_points_all = np.floor(tau_az_all * prf).astype(int)\n\n# Build all padded chirps on CPU (loop is fast, chirps are small)\npadded_all = np.zeros((ncols, datalen), dtype=np.complex64)\nfor i in range(ncols):\n    npts = n_points_all[i]\n    t_chirp = np.arange(-npts // 2, npts // 2) * dt\n    phase = 2 * np.pi * doppler_centroid * t_chirp + np.pi * fm_rate_all[i] * t_chirp**2\n    padded_all[i, :npts] = np.exp(1j * phase).astype(np.complex64)\n    shift = npts // 2 + int(-(2 * doppler_centroid / fm_rate_all[i]) * prf) // 2\n    padded_all[i] = np.roll(padded_all[i], -shift)\n\n_t1 = _time.monotonic()\n\n# Batch FFT on GPU (all columns at once)\npadded_gpu = cp.asarray(padded_all)\naz_refs_gpu = cp.conj(cp.fft.fftshift(cp.fft.fft(padded_gpu, axis=1), axes=1)).astype(cp.complex64)\ndel padded_gpu\n\n# GPU multiply\niq_gpu = cp.asarray(iq_data_rcmc)\niq_az_cmp = cp.asnumpy(iq_gpu * az_refs_gpu.T).astype(np.complex64)\n\ndel az_refs_gpu, iq_gpu\ncp.get_default_memory_pool().free_all_blocks()\n\nprint(f'Az compression (GPU v5): {iq_az_cmp.shape} (chirp:{_t1-_t0:.2f}s, fft+mul:{_time.monotonic()-_t1:.2f}s, total:{_time.monotonic()-_t0:.2f}s)')",
            "label": "Az Compression"
          }
        },
        "width": 400
      },
