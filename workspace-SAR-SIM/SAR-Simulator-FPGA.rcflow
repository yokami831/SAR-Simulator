      {
        "id": "n14",
        "type": "canvasNode",
        "position": {
          "x": 714.7787165463642,
          "y": 2096.9510393888813
        },
        "width": 400,
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
