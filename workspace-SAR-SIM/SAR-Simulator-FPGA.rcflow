          "defaultParameters": {
            "code": "# === Plot library (workspace-local) ===\n# Display/interpolation helpers for this SAR workspace. Defined here as a\n# visible first node (not hidden in app code) so they are easy to find and\n# edit, and shared with every downstream node via the kernel namespace.\n# See this block's SPEC for what each function does.\n\nimport json as _json\nfrom IPython.display import display as _display, HTML as _HTML\n\n# Display vertex cap used by crop_upsample_factor to bound the upsampled-crop\n# vertex count so a complex-upsampled crop stays under the 4GB-capped renderer\n# heap. (The _gl display path is full resolution / no max-pool.)\nMAX_VERTS = 250000  # ~500x500\n\ndef crop_upsample_factor(n_rows, n_cols, cap=MAX_VERTS, fmax=6, range_only=False):\n    \"\"\"Largest integer upsample factor F in [1..fmax] keeping the upsampled crop\n    under `cap` vertices, so a crop can be x-upsampled WITHOUT being max-pooled\n    afterwards (pooling a deliberate upsample is self-defeating).\n      2D  (upsample_complex, both axes): verts ~= ((R-1)*F+1)*((C-1)*F+1)\n          -> F ~= floor(sqrt(cap/(R*C)))\n      range-only (upsample_complex_range, only last axis; rows stay full):\n          verts ~= R*((C-1)*F+1) -> F ~= floor((cap/R - 1)/(C-1))\n          (If R alone already nears cap, F clamps to 1 and the caller should pool\n           the ROW axis only via pool='rows' to fit — that keeps range detail.)\n    n_rows/n_cols are the crop's sample counts BEFORE upsampling.\"\"\"\n    import math as _math\n    R = max(1, int(n_rows)); C = max(1, int(n_cols))\n    if range_only:\n        if C <= 1:\n            return max(1, min(fmax, int(cap // R)))\n        F = int((cap / R - 1) // (C - 1))\n    else:\n        F = int(_math.floor(_math.sqrt(cap / (R * C))))\n    return max(1, min(fmax, F))\n\n\ndef _catmull(p0,p1,p2,p3,t):\n    t2=t*t; t3=t2*t\n    return 0.5*(2*p1+(-p0+p2)*t+(2*p0-5*p1+4*p2-p3)*t2+(-p0+3*p1-3*p2+p3)*t3)\ndef _interp_axis(a, f):\n    import numpy as _np\n    N=a.shape[-1]; outN=(N-1)*f+1; oc=_np.arange(outN); fc=oc/f\n    c1=_np.minimum(N-2,_np.floor(fc).astype(int)); tc=fc-c1\n    cm1=_np.clip(c1-1,0,N-1); c0=_np.clip(c1,0,N-1); cp1=_np.clip(c1+1,0,N-1); cp2=_np.clip(c1+2,0,N-1)\n    return _catmull(a[...,cm1],a[...,c0],a[...,cp1],a[...,cp2],tc)\ndef upsample_complex(field, factor):\n    import numpy as _np\n    f=int(factor)\n    if f<=1: return _np.abs(field)\n    re=field.real; im=field.imag\n    re=_interp_axis(re,f); im=_interp_axis(im,f)\n    re=_np.moveaxis(_interp_axis(_np.moveaxis(re,0,-1),f),-1,0)\n    im=_np.moveaxis(_interp_axis(_np.moveaxis(im,0,-1),f),-1,0)\n    return _np.hypot(re,im)\ndef upsample_axis(ax, f):\n    import numpy as _np\n    f=int(f); return _np.linspace(float(ax[0]), float(ax[-1]), (len(ax)-1)*f+1) if f>1 else _np.asarray(ax)\n\ndef upsample_complex_range(field, factor):\n    \"\"\"Complex upsample along the LAST axis (range) only — re/im interpolated\n    separately, then magnitude. Use for Range-Doppler/RCMC crops where only the\n    range axis is cropped and the Doppler axis must stay as-is.\"\"\"\n    import numpy as _np\n    f = int(factor)\n    if f <= 1:\n        return _np.abs(field)\n    re = _interp_axis(field.real, f)\n    im = _interp_axis(field.imag, f)\n    return _np.hypot(re, im)\n\ndef _emit_surface_gl(tv, xa, ya, title, xlabel, ylabel, status, H=0.35):\n    \"\"\"Emit the surface as the new binary single-renderer mime.\n    tv: float32 0..1 dB-normalised grid (same definition as _surf_db_payload).\n    Vertices go out as base64(Float32Array) — emitted ONCE (no double-embed).\"\"\"\n    import numpy as _np, base64 as _b64, json as _json2\n    tvf = _np.ascontiguousarray(tv, dtype=_np.float32)\n    nr, nc = tvf.shape\n    meta = {'kind':'single','title':title,'status':status,\n        'nrows':int(nr),'ncols':int(nc),'H':float(H),\n        'xr':[float(_np.min(xa)),float(_np.max(xa))],\n        'yr':[float(_np.min(ya)),float(_np.max(ya))],\n        'xlabel':xlabel,'ylabel':ylabel,'dtype':'float32',\n        'field_b64':_b64.b64encode(tvf.tobytes()).decode('ascii')}\n    _display({'application/x-hiyocanvas-surface3d': _json2.dumps(meta)}, raw=True)\n    print('surface3d_gl: %d x %d = %d cells, payload %.1f MB (binary path)' %\n          (nr, nc, nr*nc, len(meta['field_b64'])/1e6))\n\ndef surface3d_gl(field, x_axis, y_axis, title, xlabel='range [m]', ylabel='azimuth [m]',\n                 x_range=None, y_range=None, status=None):\n    \"\"\"Binary single-renderer twin of surface3d (NO max-pool, NO string double-embed).\n    dB-normalisation identical to surface3d so old/new pixel comparison is valid.\"\"\"\n    import numpy as _np\n    A = _np.abs(field) if _np.iscomplexobj(field) else _np.asarray(field)\n    xa = _np.asarray(x_axis); ya = _np.asarray(y_axis)\n    if x_range is not None:\n        sel=_np.where((xa>=x_range[0])&(xa<=x_range[1]))[0]; j0,j1=int(sel[0]),int(sel[-1]); A=A[:,j0:j1+1]; xa=xa[j0:j1+1]\n    if y_range is not None:\n        sel=_np.where((ya>=y_range[0])&(ya<=y_range[1]))[0]; i0,i1=int(sel[0]),int(sel[-1]); A=A[i0:i1+1,:]; ya=ya[i0:i1+1]\n    dbv = 20*_np.log10(A/A.max()+1e-12); dbv=_np.clip(dbv,-40,0)\n    tv = ((dbv+40)/40).astype(_np.float32)\n    _emit_surface_gl(tv, xa, ya, title, xlabel, ylabel, status)\n\n\ndef _surf_gl_sub(field, x_axis, y_axis, title, xlabel, ylabel, status, H=0.35):\n    \"\"\"Build one sub-payload dict (a or b) for surface3d_pair_gl. dB-normalisation\n    identical to _emit_surface_gl / _surf_db_payload (load-bearing for old/new compare).\"\"\"\n    import numpy as _np, base64 as _b64\n    A = _np.abs(field) if _np.iscomplexobj(field) else _np.asarray(field)\n    xa = _np.asarray(x_axis); ya = _np.asarray(y_axis)\n    dbv = 20*_np.log10(A/A.max()+1e-12); dbv=_np.clip(dbv,-40,0)\n    tv = ((dbv+40)/40).astype(_np.float32); tvf=_np.ascontiguousarray(tv,dtype=_np.float32)\n    nr,nc = tvf.shape\n    return {'title':title,'status':status,'nrows':int(nr),'ncols':int(nc),'H':float(H),\n        'xr':[float(_np.min(xa)),float(_np.max(xa))],'yr':[float(_np.min(ya)),float(_np.max(ya))],\n        'xlabel':xlabel,'ylabel':ylabel,'dtype':'float32',\n        'field_b64':_b64.b64encode(tvf.tobytes()).decode('ascii')}\n\ndef surface3d_pair_gl(field_a, xa, ya, title_a, field_b, xb, yb, title_b,\n                      xlabel_a='range [m]', ylabel_a='azimuth [m]', xlabel_b=None, ylabel_b=None,\n                      status_a=None, status_b=None):\n    \"\"\"Binary single-renderer twin of surface3d_pair (Full=a / Crop=b toggle).\n    NO max-pool, NO string double-embed. dB-norm identical to surface3d_pair_gl single.\"\"\"\n    import json as _json2\n    if xlabel_b is None: xlabel_b = xlabel_a\n    if ylabel_b is None: ylabel_b = ylabel_a\n    a = _surf_gl_sub(field_a, xa, ya, title_a, xlabel_a, ylabel_a, status_a)\n    b = _surf_gl_sub(field_b, xb, yb, title_b, xlabel_b, ylabel_b, status_b)\n    meta = {'kind':'pair','a':a,'b':b}\n    _display({'application/x-hiyocanvas-surface3d': _json2.dumps(meta)}, raw=True)\n    print('surface3d_pair_gl: A %dx%d / B %dx%d, payload %.1f MB (binary path)' %\n          (a['nrows'],a['ncols'],b['nrows'],b['ncols'],(len(a['field_b64'])+len(b['field_b64']))/1e6))\n\nprint('plot library ready: crop_upsample_factor, upsample_complex, upsample_complex_range, upsample_axis, surface3d_gl, surface3d_pair_gl')",
            "label": "Plot Library",
            "spec": "Plot library for this SAR workspace (workspace-local, not app code). Defined as an unconnected first node so it runs before everything (input-unconnected nodes execute first) and shares its functions with all downstream nodes via the kernel namespace.\n\nFunctions:\n- surface3d(field, x_axis, y_axis, title, xlabel, ylabel, x_range, y_range, status): interactive Three.js 3D dB surface (inferno, -40..0 dB). x_range/y_range crop range/azimuth. On-demand render; left-drag rotate, right-drag pan, wheel zoom; Expand opens a new window.\n- upsample_complex(field, factor): 2-axis complex Catmull-Rom upsample (re/im then |z|) for smooth sidelobes on cropped views.\n- upsample_complex_range(field, factor): complex upsample along the range axis only (Range-Doppler/RCMC crops; Doppler stays as-is).\n- upsample_axis(ax, factor): matching linear upsample of an axis vector.\n- _catmull/_interp_axis: internal Catmull-Rom helpers."
          },
          "codeCollapsed": true
        }
      },
      {
        "id": "n32",
        "type": "canvasNode",
        "position": {
          "x": 2160.7966858033133,
