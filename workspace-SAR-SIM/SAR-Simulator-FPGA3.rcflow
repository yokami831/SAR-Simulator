            }
          ],
          "defaultParameters": {
            "var_name": "route_mode",
            "options_csv": "float,fixed,hdl",
            "label": "Route Selector",
            "value": "hdl",
            "spec": "【Route Selector — 3ルート切替ドロップダウン】\n\nvar_name='route_mode'。s_raw(反射波)をどの方式で生成するかをここ1箇所で選ぶ。\n3つのルートノード(n42/n43/n62)は全て enabled だが、各々が先頭で route_mode を見て\n『自分が選ばれた時だけ』s_raw を計算する。→ 同時実行・後勝ち事故が原理的に起きない。\n\n  float : Route A (n42) 浮動小数点・理想 (golden)。ifft(S_all x chirp_fft)。\n  fixed : Route B (n43) Python(cupy) 固定小数点。Q-format 量子化を模擬。\n  hdl   : Route HDL (n62) Verilator ゲートレベル。実HDLと同じ算術 (route_b_pipeline)。\n\nQ-format は n60 'FPGA Q-Format Config' の単一ソースを 3 ルート共通で使う。\n切替はこのドロップダウンの値を変えて再実行するだけ。enable/disable は触らない。"
          },
          "executionOrder": 3
        },
        "width": 250,
        "style": {}
      },
      {
        "id": "n62",
        "type": "canvasNode",
        "position": {
          "x": 3551.716933450932,
          "y": 717.2550974406334
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# === FPGA Route HDL: Verilator gate-level simulation ===\n# route_mode == 'hdl' のときだけ実行。Amaranth->Verilog->Verilator でコンパイルした\n# 実HDLと同じゲートレベル FFT で Route B 相当を計算 (route_b_pipeline)。\n# Q_IN/Q_FFT/Q_OUT は n60 \"FPGA Q-Format Config\" の単一ソースを使う。\n# float=Route A / fixed=Route B(Python) / hdl=ここ。Route Selector ドロップダウンで切替。\n#\n# Nr は n2 で 2のべき乗 (next_pow2) に設定済み。radix-2 FFT がそのまま Nr 長で動くので\n# route_b_pipeline は内部 next_pow2(Nr)==Nr -> ゼロ埋め不要・切出し不要 = 純粋な巡回 Nr。\n# よって float/fixed(巡回 Nr) と同じ巡回長になり、継ぎ目なしで一致する。N_FFT は渡さない\n# (固定 FFT 長のハードコードは廃止。Nr が pow2 のまま可変パラメータに自動追従)。\n_mode = str(globals().get('route_mode', 'float'))\nif _mode == 'hdl':\n    import numpy as np, sys, os\n    import time as _time\n    _SCRIPTS = r\"d:\\kamijo\\HiyoCanvas\\workspace-SAR-SIM\\scripts\"\n    if _SCRIPTS not in sys.path:\n        sys.path.insert(0, _SCRIPTS)\n    from verilator_route_b import route_b_pipeline\n    if not all(k in globals() for k in ('Q_IN', 'Q_FFT', 'Q_OUT')):\n        raise NameError(\"Q_IN/Q_FFT/Q_OUT undefined; enable 'FPGA Q-Format Config' (n60) first\")\n    _t0 = _time.monotonic()\n    print('Route HDL (Verilator): Q_IN=Q%d.%d  Q_FFT=Q%d.%d  Q_OUT=Q%d.%d' % (\n        Q_IN[0]-Q_IN[1], Q_IN[1], Q_FFT[0]-Q_FFT[1], Q_FFT[1], Q_OUT[0]-Q_OUT[1], Q_OUT[1]))\n    s_raw = route_b_pipeline(\n        fir_coefficients.astype(np.complex64),\n        ref_chirp.astype(np.complex64),\n        Q_IN=Q_IN, Q_FFT=Q_FFT, Q_OUT=Q_OUT, verbose=True)\n    print('Route HDL: s_raw=%s peak|s|=%.3f  (%.1fs total)' % (\n        s_raw.shape, float(np.abs(s_raw).max()), _time.monotonic() - _t0))\nelse:\n    print('[Route HDL] skipped (route_mode=%s)' % _mode)\n",
            "label": "FPGA Route HDL: Verilator (gate-level)"
          },
          "codeCollapsed": true,
          "executionOrder": 19
        },
        "width": 400,
        "style": {}
      }
