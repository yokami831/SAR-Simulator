      {
        "id": "n58",
        "type": "canvasNode",
        "position": {
          "x": 3249.6161636496636,
          "y": 975.7437420921627
        },
        "data": {
          "label": "Python Code",
          "category": "processing",
          "blockType": "python_code",
          "inputs": [
            {
              "id": "in_0",
              "label": "in_0",
              "portType": "any"
            }
          ],
          "outputs": [
            {
              "id": "out_0",
              "label": "out_0",
              "portType": "any"
            }
          ],
          "defaultParameters": {
            "code": "# === Level Diagram (SAR link budget waterfall, incl. LNA output) ===\n# Absolute power level [dBm] through each RF chain stage from HPA output all\n# the way down to the LNA *output*. Reads everything from the kernel namespace\n# so the plot tracks n25 (LNA), sar_visualizer (geometry), antenna params,\n# σ_max live. Shows the kTB·F noise floor as a horizontal line; the noise rises\n# by exactly G_LNA across the LNA, matching the physically-correct Friis\n# behaviour (SNR is preserved across the LNA — its NF is already baked into\n# kTB·F). This is the analytical link budget; the simulator's noise model in\n# n25 holds noise at an ADC-referred fixed level instead, so the simulator's\n# G_LNA only moves the signal (see n25 spec). The two diverge intentionally.\n#\n# Stages (per pulse, σ_ref point scatterer at slant range R0):\n#   1) HPA out         P_t                                      [dBm]\n#   2) TX feed out     P_t − L_tx_feed                          [dBm]\n#   3) EIRP            P_t − L_tx_feed + G_t                    [dBm]\n#   4) After uplink    EIRP − 10·log10(4πR0²)                   [dBm/m²]\n#   5) Target reflect  + σ_dBsm                                  [dBm]\n#   6) After downlink  − 10·log10(4πR0²)                        [dBm/m²]\n#   7) After RX ant    + 10·log10(Aeff), Aeff = G_r·λ²/(4π)      [dBm]\n#   8) LNA input       (signal at LNA terminal, before amp)      [dBm]\n#   9) LNA output      + G_LNA                                   [dBm]\n\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport io, base64\nfrom IPython.display import display\n\n# --- Dark-mode palette (Catppuccin Mocha) ---\nCP_BASE   = '#1e1e2e'\nCP_MANTLE = '#181825'\nCP_SURF   = '#313244'\nCP_TEXT   = '#cdd6f4'\nCP_SUB    = '#a6adc8'\nCP_OV     = '#6c7086'\nCP_SAPPH  = '#74c7ec'\nCP_PEACH  = '#fab387'\nCP_RED    = '#f38ba8'\nCP_YELLOW = '#f9e2af'\nCP_GREEN  = '#a6e3a1'\n\n# --- Design constants (kept in sync with n25 LNA hard-coded values) ---\nP_t_dbm      = 63.0       # HPA peak power [dBm] (~2 kW)\nL_tx_feed_db = 3.0        # Tx feedline / waveguide loss [dB]\neta_ant      = 0.6        # Antenna aperture efficiency\nT_K          = 290.0      # Reference noise temperature [K]\n\n# --- Live values from kernel namespace ---\nnf_db_v        = float(globals().get('nf_db',         3.0))\ng_lna_v        = float(globals().get('g_lna_db',    110.0))\nsigma_max_db_v = float(globals().get('sigma0_max_db', 0.0))\nsigma_dbsm     = sigma_max_db_v\n\n# --- Derived ---\nG_ant_dbi   = 10.0 * np.log10(4.0 * np.pi * eta_ant * La * Lr / (lam ** 2))\nAeff_m2     = (10.0 ** (G_ant_dbi / 10.0)) * (lam ** 2) / (4.0 * np.pi)\nAeff_db     = 10.0 * np.log10(Aeff_m2)\nL_oneway_db = 10.0 * np.log10(4.0 * np.pi * R0 ** 2)\nktbf_dbm    = -174.0 + 10.0 * np.log10(B) + nf_db_v\n\n# --- Build the chain through LNA output ---\nstages = []\nlvl = P_t_dbm;        stages.append(('HPA out',         lvl))\nlvl -= L_tx_feed_db;  stages.append(('TX feed out',     lvl))\nlvl += G_ant_dbi;     stages.append(('EIRP',            lvl))\nlvl -= L_oneway_db;   stages.append(('After uplink',    lvl))\nlvl += sigma_dbsm;    stages.append(('Target reflect',  lvl))\nlvl -= L_oneway_db;   stages.append(('After downlink',  lvl))\nlvl += Aeff_db;       stages.append(('After RX ant',    lvl))\nstages.append(('LNA input', lvl))\nlvl += g_lna_v;       stages.append(('LNA out',         lvl))\nlabels = [s[0] for s in stages]\nlevels = [s[1] for s in stages]\nn_st   = len(stages)\n\n# --- Noise: kTB·F at LNA input (NF already baked in); rises by G_LNA after LNA.\n# Drawn only on the receive side (idx 6..8) where it's physically meaningful.\nnoise_x = [6, 7, 8]\nnoise_y = [ktbf_dbm, ktbf_dbm, ktbf_dbm + g_lna_v]\n\n# --- Plot ---\nfig, ax = plt.subplots(figsize=(12.0, 5.6), facecolor=CP_BASE)\nax.set_facecolor(CP_MANTLE)\nax.grid(True, alpha=0.22, color=CP_OV, linewidth=0.6)\n\n# Signal trace\nax.plot(range(n_st), levels, '-o', color=CP_SAPPH, linewidth=2.2, markersize=8,\n        markerfacecolor=CP_SAPPH, markeredgecolor=CP_TEXT, markeredgewidth=0.6,\n        label='Signal level', zorder=3)\n\n# Noise trace (kTB·F at receiver, jumps with LNA gain)\nax.plot(noise_x, noise_y, '--o', color=CP_PEACH, linewidth=1.7, markersize=6,\n        alpha=0.9,\n        label='Noise floor  (kTB·F = %+.1f dBm @ B=%.0f MHz, NF=%.1f dB)  +G_LNA after LNA' %\n              (ktbf_dbm, B/1e6, nf_db_v),\n        zorder=2)\n\n# Inter-stage delta annotations\nfor i in range(1, n_st):\n    dl = levels[i] - levels[i-1]\n    if abs(dl) < 0.05:\n        continue\n    sign = '+' if dl >= 0 else ''\n    xm = (i - 1 + i) / 2\n    ym = (levels[i-1] + levels[i]) / 2\n    dy_off = 14 if dl >= 0 else -18\n    ax.annotate('%s%.1f dB' % (sign, dl),\n                xy=(xm, ym),\n                xytext=(0, dy_off), textcoords='offset points',\n                ha='center', fontsize=9, color=CP_SUB, zorder=4)\n\n# Axes styling\nax.set_xticks(range(n_st))\nax.set_xticklabels(labels, rotation=22, ha='right', color=CP_TEXT)\nax.tick_params(axis='y', colors=CP_TEXT)\nax.tick_params(axis='x', colors=CP_TEXT)\nax.set_ylabel('Level [dBm]', color=CP_TEXT, fontsize=11)\nax.set_title('SAR Link Budget Waterfall  (σ=%+.0f dBsm, R=%.1f km, λ=%.2f cm, ant %.1fx%.1f m, G_ant=%+.1f dBi, G_LNA=%+.1f dB)'\n             % (sigma_dbsm, R0/1e3, lam*100, La, Lr, G_ant_dbi, g_lna_v),\n             color=CP_TEXT, fontsize=10.5)\nfor sp in ax.spines.values():\n    sp.set_edgecolor(CP_OV)\n\n# Legend\nleg = ax.legend(loc='lower left', fontsize=9, facecolor=CP_SURF, edgecolor=CP_OV, labelcolor=CP_TEXT)\nleg.get_frame().set_alpha(0.92)\n\n# SNR boxes at LNA input and LNA output (identical — LNA preserves SNR)\nsnr_in_db  = levels[7] - ktbf_dbm\nsnr_out_db = levels[8] - (ktbf_dbm + g_lna_v)\ndef _snr_color(s):\n    return CP_GREEN if s >= 0 else CP_YELLOW if s >= -10 else CP_RED\nfor idx, snr in [(7, snr_in_db), (8, snr_out_db)]:\n    ax.annotate('SNR=%+.1f dB' % snr,\n                xy=(idx, levels[idx]),\n                xytext=(0, 22), textcoords='offset points',\n                ha='center', fontsize=9, color=_snr_color(snr),\n                bbox=dict(boxstyle='round,pad=0.25', facecolor=CP_SURF, edgecolor=CP_OV, alpha=0.9),\n                zorder=5)\n\n# Side note: matched-filter processing gain (downstream of this plot)\nax.text(0.99, 0.97,\n        'Matched filter downstream adds ≈ +60 dB processing gain\\n'\n        '(range comp +sqrt(Tp·B) + azimuth comp +sqrt(N_a)\\n'\n        '→ focused-image SNR ≈ SNR@LNAout + 60 dB)',\n        transform=ax.transAxes, ha='right', va='top', fontsize=8, color=CP_SUB,\n        bbox=dict(boxstyle='round,pad=0.35', facecolor=CP_SURF, edgecolor=CP_OV, alpha=0.85))\n\n# Side note: simulator noise modelling caveat\nax.text(0.01, 0.97,\n        'NOTE: simulator (n25) holds noise at an ADC-referred fixed level —\\n'\n        'so in the sim, G_LNA moves the signal but not the noise. This chart\\n'\n        'shows the physically-correct (Friis) view for reference.',\n        transform=ax.transAxes, ha='left', va='top', fontsize=8, color=CP_SUB,\n        bbox=dict(boxstyle='round,pad=0.35', facecolor=CP_SURF, edgecolor=CP_OV, alpha=0.85))\n\nfig.tight_layout()\nbuf = io.BytesIO()\nfig.savefig(buf, format='png', dpi=110, bbox_inches='tight', facecolor=fig.get_facecolor())\nplt.close(fig)\ndisplay({'image/png': base64.b64encode(buf.getvalue()).decode('ascii')}, raw=True)\n\nprint('Link budget waterfall:')\nfor lab, lvl in stages:\n    print('  %-16s  %+8.1f dBm' % (lab, lvl))\nprint('  %-16s  %+8.1f dBm  (kTB·F at LNA input)'  % ('Noise floor in',  ktbf_dbm))\nprint('  %-16s  %+8.1f dBm  (kTB·F + G_LNA)'        % ('Noise floor out', ktbf_dbm + g_lna_v))\nprint('  %-16s  %+8.1f dB'  % ('SNR @ LNA in',  snr_in_db))\nprint('  %-16s  %+8.1f dB'  % ('SNR @ LNA out', snr_out_db))\nprint('  (matched-filter processing gain ≈ +60 dB applied downstream)')\n",
            "label": "Level Diagram (Link Budget)"
          },
          "codeCollapsed": true,
          "barColor": "#f59e0b",
          "executionOrder": 20
        },
        "width": 1042,
        "style": {}
      },
